C pseudo2d.fC PSEUDO-SPECTRAL CALCULATION  -2D-C              CODED BY DR T. FURUMURA (HOKKAIDO UNIV. OF EDUCATION)C THIS CODE MUST BE LINKED WITH FFTFORT.F.C             (COMMENTED BY H. TAKENAKA ON 17 AUGUST 1992)C***********************************************************************C  PARAMETER                                                           *C***********************************************************************      PARAMETER ( ZERO = 0.0 , TRUE = 1   , FALSE = 0   )               C  NUMBER OF MESH GRIDS      PARAMETER ( NX = 256, NY = 256, NY2 = NY*2 )  C  MESH SIZE(m) AND INTERVAL OF TIME STEP(msecs)      PARAMETER ( DX = 1.5, DY = 1.5, DT = 0.05)        PARAMETER ( NTMAX = 1301  , NWRITE =   50  )       PARAMETER ( NSKIP = NTMAX/2, REDUCE = 8.0 ,NTSKP=NTMAX/NSKIP+1 )  C  SOURCE VOLUME AND SOURCE TIME FUNCTION (HERRMANN'S FUNCTION)      PARAMETER ( AX = DX    , AY = DY    , AT = 0.50   , T0 = AT*2  )*      PARAMETER ( alpha=1500.0,T0=0.15,lambda=1.0)    C  SOURCE POSITION      PARAMETER ( I0 =5*Nx/8, J0 = 5*Ny/8)                                    C  SOURCE MECHANISM (MOMENT TENSOR AND SINGLE FORCES)      PARAMETER ( RXX= 0.0, RXZ = 1.0, RZZ = 0.0, RFX = 0.0, RFZ = 0.0) C  NUMBER OF OBSERVATION POINTS FOR SEISMIC TRACES      PARAMETER ( NST = 55                              )               C      PARAMETER ( NXA =  20  , NYA =  20                )              C***********************************************************************C  DIMENSION                                                           *C***********************************************************************      REAL     SXX  (NX,NY) ,  SXY  (NX,NY)  ,   SYY  (NX,NY)                 REAL     EXX  (NX,NY) ,  EXY  (NX,NY)  ,   EYY  (NX,NY)                 EQUIVALENCE   ( SXX, EXX ), ( SYY, EYY ), ( SXY, EXY )                  REAL     DEN  (NX,NY) ,  RIG  (NX,NY)  ,   LAM  (NX,NY)                 REAL     UX   (NX,NY) ,  UY   (NX,NY)                                   REAL     UP   (NX,NY) ,  US   (NX,NY)                                   REAL     DXUX (NX,NY) ,  DXUY (NX,NY)                                   REAL     DYUX (NX,NY) ,  DYUY (NX,NY)                                   REAL     UXT1 (NX,NY) ,  UYT1 (NX,NY)                                   REAL     DXSXX(NX,NY) ,  DXSXY(NX,NY)                                   REAL     DYSXY(NX,NY) ,  DYSYY(NX,NY)                                   INTEGER  IMAP (NX,NY )                                                  EQUIVALENCE   ( SXX, DXSXX ), ( SYY, DYSYY )                            REAL     GGG  (NX,NY)                                                   REAL     CYWORK(NY2)   ,  CXWORK( NX )                                  REAL     UXALL  ( NST,NTSKP ) , UYALL  ( NST,NTSKP )                    REAL     UPALL  ( NST,NTSKP ) , USALL  ( NST,NTSKP )                    INTEGER  ISTX( NST )  , ISTY( NST )                                     REAL     SOX ( NST )  , SOY ( NST )                                     REAL     GX  ( NX )   , GY  ( NY )  	real tarray(2)                              *      CHARACTER*12 PTIME                                                *      CHARACTER*8  PDATE 	character*24   fdate                                               C********************************************************************** C   OUTPUT FILE NAME                                                  * C**********************************************************************       CHARACTER*20   ONAME, WNAME, PNAME                                      CHARACTER*80   TITLE                                                    INTEGER*4      ISPOUT ( 4 ) , ISPWAV ( 4 )                        C  NAMES OF FILES*      PNAME = 'SLAB2.PARM'                                              *      WNAME = 'FORSLAB9.WAV'                                                  ONAME = 'snap.out'                                              C  OBSERVATION POINTS FOR TRACES      DO 77  I = 1, NST                                                         ISTX ( I ) = 20 + (I-1) * 4                                             ISTY ( I ) =  1                                                   77  CONTINUE                                                          C  INPUT PARAMETERSC     READING STRUCTURAL MODEL      type*,'entering modelin'      call modelin(nx,ny,rig,lam,den)      type*,'leaving modelin'                                                                                                                       C********************************************************************** C     INITIAL CONDITION                                               * C********************************************************************** C                                                                       C     CALL DATE ( PDATE )       write(*,*) fdate()                                                    C     CALL CLOCK( PTIME,1 )                                             C                                                                             KX = NBEGI2( NX )                                                       KY = NBEGI2( NY )                                                 C COORDINATES OF OBSERVATION POINTS      DO 51 I = 1, NST                                                          SOX( I ) = ( ISTX(I) - 1 ) * DX                                         SOY( I ) = ( ISTY(I) - 1 ) * DY                                   51  CONTINUE                                                          C COORDINATE OF SOURCE LOCATION      STX = (I0-1)*DX                                                         STY = (J0-1)*DY                                                   C COORDINATES OF MESH GRID POINTS      DO 52 I = 1, NX                                                           GX ( I ) = ( I - 1 ) * DX                                         52  CONTINUE                                                                DO 53 J = 1, NY                                                           GY ( J ) = ( J - 1 ) * DY                                         53  CONTINUE                                                          C     TIME WHEN SOURCE TIME FUNCTION (HERRMANN'S FUNCTION)C     REDUCES TO ZERO AGAIN      FTMAX = T0 + AT*2                                                 C  INITIALIZE DISPLACEMENT FIELD & ITS TEMPORAL DERIVATIVE TO ZERO                                                                CALL   CLEAR ( UXT1  , NX, NY, ZERO )                                   CALL   CLEAR ( UYT1  , NX, NY, ZERO )                                   CALL   CLEAR ( UX    , NX, NY, ZERO )                                   CALL   CLEAR ( UY    , NX, NY, ZERO )                                                                                                           OPEN( 16, FILE=ONAME,     FORM = 'FORMATTED', STATUS='unknown',          &      ACCESS='SEQUENTIAL',IOSTAT=IER )                  IF( IER.NE.0 ) THEN                                                         WRITE ( 6,* ) ' FILE(16) CREATE ERR', IER                               STOP                                                                END IF                                                            C                                                                       C********************************************************************** C       ABSORBING  BOUNDARY CONDITION                                 * C**********************************************************************       APARA = 0.015                                                           DO 209  I = 1,NX                                                        DO 209  J = 1,NY                                                           IF( I .LT. NXA ) THEN                                                     GG = EXP( -( ( APARA * (NXA-I     ) )**2 ) )                          ELSE IF ( I .GT. ( NX-NXA+1 ) ) THEN                                      GG = EXP( -( ( APARA * (I-NX+NXA-1) )**2 ) )                          ELSE IF ( J .GT. ( NY-NYA+1 ) ) THEN                                      GG = EXP( -( ( APARA * (J-NY+NYA-1) )**2 ) ) *         elseif (j .lt. nya) then !top boundary damper*           GG = EXP( -( ( APARA * (NyA-j     ) )**2 ) )         ELSE                                                                      GG = 1.0                                                              END IF                                                                  GGG ( I,J ) = GG                                                209  CONTINUE                                                          C                                                                       C***********************************************************************C  TIME STEP START                                                     *C***********************************************************************C                                                                             NTW = 0       NTT = 0                                              C                                                                             DO  800  IT = 1, NTMAX                                            C                                                                             NTT = NTT + 1                                                           T     =   DT * (IT-1)                                                   NTW   =   NTW + 1                                                 C                                                                             CALL   DIFFX  ( UX, DXUX, CXWORK, NX, NY, KX, DX )                      CALL   DIFFX  ( UY, DXUY, CXWORK, NX, NY, KX, DX ) *      CALL   DIFFx ( UX, DYUX, CYWORK, NX, NY, KY, DY )           *      CALL   DIFFx ( UY, DYUY, CYWORK, NX, NY, KY, DY )                     CALL   DIFFYU ( UX, DYUX, CYWORK, NX, NY, KY, DY, NY2 )                 CALL   DIFFYU ( UY, DYUY, CYWORK, NX, NY, KY, DY, NY2 )           C                                                                             DO 4 I = 1,NX                                                           DO 4 J = 1,NY                                                              EXX ( I,J ) =   DXUX ( I,J )                                            EYY ( I,J ) =   DYUY ( I,J )                                            EXY ( I,J ) = ( DXUY ( I,J ) + DYUX ( I,J ) ) / 2.0             4    CONTINUE                                                                                                                                  *      IF ( NTT .EQ. NSKIP ) THEN                                        *       DO 25 NS = 1,NST                                                 *          NTT = 0                                                       *          ISX  =  ISTX ( NS )                                           *          ISY  =  ISTY ( NS )                                           *          IT1  =  IT / NSKIP + 1                                        *          UXALL ( NS,IT1 ) =   UX   ( ISX,ISY )                         *          UYALL ( NS,IT1 ) =   UY   ( ISX,ISY )                         *          UPALL ( NS,IT1 ) = ( DXUX ( ISX,ISY ) + DYUY ( ISX,ISY ) )    *          USALL ( NS,IT1 ) = ( DYUX ( ISX,ISY ) - DXUY ( ISX,ISY ) )    *  25  CONTINUE                                                          *      END IF                                                                                                                                          DO 5 I = 1,NX                                                           DO 5 J = 1,NY                                                              RAM1  = LAM ( I,J )                                                     RIG1  = RIG ( I,J ) * 2.0          EXXIJ = EXX ( I,J )                                                     EXYIJ = EXY ( I,J )                                                     EYYIJ = EYY ( I,J )                                                     SXX ( I,J )  = ( RAM1+RIG1 ) * EXXIJ  +  RAM1 * EYYIJ                   SYY ( I,J )  = ( RAM1+RIG1 ) * EYYIJ  +  RAM1 * EXXIJ                   SXY ( I,J )  =   RIG1 * EXYIJ                                     5  CONTINUE                                                        C                                                                             CALL   DIFFX  ( SXX, DXSXX, CXWORK, NX, NY, KX, DX )                    CALL   DIFFX  ( SXY, DXSXY, CXWORK, NX, NY, KX, DX )       CALL   DIFFYS ( SXY, DYSXY, CYWORK, NX, NY, KY, DY, NY2 )               CALL   DIFFYS ( SYY, DYSYY, CYWORK, NX, NY, KY, DY, NY2 )                      C *      call r1(amp,T)  !set source timefunction *      type*,' t,amp=',t,amp                                                                                                                                   DO 7 I =  1, NX                                                         DO 7 J =  1, NY                                                   C                                                                                GG   = GGG ( I,J )                                                      DEN1 = DEN ( I,J )                                             C *        set the body force term                                                                               FX1 =  ZERO                                                             FY1 =  ZERO                                                             IF ( T .LE. FTMAX )   THEN                                                FX1 = FX1                                                         &      + RXX * FXMXX ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )        &      + RXZ * FXMXZ ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )        &      + RFX * FX    ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )              FY1 = FY1                                                         &      + RZZ * FZMZZ ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )        &      + RXZ * FZMXZ ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )        &      + RFZ * FZ    ( I, J, I0, J0, DX, DY, AX, AY, T, T0, AT )            END IF *	  dj=(float(i-isx)**2+float(j-isz)**2)*lambda*	  FX1=amp*(float(i-I0))*exp(-dj)*	  FY1=amp*(float(j-J0))*exp(-dj)*         type*,'FX1,FY1=',FX1,FY1                                                                                      UXT2IJ  = ( DXSXX (I,J) + DYSXY ( I,J ) + FX1 ) / DEN1                  UYT2IJ  = ( DXSXY (I,J) + DYSYY ( I,J ) + FY1 ) / DEN1                                                                                          UXT1 ( I,J ) =  UXT1 ( I,J ) * GG + DT * UXT2IJ                         UYT1 ( I,J ) =  UYT1 ( I,J ) * GG + DT * UYT2IJ                                                                                                 UX   ( I,J ) =  UX   ( I,J ) * GG + DT * UXT1( I,J )                    UY   ( I,J ) =  UY   ( I,J ) * GG + DT * UYT1( I,J )                                                                                            UP   ( I,J ) =  DXUX ( I,J ) + DYUY ( I,J )                             US   ( I,J ) =  DXUY ( I,J ) - DYUX ( I,J )                                                                                              7   CONTINUE     C                                                                       C***********************************************************************C  WRITE  SNAP SHOT                                                    *C***********************************************************************C                                                                             IF( mod(it,Nwrite) .EQ. 0 ) THEN                                        *        NTW = ZERO       write(16,2100) T 2100 format(e10.3)      do 777 iy=1,ny         write(16,2400) (UP(ix,iy),ix=1,nx)  777 continue      do 999 iy=1,ny         write(16,2400) (US(ix,iy),ix=1,nx)  999 continue 2400 format(10e10.3)                                                     *        WRITE( 16 )  T                                                  *        WRITE( 16 )  UP, US                                                   END IF                                                            C                                                                       C***********************************************************************C  NEXT TIME STEP                                                      *C***********************************************************************C  	type*,'passed time step',it*	Pause 'passed time step'  800 CONTINUE                                                          C                                                                       C***********************************************************************C  WRITE  WAVEFORM                                                      C***********************************************************************C                                                                       *      WRITE( 26 ) UPALL,    USALL,                                      *     &            UXALL ,   UYALL                                       C                                                                             CLOSE( 16 )                                                       *      CLOSE( 26 )                                                       C                    	write(*,*) fdate(),etime(tarray)                                                                                              STOP                                                                    END                                                               C                                                                       C***********************************************************************C  ***********   END OF MAIN PROGRAM  *****************                *C***********************************************************************C                                                                       **	First deivative of a Gaussian function*	  subroutine r1(f,t)          parameter (t0=.15,alpha=25.1327,rtpi=1.77245)	  alp1=alpha*alpha*(t-t0)*(t-t0)	  ep=exp(-alp1)	  f=0.5*alpha*(1.-2.*alp1)*ep/rtPi	  return	  end	subroutine modelin(nx,ny,rig,lam,den)	real rig(nx,ny),lam(nx,ny),den(nx,ny)        real alpha0,beta0,alpha1,beta1        data  alpha0,alpha1,beta0,beta1/2.7,4.4,1.5,2.2/	ilx=3*nx/8	iux=nx/2	ily=3*ny/8	iuy=ny/2	do ix=1,nx	do iy=1,ny	  if (((ix .le. iux).and.(ix .ge. ilx)).and.((iy .le. iuy).and.     &          (iy .ge. ily))) then	    rig(ix,iy)=beta1*beta1	    lam(ix,iy)=2.0*alpha1*alpha1-rig(ix,iy)	    den(ix,iy)=1.0	  else	    rig(ix,iy)=beta0*beta0	    lam(ix,iy)=2.0*alpha0*alpha0-rig(ix,iy)	    den(ix,iy)=1.0	  endif	enddo	enddo  		return	end      REAL FUNCTION  FXMXZ ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )        X0 = I0 * DX                                                            Z0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX =  HERRMAN ( AX, X, X0 )                                            FHZ =-DHERRMAN ( AZ, Z, Z0 )                                            FHT =  HERRMAN ( AT, T, T0 )                                            FXMXZ  = FHX * FHZ * FHT                                                RETURN                                                                  END                                                                                                                                             REAL FUNCTION  FZMXZ ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )        X0 = I0 * DX                                                            Z0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX =-DHERRMAN ( AX, X, X0 )                                            FHZ =  HERRMAN ( AZ, Z, Z0 )                                            FHT =  HERRMAN ( AT, T, T0 )                                            FZMXZ  = FHX * FHZ * FHT                                                RETURN                                                                  END                                                                                                                                             REAL FUNCTION  FZMZZ ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )        X0 = I0 * DX                                                            Z0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX =  HERRMAN ( AX, X, X0 )                                            FHZ =-DHERRMAN ( AZ, Z, Z0 )                                            FHT =  HERRMAN ( AT, T, T0 )                                            FZMZZ  = FHX * FHZ * FHT                                                RETURN                                                                  END                                                                                                                                             REAL FUNCTION  FXMXX ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )        X0 = I0 * DX                                                            Z0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX =-DHERRMAN ( AX, X, X0 )                                            FHZ =  HERRMAN ( AZ, Z, Z0 )                                            FHT =  HERRMAN ( AT, T, T0 )                                            FXMXX   = FHX * FHZ * FHT                                               RETURN                                                                  END                                                                                                                                             REAL FUNCTION  FX ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )           X0 = I0 * DX                                                            Y0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX = HERRMAN ( AX, X, X0 )                                             FHZ = HERRMAN ( AZ, Z, Z0 )                                             FHT = HERRMAN ( AT, T, T0 )                                             FX  = FHX * FHZ * FHT                                                   RETURN                                                                  END                                                               C                                                                             REAL FUNCTION  FZ ( I, J, I0, J0, DX, DZ, AX, AZ, T, T0, AT )           X0 = I0 * DX                                                            Z0 = J0 * DZ                                                            X  = I  * DX                                                            Z  = J  * DZ                                                            FHX = HERRMAN ( AX, X, X0 )                                             FHZ = HERRMAN ( AY, Z, Z0 )                                             FHT = HERRMAN ( AT, T, T0 )                                             FZ  = FHX * FHZ * FHT                                                   RETURN                                                                  END                                                               C                                                                             REAL FUNCTION  HERRMAN ( A, X, X0 )                                     A2  = 2.0 * A                                                           T   = X - X0                                                            TD  = ( T + A2 ) / A                                                    IF( T .LE. -A2 ) THEN                                                       HERRMAN  = 0.0                                                          RETURN                                                              ELSE IF( (T .GT. -A2) .AND. (T .LE. -A) ) THEN                              HERRMAN  = ( 0.5 * TD**2 ) / A2                                         RETURN                                                              ELSE IF( (T .GT. -A ) .AND. (T .LE.  A) ) THEN                              HERRMAN  = ( -0.5 * TD**2 + 2.0 * TD - 1.0 ) / A2                       RETURN                                                              ELSE IF( (T .GT.  A ) .AND. (T .LE. A2) ) THEN                              HERRMAN  = (  0.5 * TD**2 - 4.0 * TD + 8.0 ) / A2                       RETURN                                                              ELSE                                                                        HERRMAN  = 0.0                                                          RETURN                                                              END IF                                                                  END                                                               C                                                                             REAL FUNCTION  DHERRMAN ( A, X, X0 )                                    A2  = 2.0 * A                                                           T   = X - X0                                                            TD  = ( T + A2 ) / A                                                    IF( T .LE. -A2 ) THEN                                                       DHERRMAN  = 0.0                                                         RETURN                                                              ELSE IF( (T .GT. -A2) .AND. (T .LE. -A) ) THEN                              DHERRMAN  = (       TD    ) / A2  * 2.0                                 RETURN                                                              ELSE IF( (T .GT. -A ) .AND. (T .LE.  A) ) THEN                              DHERRMAN  = (       -TD    + 2.0            ) / A2  * 2.0               RETURN                                                              ELSE IF( (T .GT.  A ) .AND. (T .LE. A2) ) THEN                              DHERRMAN  = (        TD    - 4.0            ) / A2  * 2.0               RETURN                                                              ELSE                                                                        DHERRMAN  = 0.0                                                         RETURN                                                              END IF                                                                  END                                                               C                                                                       C                                                                             INTEGER  FUNCTION NBEGI2( NX )                                    C     INPUT :  KX = 2**N                                                C     OUTPUT:  N                                                              NXX = NX                                                                KX = 0                                                                  DO 10 I = 1,NX                                                            KX = KX + 1                                                             NXX = NXX/2                                                             IF( NXX.EQ.1 ) GOTO 99                                             10 CONTINUE                                                             99 NBEGI2   =    KX                                                        RETURN                                                                  END                                                               C                                                                             SUBROUTINE   DIFFX ( A, B, WORK, NX, NY, KX, DX )                       REAL         A( NX,NY ) , B( NX,NY ) , WORK ( NX )                C                                                                             DO 100 J = 1, NY                                                                                                                                  DO 1 I = 1,NX                                                              WORK( I )  =  A ( I,J )                                       1      CONTINUE                                                                                                                                        CALL  FFTR ( WORK, KX, ILL )                                                                                                                    DKX = 6.283185 / NX / DX                                                NXD2 = NX / 2                                                                                                                                   WORK (      1  ) = 0.0                                                  WORK ( NXD2+1  ) = 0.0                                                                                                                          DO 2 I = 2, NXD2                                                          WC = -DKX*( I-1 ) * WORK (      I )                                     WS =  DKX*( I-1 ) * WORK ( NXD2+I )                                     WORK (      I ) = WS                                                    WORK ( NXD2+I ) = WC                                           2      CONTINUE                                                                                                                                        CALL  FFTRI ( WORK, KX, ILL )                                                                                                                   DO 3 I = 1,NX                                                             B ( I,J ) =  WORK ( I )                                        3      CONTINUE                                                                                                                                 100  CONTINUE                                                                                                                                        RETURN                                                                  END                                                               C                                                                             SUBROUTINE   DIFFYU ( A, B, WORK, NX, NY, KY, DY, NY2 )           C     DERIVATIVE BY SYMMETRIC DIFFERENTIATION METHOD      REAL         A( NX,NY ) , B( NX,NY )                                    REAL         WORK( NY2 )                                          C                                                                             DO 100 I = 1, NX                                                                                                                                  DO 1 J = 1, NY                                                            WORK ( NY-J+1 ) =  A ( I,J )                                            WORK ( NY+J   ) =  A ( I,J )                                   1      CONTINUE                                                                                                                                        CALL  FFTR ( WORK, KY+1, ILL )                                                                                                                  DKY = 6.283185 / NY2 / DY                                               NYD2 = NY2 / 2                                                                                                                                  WORK (      1  ) = 0.0                                                  WORK ( NYD2+1  ) = 0.0                                                                                                                          DO 2 J = 2, NYD2                                                          WC = -DKY*( J-1 ) * WORK (      J )                                     WS =  DKY*( J-1 ) * WORK ( NYD2+J )                                     WORK (      J ) = WS                                                    WORK ( NYD2+J ) = WC                                           2      CONTINUE                                                                                                                                        CALL  FFTRI ( WORK, KY+1, ILL )                                                                                                                 DO 3 J = 1, NY                                                            B ( I,J ) =  WORK ( NY+J )                                     3      CONTINUE                                                                                                                                 100  CONTINUE                                                                                                                                        RETURN                                                                  END                                                               C                                                                             SUBROUTINE   DIFFYS ( A, B, WORK, NX, NY, KY, DY, NY2 )                 REAL         A( NX,NY ) , B( NX,NY )                                    REAL         WORK( NY2 )                                          C                                                                             DO 100 I = 1, NX                                                                                                                                  DO 1 J = 1, NY                                                            WORK (    J ) =  0.0                                                    WORK ( NY+J ) =  A ( I,J )                                     1      CONTINUE                                                                                                                                        CALL  FFTR ( WORK, KY+1, INV, ILL )                                                                                                             DKY  = 6.283185 / NY2 / DY                                              NYD2 = NY2 / 2                                                                                                                                  WORK (      1  ) = 0.0                                                  WORK ( NYD2+1  ) = 0.0                                                                                                                          DO 2 J = 2, NYD2                                                          WC = -DKY*( J-1 ) * WORK (      J )                                     WS =  DKY*( J-1 ) * WORK ( NYD2+J )                                     WORK (      J ) = WS                                                    WORK ( NYD2+J ) = WC                                           2      CONTINUE                                                                                                                                        CALL  FFTRI ( WORK, KY+1, ILL )                                                                                                                 DO 3 J = 1, NY                                                            B ( I,J ) = WORK ( NY+J )                                      3      CONTINUE                                                                                                                                 100  CONTINUE                                                                                                                                        RETURN                                                                  END                                                               C                                                                             SUBROUTINE  CLEAR( A, NX, NY, VALUE )                                   REAL   A( NX,NY )                                                       DO 1 I = 1,NX                                                           DO 1 J = 1,NY                                                                A( I,J ) = VALUE                                              1    CONTINUE                                                                RETURN                                                                  END                                                               C                                                                             SUBROUTINE  CLEAR3( E, NX, NY, NK, VALUE )                              REAL   E( NX, NY ,NK )                                                  DO 1 I = 1,NX                                                           DO 1 J = 1,NY                                                           DO 1 K = 1,NK                                                                E( I,J,K) = VALUE                                             1    CONTINUE                                                                RETURN                                                                  END                                                               C                                                                             SUBROUTINE PADD ( A, NX, NY, NX0 ,NX1, NY0, NY1, VALUE )                REAL A( NX,NY )                                                         DO 1 I = NX0 , NX1                                                      DO 1 J = NY0 , NY1                                                           A( I,J ) = VALUE                                               1   CONTINUE                                                                RETURN                                                                  END                                                               