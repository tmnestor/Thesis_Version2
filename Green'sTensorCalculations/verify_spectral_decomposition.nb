Notebook[{

Cell[CellGroupData[{
Cell["\<\
Verification of Equation (3.12): Spectral Decomposition of the System Matrix\
\>", "Title",ExpressionUUID->"ff134dc1-2c62-4d4f-8e2b-ad2dd5d089e3"],

Cell["\<\
T.M. Nestor \[Dash] PhD Thesis (ANU, 1996)
Reference: basic_equations.pdf, Section 3.1\
\>", "Subtitle",ExpressionUUID->"146b6ce9-6670-4c79-abd6-761849d86216"],

Cell["\<\
This notebook verifies equation (3.12) from the thesis:
    A(kx, ky) \[Equivalent] Dz(kx, ky) . \[CapitalLambda](kx, ky) . \
Dz^(-1)(kx, ky)

where:
  \[Bullet] A is the 6\[Times]6 Fourier-domain system matrix [eq. (3.7) / \
label Akdef]
  \[Bullet] \[CapitalLambda] is the diagonal eigenvalue matrix [eq. (3.9) / \
label eigDef]
  \[Bullet] Dz is the eigen matrix whose columns are P, SV, SH eigenvectors \
[eqs. (3.13)-(3.15)]
  \[Bullet] Dz^(-1) is computed via the symplectic inverse [eq. (3.21) / \
label D1def]

We also verify:
  1. Each eigenvector satisfies A . v = \[Lambda] v
  2. The symplectic inverse formula Dz^(-1) = -i J6 . Dz^T(-kx,-ky) . J6
  3. The normalization condition [eq. (3.19) / label dinv2]\
\>", "Text",ExpressionUUID->"2dbce990-e784-4df3-8508-847e8703d938"],

Cell[CellGroupData[{

Cell["1. Symbols and Material Parameters", "Section",ExpressionUUID->"b54c6360-52fb-4b97-b3fb-2b360d580316"],

Cell["\<\
Define all symbolic variables. We work with generic (kx, ky, \[Omega], \
\[Rho], \[Alpha], \[Beta]) to keep the verification fully symbolic.\
\>", "Text",ExpressionUUID->"96c2e242-addb-4d96-a288-712712655b66"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Symbolic", " ", "variables"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "kx", ",", "ky", ",", "\[Omega]", ",", "\[Rho]", ",", "\[Alpha]", ",", 
     "\[Beta]"}], "}"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Derived", " ", "material", " ", "parameters", " ", 
    RowBox[{"(", 
     RowBox[{"Table", " ", "2.1", " ", "of", " ", "thesis"}], ")"}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"\[Gamma]", "=", 
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"\[Beta]", "^", "2"}], "/", 
     RowBox[{"\[Alpha]", "^", "2"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Zeta]", "=", 
   RowBox[{"4", "\[Rho]", 
    RowBox[{"\[Beta]", "^", "2"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"\[Beta]", "^", "2"}], "/", 
       RowBox[{"\[Alpha]", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Chi]", "=", 
   RowBox[{"2", "\[Rho]", 
    RowBox[{"\[Beta]", "^", "2"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", 
       RowBox[{"\[Beta]", "^", "2"}], "/", 
       RowBox[{"\[Alpha]", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"aParam", "=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"\[Rho]", 
      RowBox[{"\[Alpha]", "^", "2"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"bParam", "=", 
   RowBox[{"1", "/", 
    RowBox[{"(", 
     RowBox[{"\[Rho]", 
      RowBox[{"\[Beta]", "^", "2"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Mu]", "=", 
   RowBox[{"\[Rho]", 
    RowBox[{"\[Beta]", "^", "2"}]}]}], ";"}]}], "Input",
 CellLabel->
  "In[129]:=",ExpressionUUID->"79f964be-c288-4ec8-9089-ea7cb3bc9ea0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Vertical Wavenumbers", "Section",ExpressionUUID->"a118e074-69d8-4456-a2b8-7f93fc6167d9"],

Cell["\<\
The vertical wavenumbers for P, SV, and SH waves. Note kzS = kzH since S = H \
= \[Beta].\
\>", "Text",ExpressionUUID->"b5d5fcf6-9cd6-444a-b5d9-97bc13d0a8d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Effective", " ", "horizontal", " ", "wavenumbers", " ", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"eq", "."}], " ", 
      RowBox[{"(", "3.11", ")"}]}], "]"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"KhatP", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "\[Alpha]"}], ")"}], "^", "2"}], "-", 
       RowBox[{"ky", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"KhatS", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Omega]", "/", "\[Beta]"}], ")"}], "^", "2"}], "-", 
       RowBox[{"ky", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"KhatH", "=", "KhatS"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Vertical", " ", "wavenumbers", " ", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"eq", "."}], " ", 
       RowBox[{"(", "3.10", ")"}]}], "]"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"kzP", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"KhatP", "^", "2"}], "-", 
       RowBox[{"kx", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kzS", "=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"KhatS", "^", "2"}], "-", 
       RowBox[{"kx", "^", "2"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kzH", "=", "kzS"}], ";"}]}]}]], "Input",
 CellLabel->
  "In[137]:=",ExpressionUUID->"44143818-fc9f-45e2-bba4-c2ec3682f9b6"]
}, Open  ]],

