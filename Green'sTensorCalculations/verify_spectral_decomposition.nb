Cell[CellGroupData[{

Cell["8. Verify Symplectic Inverse [eq. (3.21)]", "Section",ExpressionUUID->"9e40f8e8-9b5c-431d-ad74-9ff0087d0a1e"],

Cell["\<\
Equation (3.21): Dz^(-1)(kx,ky) = -i J6 . Dz^T(-kx,-ky) . J6

First construct Dz(-kx,-ky) by substituting kx \[Rule] -kx, ky \[Rule] -ky.\
\>", "Text",
 CellChangeTimes->{
  3.981321428380443*^9},ExpressionUUID->"63846f86-99f2-4dce-ac42-\
f80536070e12"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Construct", " ", "Dz", " ", "at", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "kx"}], ",", 
      RowBox[{"-", "ky"}]}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"DzNeg", "=", 
     RowBox[{"Dz", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"kx", "->", 
         RowBox[{"-", "kx"}]}], ",", 
        RowBox[{"ky", "->", 
         RowBox[{"-", "ky"}]}]}], "}"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Symplectic", " ", "inverse"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"DzInvSymplectic", "=", 
     RowBox[{
      RowBox[{"-", "I"}], " ", 
      RowBox[{"J6", ".", 
       RowBox[{"Transpose", "[", "DzNeg", "]"}], ".", "J6"}]}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Direct", " ", "inverse"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nComputing Dz . DzInvSymplectic (should be \
I6)...\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"product", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"Dz", ".", "DzInvSymplectic"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\[Omega]", ">", "0"}], ",", 
          RowBox[{"\[Rho]", ">", "0"}], ",", 
          RowBox[{"\[Alpha]", ">", "0"}], ",", 
          RowBox[{"\[Beta]", ">", "0"}], ",", 
          RowBox[{"\[Alpha]", ">", "\[Beta]"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"product", "=", 
     RowBox[{
      RowBox[{"product", "//.", "dispRules"}], "//", "Simplify"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Dz . Dz^(-1) = \>\"", "]"}], ";"}], "\n", 
   RowBox[{"product", "//", "MatrixForm"}]}]}]], "Input",
 CellLabel->
  "In[168]:=",ExpressionUUID->"7f78b724-a1dc-4e16-a3e0-d8cc4313cffc"],

