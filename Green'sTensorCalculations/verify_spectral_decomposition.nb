Cell[CellGroupData[{

Cell["10. Numerical Spot Check", "Section",ExpressionUUID->"131fd177-5fa6-4bee-9528-b9e6b8f17b10"],

Cell["\<\
Substitute specific numerical values to confirm the symbolic result and catch \
any branch-cut subtleties.\
\>", "Text",ExpressionUUID->"1c765fc2-8f3d-480f-b546-8d9cbfba76aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Numerical", " ", "parameters", ":", " ", 
    RowBox[{"ocean", " ", "crust", " ", "model"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"numRules", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", "->", "3.0"}], ",", 
       RowBox[{"\[Alpha]", "->", "5.0"}], ",", 
       RowBox[{"\[Beta]", "->", "3.0"}], ",", 
       RowBox[{"\[Omega]", "->", 
        RowBox[{"2", "Pi", " ", "1.0"}]}], ",", 
       RowBox[{"kx", "->", "0.5"}], ",", 
       RowBox[{"ky", "->", "0.3"}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"AmatNum", "=", 
     RowBox[{"N", "[", 
      RowBox[{"Amat", "/.", "numRules"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DzNum", "=", 
     RowBox[{"N", "[", 
      RowBox[{"Dz", "/.", "numRules"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[CapitalLambda]Num", "=", 
     RowBox[{"N", "[", 
      RowBox[{"\[CapitalLambda]mat", "/.", "numRules"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"DzInvNum", "=", 
     RowBox[{"N", "[", 
      RowBox[{"DzInvSymplectic", "/.", "numRules"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"AReconNum", "=", 
     RowBox[{"DzNum", ".", "\[CapitalLambda]Num", ".", "DzInvNum"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"numResidual", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"Abs", "[", 
       RowBox[{"AmatNum", "-", "AReconNum"}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nNumerical spot check (\[Rho]=3, \[Alpha]=5, \
\[Beta]=3, \[Omega]=2\[Pi], kx=0.5, ky=0.3):\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Max |A - Dz.\[CapitalLambda].Dz^(-1)| = \>\"", ",", 
      RowBox[{"ScientificForm", "[", "numResidual", "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"numResidual", "<", 
       RowBox[{"10", "^", 
        RowBox[{"-", "12"}]}]}], ",", "\n", 
      RowBox[{
      "Print", "[", "\"\<  \[CheckmarkedBox] Numerical verification passed \
(residual < 10^-12)\>\"", "]"}], ",", "\n", 
      RowBox[{
      "Print", "[", "\"\<  \[WarningSign] Numerical residual exceeds \
tolerance!\>\"", "]"}]}], "\n", "]"}], ";"}]}]}]], "Input",
 CellLabel->
  "In[184]:=",ExpressionUUID->"1e1b7604-1d02-4399-8d71-dae03383b156"],

