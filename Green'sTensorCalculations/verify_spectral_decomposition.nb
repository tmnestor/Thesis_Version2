Cell[CellGroupData[{

Cell["12. Bonus: Verify Normalization Condition [eq. (3.19)]", "Section",ExpressionUUID->"b3efbb0f-4834-48fc-8f02-3e7daccd80ed"],

Cell["(J6 . Dz(-kx,-ky))^T . Dz(kx,ky) = i J6", "Text",ExpressionUUID->"ee7ae007-8067-4935-8bdf-86d9b5960f18"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"normProduct", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Transpose", "[", 
       RowBox[{"J6", ".", "DzNeg"}], "]"}], ".", "Dz"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Omega]", ">", "0"}], ",", 
        RowBox[{"\[Rho]", ">", "0"}], ",", 
        RowBox[{"\[Alpha]", ">", "0"}], ",", 
        RowBox[{"\[Beta]", ">", "0"}], ",", 
        RowBox[{"\[Alpha]", ">", "\[Beta]"}]}], "}"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"normProduct", "=", 
    RowBox[{
     RowBox[{"normProduct", "//.", "dispRules"}], "//", "Simplify"}]}], ";"}],
   "\n"}], "\n", 
 RowBox[{
  RowBox[{"normResidual", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"normProduct", "-", 
     RowBox[{"I", " ", "J6"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<\\nNormalization check: (J6.Dz(-kx,-ky))^T . Dz(kx,ky) - \
i J6 = \>\"", "]"}], ";"}], "\n", 
 RowBox[{"normResidual", "//", "MatrixForm"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"normResidual", "===", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"6", ",", "6"}], "}"}]}], "]"}]}], ",", "\n", 
    RowBox[{
    "Print", "[", "\"\<\[CheckmarkedBox] Normalization condition [eq. (3.19)] \
verified\>\"", "]"}], ",", "\n", 
    RowBox[{
    "Print", "[", "\"\<\[WarningSign] Normalization check FAILED\>\"", 
     "]"}]}], "\n", "]"}], ";"}]}], "Input",
 CellLabel->
  "In[199]:=",ExpressionUUID->"b47c795a-757f-4f06-8d63-a257102a0d0a"],

