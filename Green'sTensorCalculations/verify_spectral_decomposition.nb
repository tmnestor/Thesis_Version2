Cell["7. The Canonically Symplectic Array J6", "Section",ExpressionUUID->"3bf753cc-3b52-46f7-82e0-958362592aac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"J6", " ", "=", " ", 
    RowBox[{"antidiag", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"0", " ", "I3"}], ";", 
       RowBox[{
        RowBox[{"-", "I3"}], " ", "0"}]}], ")"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"J6", "=", 
     RowBox[{"ArrayFlatten", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"0", 
           RowBox[{"IdentityMatrix", "[", "3", "]"}]}], ",", 
          RowBox[{"IdentityMatrix", "[", "3", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"IdentityMatrix", "[", "3", "]"}]}], ",", 
          RowBox[{"0", 
           RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], "}"}]}], "}"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<J6 (symplectic matrix):\>\"", "]"}], ";"}], "\n", 
