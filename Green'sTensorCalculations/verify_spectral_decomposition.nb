Cell[CellGroupData[{

Cell["5. Eigenvectors: P, SV, SH waves [eqs. (3.13)-(3.15)]", "Section",ExpressionUUID->"46d579d4-185f-4ee1-99ac-247873ef47db"],

Cell["\<\
The normalization factors \[Epsilon]P, \[Epsilon]S, \[Epsilon]H are given by \
eq. (3.18) / label epsdef.\
\>", "Text",ExpressionUUID->"c90bf990-4a2b-488e-8f1b-595f4982ce73"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Normalization", " ", "factors", " ", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"eq", "."}], " ", 
      RowBox[{"(", "3.18", ")"}]}], "]"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]P", "=", 
     RowBox[{"1", "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"2", "\[Rho]", 
        RowBox[{"\[Omega]", "^", "2"}], "kzP"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Epsilon]S", "=", 
     RowBox[{"\[Omega]", "/", 
      RowBox[{"(", 
       RowBox[{"\[Beta]", " ", "KhatS", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", "\[Rho]", 
          RowBox[{"\[Omega]", "^", "2"}], "kzS"}], "]"}]}], ")"}]}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"\[Epsilon]H", "=", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"KhatH", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", "\[Rho]", 
          RowBox[{"\[Omega]", "^", "2"}], "kzH"}], "]"}]}], ")"}]}]}], 
    ";"}]}]}]], "Input",
 CellLabel->
  "In[149]:=",ExpressionUUID->"102f57fe-2e2b-4851-adb8-cbadf6afab85"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"P", "-", 
    RowBox[{"wave", " ", "eigenvectors", " ", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"eq", "."}], " ", 
       RowBox[{"(", "3.13", ")"}]}], "]"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"vPplus", "=", 
     RowBox[{"\[Epsilon]P", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"I", " ", "kzP"}], ",", 
        RowBox[{"I", " ", "kx"}], ",", 
        RowBox[{"I", " ", "ky"}], ",", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"kx", "^", "2"}]}], "+", 
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}], "-", 
           RowBox[{"\[Omega]", "^", "2"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "kzP"}], ",", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "ky", " ", "kzP"}]}], "}"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"vPminus", "=", 
     RowBox[{"\[Epsilon]P", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "I"}], " ", "kzP"}], ",", 
        RowBox[{"I", " ", "kx"}], ",", 
        RowBox[{"I", " ", "ky"}], ",", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"kx", "^", "2"}]}], "+", 
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}], "-", 
           RowBox[{"\[Omega]", "^", "2"}]}], ")"}]}], ",", 
        RowBox[{"2", "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "kzP"}], ",", 
        RowBox[{"2", "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "ky", " ", "kzP"}]}], "}"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"SV", "-", 
     RowBox[{"wave", " ", "eigenvectors", " ", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"eq", "."}], " ", 
        RowBox[{"(", "3.14", ")"}]}], "]"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"vSplus", "=", 
     RowBox[{"\[Epsilon]S", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"I", " ", "kx"}], ",", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "kzS"}], ",", "0", ",", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "kzS"}], ",", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Omega]", "^", "2"}], "-", 
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"kx", "^", "2"}]}], "-", 
           RowBox[{
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"-", "\[Rho]"}], 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "ky"}]}], "}"}]}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"vSminus", "=", 
     RowBox[{"\[Epsilon]S", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"I", " ", "kx"}], ",", 
        RowBox[{"I", " ", "kzS"}], ",", "0", ",", 
        RowBox[{"2", "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "kzS"}], ",", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Omega]", "^", "2"}], "-", 
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"kx", "^", "2"}]}], "-", 
           RowBox[{
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"-", "\[Rho]"}], 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "ky"}]}], "}"}]}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"SH", "-", 
     RowBox[{"wave", " ", "eigenvectors", " ", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{"eq", "."}], " ", 
        RowBox[{"(", "3.15", ")"}]}], "]"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"vHplus", "=", 
     RowBox[{"\[Epsilon]H", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "ky"}], " ", "kzH"}], ",", 
        RowBox[{
         RowBox[{"-", "kx"}], " ", "ky"}], ",", 
        RowBox[{"KhatH", "^", "2"}], ",", 
        RowBox[{"2", "I", " ", "ky", " ", "\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"kx", "^", "2"}]}], "+", 
           RowBox[{
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}], "-", 
           RowBox[{"\[Omega]", "^", "2"}]}], ")"}]}], ",", 
        RowBox[{
         RowBox[{"-", "2"}], "I", " ", "\[Rho]", 
         RowBox[{"\[Beta]", "^", "2"}], "kx", " ", "ky", " ", "kzH"}], ",", 
        RowBox[{"I", " ", "kzH", " ", "\[Rho]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Omega]", "^", "2"}], "-", 
           RowBox[{"2", 
            RowBox[{"\[Beta]", "^", "2"}], 
            RowBox[{"ky", "^", "2"}]}]}], ")"}]}]}], "}"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"vHminus", "=", 
     RowBox[{"\[Epsilon]H", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ky", " ", "kzH"}], ",", 
        RowBox[{
         RowBox[{"-", "kx"}], " ", "ky"}], ",", 
        RowBox[{"KhatH", "^", "2"}], ",", 
        RowBox[{"2", "I", " ", "ky", " ", "\[Rho]", 
