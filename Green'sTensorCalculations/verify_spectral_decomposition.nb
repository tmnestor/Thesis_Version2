Cell[CellGroupData[{

Cell["9. MAIN VERIFICATION: Equation (3.12)", "Section",ExpressionUUID->"44330be7-d173-415c-9398-b885e7f2d3d0"],

Cell["\<\
The spectral decomposition:
    A(kx, ky) = Dz(kx, ky) . \[CapitalLambda](kx, ky) . Dz^(-1)(kx, ky)

We compute the right-hand side and check it equals A.\
\>", "Text",ExpressionUUID->"8ab717e8-faeb-4e83-b93e-419b770051ff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<\\n\>\"", ",", "\"\<=== VERIFYING EQUATION (3.12) ===\>\"", 
    ",", "\"\<\\n\>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<Computing Dz . \[CapitalLambda] . Dz^(-1) ...\>\"", 
    "]"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Use", " ", "symplectic", " ", "inverse"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AReconstructed", "=", 
    RowBox[{"Dz", ".", "\[CapitalLambda]mat", ".", "DzInvSymplectic"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "residual", ":", " ", 
    RowBox[{"A", " ", "-", " ", 
     RowBox[{"Dz", ".", "\[CapitalLambda]", ".", 
      RowBox[{"Dz", "^", 
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}]}]}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"residualMat", "=", 
    RowBox[{"Amat", "-", "AReconstructed"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
