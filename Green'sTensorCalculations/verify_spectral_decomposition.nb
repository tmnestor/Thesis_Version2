Cell[CellGroupData[{

Cell["6. Verification: A . v = \[Lambda] v for each eigenvector", "Section",ExpressionUUID->"7e579587-ad38-4ea0-a351-530c0238f6f8"],

Cell["\<\
For each column of Dz, check that A . v_i = \[Lambda]_i v_i. We simplify \
using the identity kzP^2 = (\[Omega]/\[Alpha])^2 - kx^2 - ky^2 (and similarly \
for kzS).\
\>", "Text",ExpressionUUID->"ac239897-81c7-47d3-bd65-adb1f615889d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Simplification", " ", "rules", " ", "encoding", " ", "the", " ", 
    "dispersion", " ", "relations"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dispRules", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"kzP", "^", "2"}], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "\[Alpha]"}], ")"}], "^", "2"}], "-", 
         RowBox[{"kx", "^", "2"}], "-", 
         RowBox[{"ky", "^", "2"}]}]}], ",", 
       RowBox[{
        RowBox[{"kzS", "^", "2"}], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "\[Beta]"}], ")"}], "^", "2"}], "-", 
         RowBox[{"kx", "^", "2"}], "-", 
         RowBox[{"ky", "^", "2"}]}]}], ",", 
       RowBox[{
        RowBox[{"kzH", "^", "2"}], "->", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Omega]", "/", "\[Beta]"}], ")"}], "^", "2"}], "-", 
         RowBox[{"kx", "^", "2"}], "-", 
         RowBox[{"ky", "^", "2"}]}]}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"eigenvalues", "=", 
     RowBox[{"Diagonal", "[", "\[CapitalLambda]mat", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"eigenvecs", "=", 
     RowBox[{"{", 
      RowBox[{
      "vPplus", ",", "vSplus", ",", "vHplus", ",", "vPminus", ",", "vSminus", 
       ",", "vHminus"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"labels", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<|+,P\[RightAngleBracket]\>\"", 
       ",", "\"\<|+,S\[RightAngleBracket]\>\"", 
       ",", "\"\<|+,H\[RightAngleBracket]\>\"", 
       ",", "\"\<|-,P\[RightAngleBracket]\>\"", 
       ",", "\"\<|-,S\[RightAngleBracket]\>\"", 
       ",", "\"\<|-,H\[RightAngleBracket]\>\""}], "}"}]}], ";"}], "\n", "\n", 
   
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\nChecking A.v = \[Lambda] v for each \
eigenvector:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"v", ",", "\[Lambda]", ",", "residual"}], "}"}], ",", "\n", 
        RowBox[{
         RowBox[{"v", "=", 
          RowBox[{"eigenvecs", 
           RowBox[{"[", "["}], "j", 
           RowBox[{"]", "]"}]}]}], ";", "\n", 
         RowBox[{"\[Lambda]", "=", 
          RowBox[{"eigenvalues", 
           RowBox[{"[", "["}], "j", 
           RowBox[{"]", "]"}]}]}], ";", "\n", 
         RowBox[{"residual", "=", 
          RowBox[{
           RowBox[{"Amat", ".", "v"}], "-", 
           RowBox[{"\[Lambda]", " ", "v"}]}]}], ";", "\n", 
         RowBox[{"residual", "=", 
          RowBox[{"FullSimplify", "[", 
           RowBox[{"residual", ",", 
            RowBox[{"Assumptions", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Omega]", ">", "0"}], ",", 
               RowBox[{"\[Rho]", ">", "0"}], ",", 
               RowBox[{"\[Alpha]", ">", "0"}], ",", 
               RowBox[{"\[Beta]", ">", "0"}], ",", 
               RowBox[{"\[Alpha]", ">", "\[Beta]"}]}], "}"}]}]}], "]"}]}], ";",
          "\n", 
         RowBox[{"residual", "=", 
          RowBox[{"residual", "//.", "dispRules"}]}], ";", "\n", 
         RowBox[{"residual", "=", 
          RowBox[{"Simplify", "[", "residual", "]"}]}], ";", "\n", 
         RowBox[{"Print", "[", 
          RowBox[{
           RowBox[{"labels", 
            RowBox[{"[", "["}], "j", 
            RowBox[{"]", "]"}]}], ",", "\"\<: A.v - \[Lambda]v = \>\"", ",", 
           "residual"}], "]"}]}]}], "]"}], ",", "\n", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "6"}], "}"}]}], "]"}], ";"}]}]}]], "Input",\

 CellLabel->
  "In[160]:=",ExpressionUUID->"5f4193a0-4fdc-4aca-96bc-8acf9945ef24"],

