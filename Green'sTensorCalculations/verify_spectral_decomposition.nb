Cell[CellGroupData[{

Cell["11. Bonus: Verify Quasi-Hamiltonian Symmetry [eq. (3.8)]", "Section",ExpressionUUID->"be2d6773-0a99-4d6f-80b0-85cab4dbe58a"],

Cell["A^T(-kx,-ky) . J6 + J6 . A(kx,ky) = 0_6", "Text",ExpressionUUID->"07f73e05-bea7-4a76-b85b-e9873adced3d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AmatNeg", "=", 
   RowBox[{"Amat", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"kx", "->", 
       RowBox[{"-", "kx"}]}], ",", 
      RowBox[{"ky", "->", 
       RowBox[{"-", "ky"}]}]}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hamiltonianResidual", "=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "AmatNeg", "]"}], ".", "J6"}], "+", 
      RowBox[{"J6", ".", "Amat"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<\\nHamiltonian symmetry check: A^T(-kx,-ky).J6 + \
J6.A(kx,ky) = \>\"", "]"}], ";"}], "\n", 
 RowBox[{"hamiltonianResidual", "//", "MatrixForm"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"hamiltonianResidual", "===", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"6", ",", "6"}], "}"}]}], "]"}]}], ",", "\n", 
    RowBox[{
    "Print", "[", "\"\<\[CheckmarkedBox] Quasi-Hamiltonian symmetry \
verified\>\"", "]"}], ",", "\n", 
    RowBox[{
    "Print", "[", "\"\<\[WarningSign] Hamiltonian symmetry check FAILED\>\"", 
     "]"}]}], "\n", "]"}], ";"}]}], "Input",
 CellLabel->
  "In[194]:=",ExpressionUUID->"f1a3da7a-fa50-44db-baa2-3564ce59f8e8"],

