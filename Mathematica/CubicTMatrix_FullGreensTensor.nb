Cell[CellGroupData[{

Cell["\<\
(* Geometric constants for cube: dimensionless surface integrals *)
(* On face x_l=a, after u=x/a substitution: *)
(* j1 = \[Integral] du dv/(1+u^2+v^2)^(3/2) over [-1,1]^2 *)
(* j2 = \[Integral] u^2 du dv/(1+u^2+v^2)^(5/2) *)
(* k1 = \[Integral] du dv/(1+u^2+v^2)^(5/2) *)

j1cube = Integrate[1/(1 + u^2 + v^2)^(3/2), {u, -1, 1}, {v, -1, 1}];
j2cube = Integrate[u^2/(1 + u^2 + v^2)^(5/2), {u, -1, 1}, {v, -1, 1}];
k1cube = Integrate[1/(1 + u^2 + v^2)^(5/2), {u, -1, 1}, {v, -1, 1}];

Print[\"\\nGeometric constants (cube):\"];
Print[\"j1 = \", j1cube, \"  (analytic: 2\[Pi]/3 = \", N[2 Pi/3], \")\"];
Print[\"j2 = \", j2cube];
Print[\"k1 = \", k1cube];
Print[\"\\nTrace check: k1 + 2 j2 = \", Simplify[k1cube + 2 j2cube], \"  \
(should be 2\[Pi]/3)\"];
Print[\"Cubic anisotropy factor: 3 j2 - k1 = \", Simplify[3 j2cube - k1cube], \
\"  (=0 for sphere)\"];\
\>", "Input",
 CellLabel->"In[94]:=",ExpressionUUID->"08bcfbf4-2f97-46be-9e01-9d799d381a55"],

