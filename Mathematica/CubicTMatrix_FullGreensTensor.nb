Cell[CellGroupData[{

Cell["6. Second Derivative Integrals: A, B, C Decomposition", "Section",ExpressionUUID->"e8c970a9-eb61-451f-8282-a043b0c33a66"],

Cell["\<\
Smooth polynomial part: I^smooth_{ijkl} from \[CapitalPhi](r^2), \
\[CapitalPsi](r^2). The FULL integral tensor is I = I^stat + I^smooth.\
\>", "Text",ExpressionUUID->"0ba6b522-4e58-4be8-a212-c3aeb7709a98"],

Cell[CellGroupData[{

Cell["\<\
(* Second derivatives of smooth Green's tensor *)
Gsijkl[i_, j_, k_, l_] := Expand[D[Gs[i, j], xx[[k]], xx[[l]]]];

Print[\"Computing I_1111, I_1122, I_1212 ...\"];
I1111 = integrateCube[Gsijkl[1, 1, 1, 1]];
I1122 = integrateCube[Gsijkl[1, 1, 2, 2]];
I1212 = integrateCube[Gsijkl[1, 2, 1, 2]];

Print[\"I_1111 = \", I1111];
Print[\"I_1122 = \", I1122];
Print[\"I_1212 = \", I1212];\
\>", "Input",
 CellLabel->
  "In[141]:=",ExpressionUUID->"2d4f8bac-5466-4b1b-9f3d-c24a439bc739"],

