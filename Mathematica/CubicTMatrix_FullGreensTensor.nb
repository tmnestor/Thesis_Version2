Cell[CellGroupData[{

Cell["12. Static vs Dynamic Contributions", "Section",ExpressionUUID->"8d256002-1834-4985-8f7a-00fb2af6e06e"],

Cell[CellGroupData[{

Cell["\<\
(* Leading-order Taylor coefficients *)
\[Phi]0 = \[Phi]Coeffs[[1]];
\[Psi]0 = \[Psi]Coeffs[[1]];

Print[\"\\nLeading Taylor coefficients:\"];
Print[\"\[Phi]_0 = \", \[Phi]0];
Print[\"\[Psi]_0 = \", \[Psi]0];
Print[\"\\n\[Phi]_0 is purely imaginary, proportional to I \[Omega]/\[Beta]^3\
\"];
Print[\"\[Psi]_0 is purely imaginary, proportional to (I \[Omega])^3 [1/\
\[Alpha]^5 - 1/\[Beta]^5]\"];
Print[\"\\nThese give the RADIATION CORRECTIONS to the static Eshelby result.\
\"];\
\>", "Input",
 CellLabel->
  "In[263]:=",ExpressionUUID->"a8337bc3-d7af-460e-82ad-629bc6ff163f"],

