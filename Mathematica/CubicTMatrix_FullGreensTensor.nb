Cell[CellGroupData[{

Cell["3. Cube Moments and Cubic Anisotropy", "Section",ExpressionUUID->"2189a682-d5c2-4c51-8941-c453e19919d8"],

Cell["\<\
The fourth-rank moment tensor of the cube introduces cubic anisotropy via \
E_ijkl (=1 when all indices equal, 0 otherwise).\
\>", "Text",ExpressionUUID->"c34e95c2-9d00-4e11-838c-d2aab90c116d"],

Cell[CellGroupData[{

Cell["\<\
(* Cube moment *)
cubeMoment[p1_, p2_, p3_] := If[
  OddQ[p1] || OddQ[p2] || OddQ[p3], 0,
  (2 a^(p1 + 1)/(p1 + 1))(2 a^(p2 + 1)/(p2 + 1))(2 a^(p3 + 1)/(p3 + 1))];

Vcube = cubeMoment[0, 0, 0];
Print[\"Cube volume: \", Vcube];

(* Fourth moments -- cubic anisotropy *)
m4iiii = cubeMoment[4, 0, 0];
m4iijj = cubeMoment[2, 2, 0];
Print[\"\\nInt x1^4 = \", m4iiii];
Print[\"Int x1^2 x2^2 = \", m4iijj];
Print[\"\\nIsotropy ratio m4_iiii/(3 m4_iijj) = \", Simplify[m4iiii/(3 \
m4iijj)], \" (=1 for sphere)\"];

Pcoeff = m4iijj;
Qcoeff = Simplify[m4iiii - 3 m4iijj];
Print[\"\\nP (isotropic) = \", Pcoeff];
Print[\"Q (cubic anisotropy) = \", Qcoeff];\
\>", "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"30e03591-9589-4f81-b272-48347d11f3c2"],

