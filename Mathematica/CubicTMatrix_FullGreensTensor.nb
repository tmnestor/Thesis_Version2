Cell[CellGroupData[{

Cell["\<\
(* Verify symmetries *)
I2222 = integrateCube[Gsijkl[2, 2, 2, 2]];
I1221 = integrateCube[Gsijkl[1, 2, 2, 1]];
Print[\"\\nCubic symmetry: I_1111 - I_2222 = \", Simplify[I1111 - I2222]];
Print[\"Minor symmetry: I_1212 - I_1221 = \", Simplify[I1212 - I1221]];

(* Smooth polynomial part *)
AcSmooth = I1122;
BcSmooth = I1212;
CcSmooth = Simplify[I1111 - I1122 - 2 I1212];

Print[\"\\nSmooth polynomial (radiation) part:\"];
Print[\"A_smooth = \", AcSmooth];
Print[\"B_smooth = \", BcSmooth];
Print[\"C_smooth = \", CcSmooth];

(* FULL = static Eshelby + smooth polynomial *)
Ac = Astat + AcSmooth;
Bc = Bstat + BcSmooth;
Cc = Cstat + CcSmooth;

Print[\"\\n========================================\"];
Print[\"FULL INTEGRAL TENSOR (static + dynamic)\"];
Print[\"========================================\"];
Print[\"A = A_stat + A_smooth = \", Ac];
Print[\"B = B_stat + B_smooth = \", Bc];
Print[\"C = C_stat + C_smooth = \", Cc];\
\>", "Input",
 CellLabel->
  "In[152]:=",ExpressionUUID->"2bac994e-1e48-4cd1-935f-926acb0f5045"],

