Cell[CellGroupData[{

Cell["10. Numerical Verification", "Section",ExpressionUUID->"187ab46d-d555-4f69-83c0-493a15b47383"],

Cell[CellGroupData[{

Cell["\<\
(* Seismological units: km/s for velocities, g/cm^3 for density *)
(* \[Mu] = \[Rho] \[Beta]^2, \[Lambda] = \[Rho](\[Alpha]^2 - 2\[Beta]^2) *)
params = {
  \[Alpha] -> 5.0, \[Beta] -> 3.0, \[Rho] -> 2.5,
  \[Omega] -> 2 Pi 10.0, a -> 0.01,
  \[CapitalDelta]\[Lambda] -> 1.25, \[CapitalDelta]\[Mu] -> 0.75};

kSa = \[Omega] a/\[Beta] /. params;
kPa = \[Omega] a/\[Alpha] /. params;
\[Mu]bg = \[Rho] \[Beta]^2 /. params;
\[Lambda]bg = \[Rho] (\[Alpha]^2 - 2 \[Beta]^2) /. params;
Print[\"Seismological units: km/s, g/cm^3\"];
Print[\"Background: \[Alpha]=\", \[Alpha] /. params, \" km/s, \[Beta]=\", \
\[Beta] /. params, \" km/s, \[Rho]=\", \[Rho] /. params];
Print[\"\[Mu] = \[Rho]\[Beta]^2 = \", \[Mu]bg, \", \[Lambda] = \
\[Rho](\[Alpha]^2-2\[Beta]^2) = \", \[Lambda]bg];
Print[\"k_S a = \", kSa, \", k_P a = \", kPa];

AcNum = Ac /. params;
BcNum = Bc /. params;
CcNum = Cc /. params;
T1Num = T1 /. params;
T2Num = T2 /. params;
T3Num = T3 /. params;

Print[\"\\n========================================\"];
Print[\"NUMERICAL RESULTS (static + dynamic)\"];
Print[\"========================================\"];
Print[\"A = \", AcNum];
Print[\"B = \", BcNum];
Print[\"C = \", CcNum];
Print[\"\\nRe[A] = \", Re[AcNum], \", Im[A] = \", Im[AcNum]];
Print[\"Re[C] = \", Re[CcNum], \", Im[C] = \", Im[CcNum]];
Print[\"\\nT1 = \", T1Num];
Print[\"T2 = \", T2Num];
Print[\"T3 = \", T3Num];\
\>", "Input",
 CellLabel->
  "In[228]:=",ExpressionUUID->"8defc834-70ee-42a8-a3c6-315a7f74d81f"],

