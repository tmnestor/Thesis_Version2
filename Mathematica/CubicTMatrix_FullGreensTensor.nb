Cell[CellGroupData[{

Cell["\<\
(* Static A, B, C from surface integral derivation: *)
(* I^stat_1111 = 2(-a0 j1 + b0(2 j1 - 3 k1)) *)
(* I^stat_1122 = 2(-a0 j1 - 3 b0 j2) *)
(* I^stat_1212 = 2 b0 (j1 - 3 j2) *)
Astat = 2 (-a0stat j1cube - 3 b0stat j2cube);
Bstat = 2 b0stat (j1cube - 3 j2cube);
Cstat = 6 b0stat (3 j2cube - k1cube);

Print[\"\\n========================================\"];
Print[\"STATIC ESHELBY DEPOLARIZATION\"];
Print[\"========================================\"];
Print[\"A_stat = \", Simplify[Astat]];
Print[\"B_stat = \", Simplify[Bstat]];
Print[\"C_stat = \", Simplify[Cstat]];
Print[\"\\nC_stat/B_stat = \", Simplify[Cstat/Bstat]];
Print[\"(Nonzero \[DoubleRightArrow] cube \[NotEqual] sphere)\"];\
\>", "Input",
 CellLabel->
  "In[110]:=",ExpressionUUID->"fa15cc3c-e24a-47cc-84a9-3ba06d86644a"],

