Cell["\<\
Export key results in LaTeX format for the accompanying document.\
\>", "Text",ExpressionUUID->"b5b2c3d4-e5f6-7890-abcd-ef1234567915"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ",
