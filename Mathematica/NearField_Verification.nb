Cell[CellGroupData[{

Cell["5. Explicit Form of the Near-Field Term", "Section",ExpressionUUID->"d4b2c3d4-e5f6-7890-abcd-ef1234567911"],

Cell["\<\
We display the near-field term (Eq. 5) and the complete near-source \
asymptotic (Eq. 6) in matrix form, using the constraint \
\[Gamma]\[CenterDot]\[Gamma] = 1.\
\>", "Text",ExpressionUUID->"e4b2c3d4-e5f6-7890-abcd-ef1234567912"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{"Display", " ", "Eq", " ",
    RowBox[{"(", "5", ")"}]}], " ", "*)"}], "\n",
  RowBox[{"Print", "[",
   RowBox[{
   "\"\<\\nEq. (5) \[LongDash] Near-field term only:\\n\>\""}], "]"}]}], "\n",
 RowBox[{
  RowBox[{"MatrixForm", "[", "Geq5", "]"}]}], "\n",
 RowBox[{"\n",
  RowBox[{"(*", " ",
   RowBox[{"Display", " ", "Eq", " ",
    RowBox[{"(", "6", ")"}]}], " ", "*)"}], "\n",
  RowBox[{"Print", "[",
   RowBox[{
   "\"\<\\nEq. (6) \[LongDash] Complete near-source asymptotic:\\n\>\""}],
   "]"}]}], "\n",
 RowBox[{"MatrixForm", "[", "Geq6", "]"}]}], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"f4b2c3d4-e5f6-7890-abcd-ef1234567913"]
}, Open  ]]
}, Open  ]],

