    RowBox[{"(", "5", ")"}]}], " ", "*)"}], "\n",
  RowBox[{"Print", "[",
   RowBox[{"\"\<Eq. (5) LaTeX:\\n\>\""}], "]"}]}], "\n",
 RowBox[{"Print", "[",
  RowBox[{"TeXForm", "[",
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}],
     RowBox[{"8", "\[Pi]", " ", "\[Mu]", " ", "R"}]],
    RowBox[{"(",
     RowBox[{"1", "-",
      FractionBox[
       SuperscriptBox["\[Beta]", "2"],
       SuperscriptBox["\[Alpha]", "2"]]}], ")"}],
    RowBox[{"(",
     RowBox[{"I3", "-",
      RowBox[{"3", "\[Gamma]\[Gamma]"}]}], ")"}]}], "]"}], "]"}], "\n",
 RowBox[{"\n",
  RowBox[{"(*", " ",
   RowBox[{"LaTeX", " ", "export", " ", "of", " ", "Eq", " ",
    RowBox[{"(", "6", ")"}]}], " ", "*)"}], "\n",
  RowBox[{"Print", "[",
   RowBox[{"\"\<\\nEq. (6) LaTeX:\\n\>\""}], "]"}]}], "\n",
 RowBox[{"Print", "[",
  RowBox[{"TeXForm", "[",
   RowBox[{
    FractionBox["1",
     RowBox[{"8", "\[Pi]", " ", "\[Mu]", " ", "R"}]],
    RowBox[{"(",
     RowBox[{
      RowBox[{
       RowBox[{"(",
        RowBox[{"1", "+",
         FractionBox[
          SuperscriptBox["\[Beta]", "2"],
          SuperscriptBox["\[Alpha]", "2"]]}], ")"}], "I3"}], "+",
      RowBox[{
       RowBox[{"(",
        RowBox[{"1", "-",
         FractionBox[
          SuperscriptBox["\[Beta]", "2"],
          SuperscriptBox["\[Alpha]", "2"]]}], ")"}],
       "\[Gamma]\[Gamma]"}]}], ")"}]}], "]"}], "]"}]}], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"c5b2c3d4-e5f6-7890-abcd-ef1234567916"]
