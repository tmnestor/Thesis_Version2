Cell[CellGroupData[{

Cell["7. Summary of Verifications", "Section",ExpressionUUID->"d5b2c3d4-e5f6-7890-abcd-ef1234567917"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"results", "=",
   RowBox[{"{", "\n",
    RowBox[{
     RowBox[{"{",
      RowBox[{
      "\"\<Taylor[G_exact] = Eq.(6)\>\"", ",", "isZero1"}], "}"}], ",", "\n",
     RowBox[{"{",
      RowBox[{
      "\"\<Eq.(6) = Eq.(5) + G_far\>\"", ",", "isZero2"}], "}"}], ",", "\n",
     RowBox[{"{",
      RowBox[{
      "\"\<1-\[Beta]\[Superscript]2/\[Alpha]\[Superscript]2 = \
(\[Lambda]+\[Mu])/(\[Lambda]+2\[Mu])\>\"", ",",
       RowBox[{"test3", "===", "0"}]}], "}"}], ",", "\n",
     RowBox[{"{",
      RowBox[{
      "\"\<1/R\[Superscript]3, 1/R\[Superscript]2 cancel\>\"", ",",
       "isZeroR3"}], "}"}]}], "\n", "}"}]}], ";"}], "\n",
 RowBox[{"Grid", "[",
  RowBox[{
   RowBox[{"Prepend", "[",
    RowBox[{
     RowBox[{"Map", "[",
      RowBox[{
       RowBox[{
        RowBox[{"{",
         RowBox[{
          RowBox[{"#", "[",
           RowBox[{"[", "1", "]"}], "]"}], ",",
          RowBox[{"If", "[",
           RowBox[{
            RowBox[{"#", "[",
             RowBox[{"[", "2", "]"}], "]"}], ",",
            RowBox[{"Style", "[",
             RowBox[{"\"\<PASS\>\"", ",", "Bold", ",",
              RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",",
            RowBox[{"Style", "[",
             RowBox[{"\"\<FAIL\>\"", ",", "Bold", ",", "Red"}], "]"}]}],
           "]"}]}], "}"}], "&"}], ",", "results"}], "]"}], ",",
     RowBox[{"{",
      RowBox[{
       RowBox[{"Style", "[",
        RowBox[{"\"\<Verification\>\"", ",", "Bold"}], "]"}], ",",
       RowBox[{"Style", "[",
        RowBox[{"\"\<Result\>\"", ",", "Bold"}], "]"}]}], "}"}]}], "]"}],
   ",", "\n",
   RowBox[{"Frame", "->", "All"}], ",",
   RowBox[{"Spacings", "->",
    RowBox[{"{",
     RowBox[{"2", ",", "1"}], "}"}]}], ",",
   RowBox[{"Alignment", "->",
    RowBox[{"{",
     RowBox[{"Left", ",", "Center"}], "}"}]}]}], "]"}]}], "Input",
 CellLabel->"In[35]:=",ExpressionUUID->"e5b2c3d4-e5f6-7890-abcd-ef1234567918"]
