Cell[CellGroupData[{

Cell["12. Summary of All Verifications", "Section",ExpressionUUID->"fc1e8b1b-57b0-4a24-a4ab-be9e8e22161e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Collect", " ", "all", " ", "test", " ", "results"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"allTests", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<P-wave downgoing = P dyad\>\"", ",", "testPdnDyad"}], 
      "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<P-wave upgoing = P dyad\>\"", ",", "testPupDyad"}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"\"\<S-wave downgoing = transverse projector\>\"", ",", 
       "testSdnProj"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<S-wave upgoing = transverse projector\>\"", ",", 
       "testSupProj"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Orthogonality (all 6 dot products = 0)\>\"", ",", 
       "testOrtho"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Projector = SV dyad + SH dyad (downgoing)\>\"", ",", 
       "testProjPlus"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<Projector = SV dyad + SH dyad (upgoing)\>\"", ",", 
       "testProjMinus"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<S-wave downgoing = SV + SH dyads (A.25)\>\"", ",", 
