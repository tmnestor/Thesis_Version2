Cell[CellGroupData[{

Cell["4. S-Wave Transverse Projector (Eqns. A.19-A.21)", "Section",ExpressionUUID->"746a92e7-e81c-4d11-93e9-7f0c7fca07a2"],

Cell["\<\
The S-wave matrix should factorise as a transverse projector, giving the \
S-wave contribution scaled by a scalar prefactor.\
\>", "Text",ExpressionUUID->"91086e86-a2c1-4e7c-bb87-427e3cf45f09"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"S", "-", 
    RowBox[{"wave", " ", "propagation", " ", "vectors", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".19"}], ")"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"qPlus", "=", 
   RowBox[{"{", 
    RowBox[{"\[Nu]T", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"qMinus", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "\[Nu]T"}], ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Transverse", " ", 
   RowBox[{"projector", ":", " ", 
    RowBox[{"I", " ", "-", " ", 
     RowBox[{"qhat", " ", 
      RowBox[{"qhat", "^", "T"}]}]}]}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"projP", "=", 
   RowBox[{
    RowBox[{"IdentityMatrix", "[", "3", "]"}], "-", 
    FractionBox[
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "qPlus", ",", "qPlus"}], "]"}], 
     RowBox[{
      SuperscriptBox["\[Nu]T", "2"], "+", "\[Xi]h2"}]]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"projM", "=", 
   RowBox[{
    RowBox[{"IdentityMatrix", "[", "3", "]"}], "-", 
    FractionBox[
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "qMinus", ",", "qMinus"}], "]"}], 
     RowBox[{
      SuperscriptBox["\[Nu]T", "2"], "+", "\[Xi]h2"}]]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Expected", " ", "S"}], "-", 
   RowBox[{"wave", " ", "contour", " ", "contributions", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Eqn", ".", " ", "A"}], ".21"}], ")"}]}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"cTpProj", "=", 
   RowBox[{
    FractionBox[
     RowBox[{"I", " ", "\[Pi]"}], 
     RowBox[{"\[Mu]", " ", "\[Nu]T"}]], "projP"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cTmProj", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "I"}], " ", "\[Pi]"}], 
     RowBox[{"\[Mu]", " ", "\[Nu]T"}]], "projM"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Test", ":", " ", 
   RowBox[{
   "transverse", " ", "projector", " ", "form", " ", "matches", " ", 
    "contour", " ", "result"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"testSdnProj", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"cTp", "-", "cTpProj"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testSupProj", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"cTm", "-", "cTmProj"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"testSdnProj", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] S-wave downgoing = transverse projector\>\"", ",", 
        "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] S-wave downgoing projector mismatch\>\"", ",", 
        "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{"testSupProj", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] S-wave upgoing = transverse projector\>\"", ",", 
        "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] S-wave upgoing projector mismatch\>\"", ",", 
        "Bold", ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}], "Input",
 CellLabel->
  "In[153]:=",ExpressionUUID->"c1388d5c-5b53-473d-b470-db81b500a707"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"[PASS] S-wave downgoing = transverse projector\"\>",
      StripOnInput->False,
      LineColor->RGBColor[0, 
        Rational[2, 3], 0],
      FrontFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      BackFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      GraphicsColor->RGBColor[0, 
        Rational[2, 3], 0],
      FontWeight->Bold,
      FontColor->RGBColor[0, 
        Rational[2, 3], 0]]},
    {
     StyleBox["\<\"[FAIL] S-wave upgoing projector mismatch\"\>",
      StripOnInput->False,
