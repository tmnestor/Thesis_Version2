Notebook[{

Cell[CellGroupData[{
Cell["\<\
P-SV-SH Dyadic Decomposition of the Elastodynamic Green\[CloseCurlyQuote]s \
Tensor\
\>", "Title",ExpressionUUID->"a0d578e3-3ac8-41d8-b295-c77b72962b5e"],

Cell["\<\
This notebook verifies that the contour contributions to the 3-D \
elastodynamic Green\[CloseCurlyQuote]s tensor decompose into rank-1 dyads for \
P, SV and SH wave polarisations, as derived in Appendix A of the thesis \
(Eqns. A.17-A.25).

Specifically, we verify:
  1. P-wave contour contributions are rank-1 dyads
  2. S-wave matrix factorises as a transverse projector
  3. The transverse projector decomposes into SV + SH dyads
  4. P + SV + SH dyads sum to the full contour result\
\>", "Text",ExpressionUUID->"431e7e49-8b49-41ef-97f1-55cdaa3f342b"],

Cell[CellGroupData[{

Cell["1. Setup", "Section",ExpressionUUID->"f2936155-d26d-48e4-975e-9549d09185f7"],

Cell["\<\
We reproduce the essential definitions. All symbols match the thesis notation \
in Appendix A.\
\>", "Text",ExpressionUUID->"259ecbfe-4d51-4029-9011-3d0b81bc48ee"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]", "=", 
   RowBox[{"{", 
    RowBox[{"\[Xi]1", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]sq", "=", 
   RowBox[{
    SuperscriptBox["\[Xi]1", "2"], "+", 
    SuperscriptBox["\[Xi]2", "2"], "+", 
    SuperscriptBox["\[Xi]3", "2"]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kL2", "=", 
   FractionBox[
    RowBox[{"\[Rho]", " ", 
     SuperscriptBox["\[Omega]", "2"]}], 
    RowBox[{"\[Lambda]", "+", 
     RowBox[{"2", "\[Mu]"}]}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kT2", "=", 
   FractionBox[
    RowBox[{"\[Rho]", " ", 
     SuperscriptBox["\[Omega]", "2"]}], "\[Mu]"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]h2", "=", 
   RowBox[{
    SuperscriptBox["\[Xi]2", "2"], "+", 
    SuperscriptBox["\[Xi]3", "2"]}]}], ";"}]}], "Input",
 CellLabel->
  "In[125]:=",ExpressionUUID->"9b6b984e-88d7-4eca-bfed-404ff84a897e"],

Cell["Substitution rules for vertical wavenumbers:", "Text",ExpressionUUID->"20f72ef7-68e5-466b-84e9-9a54159eceb2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sub", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Nu]L", "2"], "\[Rule]", 
      RowBox[{"kL2", "-", 
       SuperscriptBox["\[Xi]2", "2"], "-", 
       SuperscriptBox["\[Xi]3", "2"]}]}], ",", 
     RowBox[{
      SuperscriptBox["\[Nu]T", "2"], "\[Rule]", 
      RowBox[{"kT2", "-", 
       SuperscriptBox["\[Xi]2", "2"], "-", 
       SuperscriptBox["\[Xi]3", "2"]}]}]}], "}"}]}], ";"}]], "Input",
 CellLabel->
  "In[131]:=",ExpressionUUID->"ca93dac9-7783-42c4-aaf0-7407b62a56d9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Residue Matrices", "Section",ExpressionUUID->"312e9f40-5013-4a65-bd53-34bf158cd10d"],

Cell["\<\
We define the partial-fraction form (Form 2) with \[Nu]L, \[Nu]T denominators \
and compute the residues at all four poles.\
\>", "Text",ExpressionUUID->"86bb4f8c-2a24-4f41-bdd8-3e04c905e9a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"OhatR", "[", 
   RowBox[{"i_", ",", "k_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "\[Mu]"], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
        "\[Xi]", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
        RowBox[{
        "\[Xi]", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], 
       "kT2"], 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", 
         RowBox[{
          SuperscriptBox["\[Xi]1", "2"], "-", 
          SuperscriptBox["\[Nu]L", "2"]}]], "-", 
        FractionBox["1", 
         RowBox[{
          SuperscriptBox["\[Xi]1", "2"], "-", 
          SuperscriptBox["\[Nu]T", "2"]}]]}], ")"}]}], "+", 
     FractionBox[
      RowBox[{"KroneckerDelta", "[", 
       RowBox[{"i", ",", "k"}], "]"}], 
      RowBox[{
       SuperscriptBox["\[Xi]1", "2"], "-", 
       SuperscriptBox["\[Nu]T", "2"]}]]}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"Rhat", "[", 
   RowBox[{"i_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"Apart", "[", 
   RowBox[{
    RowBox[{"OhatR", "[", 
     RowBox[{"i", ",", "k"}], "]"}], ",", "\[Xi]1"}], "]"}]}]}], "Input",
 CellLabel->
  "In[132]:=",ExpressionUUID->"bfa98eda-382a-42a2-9598-4e74e172ad05"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"resLp", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", "\[Nu]L"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resLm", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", 
          RowBox[{"-", "\[Nu]L"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resTp", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", "\[Nu]T"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resTm", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", 
          RowBox[{"-", "\[Nu]T"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[134]:=",ExpressionUUID->"fae9a1ea-b783-4a24-9b73-3ea4deda5473"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cLp", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resLp"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cLm", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resLm"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cTp", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resTp"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cTm", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resTm"}], "/.", "sub"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->
  "In[138]:=",ExpressionUUID->"fef3c295-3e93-4588-b519-5917b9f772a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. P-Wave Dyadic Verification (Eqn. A.18)", "Section",ExpressionUUID->"788d2546-7c31-46be-ba34-694e6260a1bc"],

Cell["\<\
The P-wave contour contributions should be rank-1 dyads proportional to the \
outer product of the P-wave polarisation vector with itself.\
\>", "Text",ExpressionUUID->"f899a5eb-7f1e-4f37-9c1f-cc6252f5ab99"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"P", "-", 
    RowBox[{"wave", " ", "polarisation", " ", "vectors", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".17"}], ")"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"pPlus", "=", 
   RowBox[{"{", 
    RowBox[{"\[Nu]L", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pMinus", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "\[Nu]L"}], ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Dyadic", " ", "products"}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"PdyadP", "=", 
   RowBox[{"Outer", "[", 
    RowBox[{"Times", ",", "pPlus", ",", "pPlus"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"PdyadM", "=", 
   RowBox[{"Outer", "[", 
    RowBox[{"Times", ",", "pMinus", ",", "pMinus"}], "]"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Expected", " ", "contour", " ", "contributions", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Eqn", ".", " ", "A"}], ".18"}], ")"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"cLpDyad", "=", 
   RowBox[{
    FractionBox[
     RowBox[{"I", " ", "\[Pi]"}], 
     RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
      SuperscriptBox["\[Omega]", "2"]}]], "PdyadP"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cLmDyad", "=", 
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"-", "I"}], " ", "\[Pi]"}], 
     RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
      SuperscriptBox["\[Omega]", "2"]}]], "PdyadM"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Test", ":", " ", 
   RowBox[{
   "dyadic", " ", "form", " ", "matches", " ", "contour", " ", "result"}]}], 
  " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"testPdnDyad", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"cLp", "-", "cLpDyad"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testPupDyad", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"cLm", "-", "cLmDyad"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"testPdnDyad", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] P-wave downgoing = P dyad\>\"", ",", "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] P-wave downgoing dyad mismatch\>\"", ",", "Bold", ",",
         "Red"}], "]"}]}], "]"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{"testPupDyad", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] P-wave upgoing = P dyad\>\"", ",", "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] P-wave upgoing dyad mismatch\>\"", ",", "Bold", ",",
         "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}], "Input",
 CellLabel->
  "In[142]:=",ExpressionUUID->"5c42d3d0-218f-44b5-8a05-973c36737bd2"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"[PASS] P-wave downgoing = P dyad\"\>",
