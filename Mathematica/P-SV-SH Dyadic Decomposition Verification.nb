Cell[CellGroupData[{

Cell["11. Numerical Verification of Symbolic Tests", "Section",ExpressionUUID->"5e3ab65d-a4d7-413d-a702-4335fc8519ce"],

Cell["\<\
FullSimplify may not reduce all symbolic differences to zero. We cross-check \
with exact rational arithmetic at a specific point.\
\>", "Text",ExpressionUUID->"9c200034-47f9-4933-9bff-c5be0546e6e2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Consistent", " ", "test", " ", "point"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"numVal", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Xi]2", "\[Rule]", 
      FractionBox["1", "2"]}], ",", 
     RowBox[{"\[Xi]3", "\[Rule]", 
      FractionBox["1", "4"]}], ",", 
     RowBox[{"\[Xi]h2", "\[Rule]", 
      FractionBox["5", "16"]}], ",", 
     RowBox[{"\[Mu]", "\[Rule]", "2"}], ",", 
     RowBox[{"\[Rho]", "\[Rule]", "1"}], ",", 
     RowBox[{"\[Omega]", "\[Rule]", 
      RowBox[{"Sqrt", "[", "6", "]"}]}], ",", 
     RowBox[{"\[Lambda]", "\[Rule]", "4"}], ",", 
     RowBox[{"kT2", "\[Rule]", "3"}], ",", 
     RowBox[{"kL2", "\[Rule]", 
      FractionBox["3", "4"]}], ",", 
     RowBox[{"\[Nu]T", "\[Rule]", 
      FractionBox[
       RowBox[{"Sqrt", "[", "43", "]"}], "4"]}], ",", 
     RowBox[{"\[Nu]L", "\[Rule]", 
      FractionBox[
       RowBox[{"Sqrt", "[", "7", "]"}], "4"]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Numerical", " ", "zero"}], "-", 
   RowBox[{"matrix", " ", "test"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"numZero", "[", "m_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Max", "[", 
     RowBox[{"Abs", "[", 
      RowBox[{"Flatten", "[", 
       RowBox[{"N", "[", 
        RowBox[{"m", "/.", "numVal"}], "]"}], "]"}], "]"}], "]"}], "<", 
    SuperscriptBox["10", 
     RowBox[{"-", "10"}]]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Re", "-", 
   RowBox[{
   "check", " ", "any", " ", "symbolic", " ", "FAILs", " ", "numerically"}]}],
   " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", "testSupProj"}], ",", 
    RowBox[{"testSupProj", "=", 
     RowBox[{"numZero", "[", 
      RowBox[{
       RowBox[{"cTm", "-", "cTmProj"}], "/.", "sub"}], "]"}]}]}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", "testSdnSVSH"}], ",", 
    RowBox[{"testSdnSVSH", "=", 
     RowBox[{"numZero", "[", 
      RowBox[{
       RowBox[{"cTp", "-", "cTpSVSH"}], "/.", "sub"}], "]"}]}]}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", "testSupSVSH"}], ",", 
    RowBox[{"testSupSVSH", "=", 
     RowBox[{"numZero", "[", 
      RowBox[{
       RowBox[{"cTm", "-", "cTmSVSH"}], "/.", "sub"}], "]"}]}]}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", "testTotalDn"}], ",", 
    RowBox[{"testTotalDn", "=", 
     RowBox[{"numZero", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"cLp", "+", "cTp"}], "-", "cLpDyad", "-", "cTpSVSH"}], "/.", 
       "sub"}], "]"}]}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", "testTotalUp"}], ",", 
    RowBox[{"testTotalUp", "=", 
     RowBox[{"numZero", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"cLm", "+", "cTm"}], "-", "cLmDyad", "-", "cTmSVSH"}], "/.", 
       "sub"}], "]"}]}]}], "]"}], ";"}]}], "Input",
 CellLabel->
  "In[226]:=",ExpressionUUID->"5c79f9dc-f39e-4db3-b48b-a5c356d4400c"],

Cell["\<\
If any test still fails after numerical verification, compute the \
multiplicative factor by which the result differs from the expected form.\
\>", "Text",ExpressionUUID->"c6e88a06-5bc2-4c7b-919c-645a4fe799d3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Diagnostic", ":", " ", 
    RowBox[{
    "compute", " ", "ratio", " ", "for", " ", "any", " ", "remaining", " ", 
     "failures"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ratioAt", "[", 
   RowBox[{"actual_", ",", "expected_", ",", 
    RowBox[{"{", 
     RowBox[{"i_", ",", "k_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"actual", "\[LeftDoubleBracket]", 
     RowBox[{"i", ",", "k"}], "\[RightDoubleBracket]"}], "/", 
    RowBox[{"expected", "\[LeftDoubleBracket]", 
     RowBox[{"i", ",", "k"}], "\[RightDoubleBracket]"}]}], "]"}]}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"S", "-", 
   RowBox[{"wave", " ", 
    RowBox[{"upgoing", ":", " ", 
     RowBox[{
     "ratio", " ", "of", " ", "actual", " ", "to", " ", "expected"}]}]}]}], 
  " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"Style", "[", 
    RowBox[{"\"\<Diagnostic ratios (actual / expected):\>\"", ",", "Bold"}], 
    "]"}], "]"}], ";"}], "\n", 
 RowBox[{"Print", "[", "\"\<\>\"", "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<S-wave upgoing [2,2]: cTm / cTmProj = \>\"", ",", 
   RowBox[{"ratioAt", "[", 
    RowBox[{"cTm", ",", 
     RowBox[{"cTmProj", "/.", "sub"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<S-wave dn [2,2]: cTp / cTpSVSH = \>\"", ",", 
   RowBox[{"ratioAt", "[", 
    RowBox[{"cTp", ",", 
     RowBox[{"cTpSVSH", "/.", "sub"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<S-wave up [2,2]: cTm / cTmSVSH = \>\"", ",", 
   RowBox[{"ratioAt", "[", 
    RowBox[{"cTm", ",", 
     RowBox[{"cTmSVSH", "/.", "sub"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Total dn [2,2]: (cLp+cTp) / (cLpDyad+cTpSVSH) = \>\"", ",", 
   RowBox[{"ratioAt", "[", 
    RowBox[{
     RowBox[{"cLp", "+", "cTp"}], ",", 
     RowBox[{
      RowBox[{"cLpDyad", "+", "cTpSVSH"}], "/.", "sub"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Total up [2,2]: (cLm+cTm) / (cLmDyad+cTmSVSH) = \>\"", ",", 
   RowBox[{"ratioAt", "[", 
    RowBox[{
     RowBox[{"cLm", "+", "cTm"}], ",", 
     RowBox[{
      RowBox[{"cLmDyad", "+", "cTmSVSH"}], "/.", "sub"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Print", "[", "\"\<\>\"", "]"}], "\n", 
 RowBox[{"Print", 
  "[", "\"\<(All ratios should be 1 if the formulas are correct)\>\"", 
  "]"}]}], "Input",
 CellLabel->
  "In[233]:=",ExpressionUUID->"769502bf-886f-4836-89e7-6a36282dba43"],

Cell[CellGroupData[{

Cell[BoxData[
 StyleBox["\<\"Diagnostic ratios (actual / expected):\"\>",
