Cell["10. Reduction to 2.5-D Cross-Check", "Section",ExpressionUUID->"02332c28-6592-4b5b-8261-698959efa1f4"],

Cell["\<\
Verify that at \[Xi]3 = 0, the polarisation vectors reduce to the thesis \
eigenvectors (Eqns. 3.63-3.65).\
\>", "Text",ExpressionUUID->"f1d3f12f-e8da-4944-bca5-c0d7b48a69c4"],

