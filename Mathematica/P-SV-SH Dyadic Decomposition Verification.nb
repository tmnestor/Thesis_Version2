Cell[CellGroupData[{

Cell["5. SV and SH Polarisation Vectors (Eqns. A.22-A.23)", "Section",ExpressionUUID->"608c199a-e9a8-4f09-bbbe-c75fac910fd3"],

Cell["\<\
Define the SV and SH polarisation vectors and verify their orthogonality \
properties.\
\>", "Text",ExpressionUUID->"9cb41c5b-df91-491c-8e94-09f7e704abd1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"SV", " ", "polarisation", " ", "vectors", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Eqn", ".", " ", "A"}], ".22"}], ")"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"sSVp", "=", 
   RowBox[{"{", 
    RowBox[{"\[Xi]h2", ",", 
     RowBox[{"-", 
      RowBox[{"\[Nu]T", " ", "\[Xi]2"}]}], ",", 
     RowBox[{"-", 
      RowBox[{"\[Nu]T", " ", "\[Xi]3"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"sSVm", "=", 
   RowBox[{"{", 
    RowBox[{"\[Xi]h2", ",", 
     RowBox[{"\[Nu]T", " ", "\[Xi]2"}], ",", 
     RowBox[{"\[Nu]T", " ", "\[Xi]3"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"SH", " ", "polarisation", " ", "vector", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Eqn", ".", " ", "A"}], ".23"}], ")"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"sSH", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", 
     RowBox[{"-", "\[Xi]3"}], ",", "\[Xi]2"}], "}"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Verify", " ", "norms"}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"normSVp2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"sSVp", ".", "sSVp"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"normSVm2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"sSVm", ".", "sSVm"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"normSH2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"sSH", ".", "sSH"}], "]"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<|sSV(+)|^2 = \>\"", ",", "normSVp2", 
   ",", "\"\<  (expected: \[Xi]h^2 kT^2 = \>\"", ",", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"\[Xi]h2", " ", "kT2"}], "]"}], ",", "\"\<)\>\""}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<|sSV(-)|^2 = \>\"", ",", "normSVm2", 
   ",", "\"\<  (expected: \[Xi]h^2 kT^2)\>\""}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<|sSH|^2   = \>\"", ",", "normSH2", 
   ",", "\"\<  (expected: \[Xi]h^2 = \>\"", ",", "\[Xi]h2", 
   ",", "\"\<)\>\""}], "]"}]}], "Input",
 CellLabel->
  "In[164]:=",ExpressionUUID->"420e7d9b-6dfc-4c52-b207-91da5337359a"],

Cell[CellGroupData[{

