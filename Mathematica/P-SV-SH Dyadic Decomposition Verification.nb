Cell[CellGroupData[{

Cell["6. Transverse Projector Decomposition (Eqn. A.24)", "Section",ExpressionUUID->"4695b808-26e3-4ecb-916b-bfbe002bd937"],

Cell["\<\
Verify that the transverse projector decomposes as the sum of normalised SV \
and SH dyads.\
\>", "Text",ExpressionUUID->"5e02647f-c820-422b-b440-7b1e02899a66"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Construct", " ", "the", " ", "SV", " ", "and", " ", "SH", " ", "dyadic", " ",
     "terms"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"SVdyadP", "=", 
   FractionBox[
    RowBox[{"Outer", "[", 
     RowBox[{"Times", ",", "sSVp", ",", "sSVp"}], "]"}], 
    RowBox[{"\[Xi]h2", " ", "kT2"}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SVdyadM", "=", 
   FractionBox[
    RowBox[{"Outer", "[", 
     RowBox[{"Times", ",", "sSVm", ",", "sSVm"}], "]"}], 
    RowBox[{"\[Xi]h2", " ", "kT2"}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SHdyad", "=", 
   FractionBox[
    RowBox[{"Outer", "[", 
     RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}], "\[Xi]h2"]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Sum", " ", "of", " ", "SV"}], " ", "+", " ", 
   RowBox[{"SH", " ", "dyads"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"dyadSumP", "=", 
   RowBox[{"SVdyadP", "+", "SHdyad"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dyadSumM", "=", 
   RowBox[{"SVdyadM", "+", "SHdyad"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Test", ":", " ", 
   RowBox[{
   "dyad", " ", "sum", " ", "equals", " ", "transverse", " ", "projector"}]}],
   " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"testProjPlus", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"projP", "-", "dyadSumP"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testProjMinus", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"projM", "-", "dyadSumM"}], "/.", "sub"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"testProjPlus", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] Projector = SV dyad + SH dyad (downgoing)\>\"", ",",
         "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] Projector decomposition failed (downgoing)\>\"", ",",
         "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{"testProjMinus", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] Projector = SV dyad + SH dyad (upgoing)\>\"", ",", 
        "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] Projector decomposition failed (upgoing)\>\"", ",",
         "Bold", ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}], "Input",
 CellLabel->
  "In[181]:=",ExpressionUUID->"a6853195-dc7f-4cca-a144-8934553ba87c"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"[PASS] Projector = SV dyad + SH dyad (downgoing)\"\>",
      StripOnInput->False,
      LineColor->RGBColor[0, 
        Rational[2, 3], 0],
      FrontFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      BackFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      GraphicsColor->RGBColor[0, 
