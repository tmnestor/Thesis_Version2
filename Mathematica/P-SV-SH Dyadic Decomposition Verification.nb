Cell[CellGroupData[{

Cell["8. Complete P + SV + SH Reconstruction", "Section",ExpressionUUID->"e8ab867a-ca87-4599-bfd2-dd2b0200dc90"],

Cell["\<\
As a final cross-check, verify that the sum of all three dyadic contributions \
(P + SV + SH) for each direction reconstructs the total contour result (P + \
S) from Section 2.\
\>", "Text",ExpressionUUID->"0d54b768-8a8a-4df5-a04b-1edd6a857c58"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Total", " ", "contour", " ", "result", " ", "from", " ", "residues"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"totalDn", "=", 
   RowBox[{"cLp", "+", "cTp"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"totalUp", "=", 
   RowBox[{"cLm", "+", "cTm"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Total", " ", "from", " ", "dyadic", " ", "decomposition"}], " ", 
  "*)"}], "\n", 
 RowBox[{
  RowBox[{"totalDnDyad", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"cLpDyad", "+", "cTpSVSHphys"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"totalUpDyad", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"cLmDyad", "+", "cTmSVSHphys"}], "]"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", "Test", " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"testTotalDn", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"totalDn", "-", "totalDnDyad"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testTotalUp", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"totalUp", "-", "totalUpDyad"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{"testTotalDn", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] Downgoing: P + SV + SH dyads = total contour \
result\>\"", ",", "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] Downgoing reconstruction failed\>\"", ",", "Bold", 
        ",", "Red"}], "]"}]}], "]"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{"testTotalUp", ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[PASS] Upgoing: P + SV + SH dyads = total contour \
result\>\"", ",", "Bold", ",", 
        RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
      RowBox[{"Style", "[", 
       RowBox[{"\"\<[FAIL] Upgoing reconstruction failed\>\"", ",", "Bold", ",",
         "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}], "Input",
 CellLabel->
  "In[196]:=",ExpressionUUID->"74122d5f-a311-4900-9f9d-6997fba75540"],

