Cell[CellGroupData[{

Cell["7. Full SV + SH Dyadic Decomposition of S-Wave (Eqn. A.25)", "Section",ExpressionUUID->"0dfc4bec-9e22-4b13-a4bf-f0a097ce1708"],

Cell["\<\
The main result: verify that the S-wave contour contributions decompose \
exactly into the sum of SV and SH dyads with the prefactors stated in Eqn. \
A.25 of the thesis.\
\>", "Text",ExpressionUUID->"66b4b035-b074-442e-9e87-d2b1803ae248"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Construct", " ", "the", " ", "full", " ", "dyadic", " ", "S"}], "-", 
    RowBox[{"wave", " ", "contributions", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".25"}], ")"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"cTpSVSH", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"I", " ", "\[Pi]"}], 
      RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2", " ", "kT2"}]], 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "sSVp", ",", "sSVp"}], "]"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{"I", " ", "\[Pi]"}], 
      RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2"}]], 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{
  RowBox[{"cTmSVSH", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Pi]"}], 
      RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2", " ", "kT2"}]], 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "sSVm", ",", "sSVm"}], "]"}]}], "+", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"-", "I"}], " ", "\[Pi]"}], 
      RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2"}]], 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Substitute", " ", "back", " ", "physical", " ", "parameters"}], 
  " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"cTpSVSHphys", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"cTpSVSH", "/.", "sub"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cTmSVSHphys", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"cTmSVSH", "/.", "sub"}], "]"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"(*", " ", 
  RowBox[{"Test", ":", " ", 
   RowBox[{
   "dyadic", " ", "form", " ", "matches", " ", "the", " ", "contour", " ", 
    "result", " ", "from", " ", "Section", " ", "2"}]}], " ", "*)"}], "\n", 
 RowBox[{
  RowBox[{"testSdnSVSH", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"cTp", "-", "cTpSVSHphys"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"testSupSVSH", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"cTm", "-", "cTmSVSHphys"}], "]"}], "===", 
    RowBox[{"ConstantArray", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Column", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"If", "[", 
