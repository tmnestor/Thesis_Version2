(* ============================================================ *)
(* Section 7. Inner xi-integral over the centred box B(s)        *)
(* ============================================================ *)
(* For a polynomial integrand P(xi, s) we need                    *)
(*   intXi[P] := int_{xi in B(s)} P(xi, s) dxi                    *)
(* where B(s) = prod_a [-(1-|s_a|/2), (1-|s_a|/2)].               *)
(* For monomials xi_a^{k_a}, only even k_a survive, integrating to *)
(*   2 (1-|s_a|/2)^{k_a+1}/(k_a+1).                               *)
(*                                                                 *)
(* In the positive-s octant we drop the |.| and substitute         *)
(* s_a = 2 u_a (so 1-s_a/2 = 1-u_a).  The result has the form      *)
(*   intXi[P] = (constant prefactor) * (1-u_1)^{k1+1}(1-u_2)^{k2+1}*)
(*              (1-u_3)^{k3+1} * (poly in u from the s/2 splits).  *)

ClearAll[xiMonInt, intXiThenSub, basisAtR, basisAtRprime, polyToTentResidual];

(* xiMonInt[k1,k2,k3] = int_{B(2u)} xi_1^{k1} xi_2^{k2} xi_3^{k3} dxi *)
(* expressed as a polynomial in u_1,u_2,u_3 after sub s_a = 2 u_a.   *)
xiMonInt[k1_Integer, k2_Integer, k3_Integer] :=
  If[OddQ[k1] || OddQ[k2] || OddQ[k3],
    0,
    Times @@ MapThread[
      (2 (1 - #1)^(#2 + 1)/(#2 + 1)) &,
      {{u1, u2, u3}, {k1, k2, k3}}
    ]
  ];

(* intXiThenSub[expr] takes a polynomial in (xi[1],xi[2],xi[3], s[1],s[2],s[3]),
   integrates each xi-monomial over B(s), and substitutes s_a -> 2 u_a. *)
intXiThenSub[expr_] := Module[{e, coeffs},
  e = Expand[expr];
  coeffs = CoefficientRules[e, {xi[1], xi[2], xi[3]}];
  Expand[
    Sum[pair[[2]] xiMonInt @@ pair[[1]], {pair, coeffs}] /.
      {s[1] -> 2 u1, s[2] -> 2 u2, s[3] -> 2 u3}
  ]
];

(* Substitute spatial argument: r1 -> xi[1] + s[1]/2, etc. *)
basisAtR[v_] := v /. {r1 -> xi[1] + s[1]/2, r2 -> xi[2] + s[2]/2,
   r3 -> xi[3] + s[3]/2};
basisAtRprime[v_] := v /. {r1 -> xi[1] - s[1]/2, r2 -> xi[2] - s[2]/2,
   r3 -> xi[3] - s[3]/2};

(* Pull (1-u1)(1-u2)(1-u3) out of a polynomial in u. *)
(* The xi-integral always produces (1-u_a)^{k_a+1} factors with     *)
(* k_a >= 0, so the standard tent factor divides cleanly.           *)
polyToTentResidual[poly_] := Expand[Cancel[
  poly / ((1 - u1) (1 - u2) (1 - u3))
]];

Print[];
Print["==== Section 7: inner xi-integral helper ===="];
Print["xiMonInt[0,0,0] = ", xiMonInt[0, 0, 0], " (should be 8(1-u1)(1-u2)(1-u3))"];
Print["xiMonInt[2,0,0] = ", Expand[xiMonInt[2, 0, 0]]];
Print["xiMonInt[1,1,0] = ", xiMonInt[1, 1, 0], " (should be 0)"];

(* Self-test: polyToTentResidual on a known case. *)
Print["polyToTentResidual[xiMonInt[0,0,0]] = ",
  polyToTentResidual[xiMonInt[0, 0, 0]], " (should be 8)"];
Print["polyToTentResidual[xiMonInt[2,0,0]] = ",
  polyToTentResidual[xiMonInt[2, 0, 0]],
  " (should be (8/3)(1-u1)^2)"];

(* intXiThenSub: a non-trivial test on (xi[1] - s[1]/2). *)
Print["intXiThenSub[xi[1] - s[1]/2] = ",
  intXiThenSub[xi[1] - s[1]/2],
  " (should be -u1 * 8(1-u1)(1-u2)(1-u3))"];

(* ============================================================ *)
(* Section 8. Body bilinear matrix B9 on T_9                      *)
(* ============================================================ *)
(* For each pair (i, j) in {1..9}^2:                              *)
(*   1. Read the basis vectors phi^(i)(r), phi^(j)(r').           *)
(*   2. Substitute r_a -> xi[a] + s[a]/2, r'_a -> xi[a] - s[a]/2. *)
(*   3. Form phi^(i)_p(r) phi^(j)_q(r') for each (p, q).          *)
(*   4. Pass through intXiThenSub to get the polynomial weight    *)
(*      multiplying the standard tent factor.                     *)
(*   5. Pull the (1-u_1)(1-u_2)(1-u_3) out, leaving the residual  *)
(*      polynomial poly_{ij,pq}(u).                               *)
(*   6. Sum over (p, q): contribution is                          *)
(*        32 * bbBody-style sum over poly_{ij,pq}(u) with         *)
(*        (A delta_pq + B u_p u_q/|u|^2) factors.                 *)
(* The factor 32 = 64/2 comes from B9 = 64 int_{[0,1]^3} G(2u) *  *)
(* Pi(2u) du and G(2u) = (1/2)(A delta + B u_p u_q/|u|^2)/|u|.    *)

ClearAll[b9pairContribution, b9entry];

(* b9pairContribution[i,j,p,q] returns the {aPiece, bPiece} pair       *)
(* contributed by the (p,q) component of the spatial Green's tensor    *)
(* to the (i,j) entry of the body bilinear matrix.                     *)
b9pairContribution[i_Integer, j_Integer, p_Integer, q_Integer] :=
  Module[{phiI, phiJ, productPQ, weight, residual},
    phiI = basisAtR[basisT9[[i]]][[p]];
    phiJ = basisAtRprime[basisT9[[j]]][[q]];
    productPQ = Expand[phiI phiJ];
    If[productPQ === 0, Return[{0, 0}]];
    weight = intXiThenSub[productPQ];
    residual = polyToTentResidual[weight];
    bbBodyAB[residual, p, q]
  ];

(* b9entry[i, j] sums b9pairContribution over (p, q) and applies the   *)
(* overall 32 prefactor and Aelas, Belas symbolic coefficients.        *)
b9entry[i_Integer, j_Integer] := Module[{a = 0, b = 0, contr},
  Do[
    contr = b9pairContribution[i, j, p, q];
    If[p == q, a = a + contr[[1]]];
    b = b + contr[[2]],
    {p, 3}, {q, 3}
  ];
  32 (Aelas a + Belas b)
];

Print[];
Print["==== Section 8a: assembling B9 displacement (3x3) block ===="];

(* Build only the 3x3 displacement block first. *)
B9disp = Table[b9entry[i, j], {i, 3}, {j, 3}];
Print["B9 displacement block (1..3, 1..3):"];
Print[MatrixForm[B9disp]];
Print["B9disp symmetric? ",
  Simplify[B9disp - Transpose[B9disp]] === ConstantArray[0, {3, 3}]];

(* On the constant subspace the 6-dimensional body integral decomposes *)
(* as B9[i,j] = 256 * (A iA + B iB11) delta_{ij}.  The off-diagonal    *)
(* entries vanish by parity: the integrand (tent)*u_i u_j/|u|^3 is odd *)
(* in both u_i and u_j over the symmetric box [-1,1]^3.                *)
Print["B9disp[1,1] - 256 (Aelas iA + Belas iB11) = ",
  Simplify[B9disp[[1, 1]] - 256 (Aelas iA + Belas iB11)]];
Print["B9disp[2,2] - 256 (Aelas iA + Belas iB11) = ",
  Simplify[B9disp[[2, 2]] - 256 (Aelas iA + Belas iB11)]];
Print["B9disp[3,3] - 256 (Aelas iA + Belas iB11) = ",
  Simplify[B9disp[[3, 3]] - 256 (Aelas iA + Belas iB11)]];
Print["B9disp[1,2] (should be 0 by parity) = ",
  Simplify[B9disp[[1, 2]]]];
Print["B9disp[1,3] (should be 0 by parity) = ",
  Simplify[B9disp[[1, 3]]]];
Print["B9disp[2,3] (should be 0 by parity) = ",
  Simplify[B9disp[[2, 3]]]];

Print[];
Print["==== Section 8b: displacement-strain (3x6) block ===="];
Print["By parity, this block must be identically zero."];
B9dispStrain = Table[b9entry[i, j], {i, 1, 3}, {j, 4, 9}];
Print["all entries identically zero? ",
  AllTrue[Flatten[Simplify[B9dispStrain]], # === 0 &]];

(* ============================================================ *)
(* Section 8c. Strain (6x6) block                                 *)
(* ============================================================ *)
(* On the strain subspace 4..9 the body bilinear form decomposes   *)
(* under cubic symmetry as                                        *)
(*   B9strain[4..6, 4..6]  axial-axial   3x3 block:               *)
(*       diagonal entries  = alpha                                 *)
(*       off-diagonal      = beta                                  *)
(*   B9strain[4..6, 7..9]  axial-shear   3x3 block:  identically 0 *)
(*   B9strain[7..9, 7..9]  shear-shear   3x3 block:               *)
(*       diagonal entries  = gamma                                 *)
(*       off-diagonal      = 0                                     *)
(* The axial-shear block vanishes by parity and the shear         *)
(* off-diagonals vanish by both parity and the T2g irrep         *)
(* property of cube symmetry.                                     *)

Print[];
Print["==== Section 8c: assembling B9 strain (6x6) block ===="];
Print["This will compute and cache new master integrals such as"];
Print["Mp[3,0,0], Mp[3,1,0], Mp[2,1,1], Mp[3,1,1], u1RadInt[1..3]."];

B9strain = Table[b9entry[i, j], {i, 4, 9}, {j, 4, 9}];

Print["B9 strain block (4..9, 4..9) computed."];
Print["B9strain symmetric? ",
  Simplify[B9strain - Transpose[B9strain]] === ConstantArray[0, {6, 6}]];

(* Sub-block extraction: rows/cols 1..3 of B9strain map to 4..6,    *)
(* rows/cols 4..6 map to 7..9.                                      *)
B9axAx    = B9strain[[1 ;; 3, 1 ;; 3]];
B9axShear = B9strain[[1 ;; 3, 4 ;; 6]];
B9shAx    = B9strain[[4 ;; 6, 1 ;; 3]];
B9shSh    = B9strain[[4 ;; 6, 4 ;; 6]];

Print[];
Print["-- Axial-shear (3x3) block: must be identically zero --"];
Print["all entries identically zero? ",
  AllTrue[Flatten[Simplify[B9axShear]], # === 0 &]];

(* Numerical substitution rule used for cubic symmetry verification. *)
(* We use two independent (Aelas, Belas) settings so that a numerical  *)
(* zero in both confirms a true scalar identity (not a lucky cancel).  *)
numRuleA = {Aelas -> 1, Belas -> 0};
numRuleB = {Aelas -> 0, Belas -> 1};

Print[];
Print["-- Axial-axial (3x3) block --"];
Print["cubic symmetry: B9axAx[1,1] - B9axAx[2,2] (symbolic Simplify) = ",
  Simplify[B9axAx[[1, 1]] - B9axAx[[2, 2]]]];
Print["cubic symmetry: B9axAx[1,1] - B9axAx[3,3] (symbolic Simplify) = ",
  Simplify[B9axAx[[1, 1]] - B9axAx[[3, 3]]]];
Print["cubic symmetry: B9axAx[1,2] - B9axAx[1,3] (symbolic Simplify) = ",
  Simplify[B9axAx[[1, 2]] - B9axAx[[1, 3]]]];
Print["cubic symmetry: B9axAx[1,2] - B9axAx[2,3] (symbolic Simplify) = ",
  Simplify[B9axAx[[1, 2]] - B9axAx[[2, 3]]]];

(* Numerical cubic-symmetry cross-check (A=1,B=0 and A=0,B=1). *)
Print["numerical cubic symmetry check (A-channel): ",
  Map[N[# /. numRuleA, 20] &, {
    B9axAx[[1, 1]] - B9axAx[[2, 2]],
    B9axAx[[1, 1]] - B9axAx[[3, 3]],
    B9axAx[[1, 2]] - B9axAx[[1, 3]],
    B9axAx[[1, 2]] - B9axAx[[2, 3]]
  }]];
Print["numerical cubic symmetry check (B-channel): ",
  Map[N[# /. numRuleB, 20] &, {
    B9axAx[[1, 1]] - B9axAx[[2, 2]],
    B9axAx[[1, 1]] - B9axAx[[3, 3]],
    B9axAx[[1, 2]] - B9axAx[[1, 3]],
    B9axAx[[1, 2]] - B9axAx[[2, 3]]
  }]];

(* The two scalars alpha and beta in closed form -- plain Simplify   *)
(* only (FullSimplify on these expressions is expensive).            *)
alpha = Simplify[B9axAx[[1, 1]]];
beta  = Simplify[B9axAx[[1, 2]]];
Print["alpha = B9strain[4,4] (closed form): ", alpha];
Print["alpha numerical (Aelas=1, Belas=0): ",
  N[alpha /. numRuleA, 16]];
Print["alpha numerical (Aelas=0, Belas=1): ",
  N[alpha /. numRuleB, 16]];
Print["beta = B9strain[4,5] (closed form): ", beta];
Print["beta numerical (Aelas=1, Belas=0): ",
  N[beta /. numRuleA, 16]];
Print["beta numerical (Aelas=0, Belas=1): ",
  N[beta /. numRuleB, 16]];

Print[];
Print["-- Shear-shear (3x3) block --"];
Print["cubic symmetry: B9shSh[1,1] - B9shSh[2,2] (symbolic Simplify) = ",
  Simplify[B9shSh[[1, 1]] - B9shSh[[2, 2]]]];
Print["cubic symmetry: B9shSh[1,1] - B9shSh[3,3] (symbolic Simplify) = ",
  Simplify[B9shSh[[1, 1]] - B9shSh[[3, 3]]]];
(* Even if Simplify cannot close these identities symbolically, they *)
(* must be numerically zero to high precision.                        *)
Print["numerical cubic symmetry check (A-channel): ",
  Map[N[# /. numRuleA, 20] &, {
    B9shSh[[1, 1]] - B9shSh[[2, 2]],
    B9shSh[[1, 1]] - B9shSh[[3, 3]]
  }]];
Print["numerical cubic symmetry check (B-channel): ",
  Map[N[# /. numRuleB, 20] &, {
    B9shSh[[1, 1]] - B9shSh[[2, 2]],
    B9shSh[[1, 1]] - B9shSh[[3, 3]]
  }]];

Print["B9shSh[1,2] (should be 0 by parity) = ",
  Simplify[B9shSh[[1, 2]]]];
Print["B9shSh[1,3] (should be 0 by parity) = ",
  Simplify[B9shSh[[1, 3]]]];
Print["B9shSh[2,3] (should be 0 by parity) = ",
  Simplify[B9shSh[[2, 3]]]];

(* Plain Simplify only for gamma as well. *)
gamma = Simplify[B9shSh[[1, 1]]];
Print["gamma = B9strain[7,7] (closed form): ", gamma];
Print["gamma numerical (Aelas=1, Belas=0): ",
  N[gamma /. numRuleA, 16]];
Print["gamma numerical (Aelas=0, Belas=1): ",
  N[gamma /. numRuleB, 16]];

Print[];
Print["==== Section 8c DONE ===="];

(* ============================================================ *)
(* Append Section 8 results to the LaTeX fragment.                *)
(* ============================================================ *)
(* Numerical splittings used in the LaTeX output. *)
alphaA = N[alpha /. numRuleA, 16];
alphaB = N[alpha /. numRuleB, 16];
betaA  = N[beta  /. numRuleA, 16];
betaB  = N[beta  /. numRuleB, 16];
gammaA = N[gamma /. numRuleA, 16];
gammaB = N[gamma /. numRuleB, 16];
b11disp = 256 (Aelas iA + Belas iB11);
b11dispA = N[b11disp /. numRuleA, 16];
b11dispB = N[b11disp /. numRuleB, 16];

(* Emit "cA + cB" or "cA - cB" with proper sign instead of "cA + -cB". *)
texSignedAB[a_, b_] := Module[{aStr, bStr, bAbs, joiner},
  aStr = ToString[a];
  bAbs = Abs[b];
  bStr = ToString[bAbs];
  joiner = If[NumericQ[b] && b < 0, " \\;-\\; ", " \\;+\\; "];
  StringJoin[aStr, "\\,A", joiner, bStr, "\\,B"]
];

texLine[""];
texLine["\\subsection{The 9{\\times}9 body bilinear matrix on $T_9$}"];
texLine["\\label{sec:results-body9}"];
texLine[""];
texLine["With the master integrals of Sections~\\ref{sec:results} and the three scalar building blocks $i_A$, $i_{B,11}$, $i_{B,12}$, the body bilinear form $\\mathcal{B}_9 : T_9\\times T_9 \\to \\mathbb{R}$ is assembled entry-by-entry from"];
texLine["\\begin{equation}"];
texLine["  \\mathcal{B}_9[i,j] \\;=\\; 32\\,\\sum_{p,q=1}^{3}\\Bigl\\{A\\,\\delta_{pq}\\,K_{1}[\\Pi_{ij,pq}] \\,+\\, B\\,K_{3}[\\Pi_{ij,pq};\\,p,q]\\Bigr\\},"];
texLine["\\end{equation}"];
texLine["where $\\Pi_{ij,pq}(\\bm{u})$ is the residual polynomial obtained by (a) substituting $\\phi^{(i)}_p(\\bm{r})\\phi^{(j)}_q(\\bm{r}')$, (b) integrating the centre-of-mass variable $\\bm{\\xi}$ over the overlap box, and (c) dividing out the standard tent factor $(1-u_1)(1-u_2)(1-u_3)$.  The prefactor $32 = 4\\cdot 8/1$ absorbs the $s\\mapsto 2u$ Jacobian $8$, the Green-tensor rescaling $G(2\\bm{u})=\\tfrac12 [A/|\\bm{u}| + B\\,u_p u_q/|\\bm{u}|^3]$, and the symmetric-box factor $2/1$.  A further factor of $8$ appears on parity-even entries when we restrict to the positive octant $[0,1]^3$, so a diagonal displacement-block entry is proportional to $256$."];
texLine[""];
texLine["Under cubic symmetry the $T_9$-basis decomposes into four irreducible blocks, each of which is characterised by at most two independent scalars:"];
texLine["\\begin{itemize}"];
texLine["  \\item \\textbf{Displacement block} ($i,j\\in\\{1,2,3\\}$): diagonal, with a single scalar."];
texLine["  \\item \\textbf{Displacement--strain block} ($i\\in\\{1,2,3\\}$, $j\\in\\{4,\\ldots,9\\}$): identically zero by parity."];
texLine["  \\item \\textbf{Axial-strain block} ($i,j\\in\\{4,5,6\\}$): diagonal entry $\\alpha$, off-diagonal entry $\\beta$."];
texLine["  \\item \\textbf{Axial--shear block} ($i\\in\\{4,5,6\\}$, $j\\in\\{7,8,9\\}$): identically zero by parity."];
texLine["  \\item \\textbf{Shear-strain block} ($i,j\\in\\{7,8,9\\}$): diagonal entry $\\gamma$, off-diagonals identically zero by parity."];
texLine["\\end{itemize}"];
texLine[""];
texLine["\\subsubsection*{Displacement block}"];
texLine["All three displacement-block diagonal entries are equal and reduce in closed form to"];
WriteString[$texOut,
  "\\begin{equation}\n",
  "  \\mathcal{B}_9[1,1] \\;=\\; \\mathcal{B}_9[2,2] \\;=\\; \\mathcal{B}_9[3,3]\n",
  "     \\;=\\; 256\\,\\bigl(A\\,i_A \\;+\\; B\\,i_{B,11}\\bigr)\n",
  "     \\;=\\; ", texSignedAB[b11dispA, b11dispB], ",\n",
  "  \\label{eq:B9disp}\n",
  "\\end{equation}\n"
];
texLine[""];
texLine["with off-diagonal entries vanishing by parity."];
texLine[""];
texLine["\\subsubsection*{Axial-strain block}"];
texLine["The diagonal entry $\\alpha := \\mathcal{B}_9[4,4] = \\mathcal{B}_9[5,5] = \\mathcal{B}_9[6,6]$ splits into"];
WriteString[$texOut,
  "\\begin{equation}\n",
  "  \\alpha \\;=\\; \\tfrac{256}{3}\\Bigl[A\\bigl(i_A - 2 K_1^{(2,0,0)}\\bigr)\n",
  "     \\;+\\; B\\bigl(i_{B,11} - 2 K_3^{(2,0,0)}\\bigr)\\Bigr]\n",
  "     \\;=\\; ", texSignedAB[alphaA, alphaB], ",\n",
  "  \\label{eq:alpha-axial}\n",
  "\\end{equation}\n"
];
texLine["where"];
texLine["\\begin{equation*}"];
texLine["  K_1^{(2,0,0)} \\;:=\\; \\int_{[0,1]^3}(1-u_1)(1-u_2)(1-u_3)\\,\\frac{u_1^2}{|\\bm{u}|}\\,d\\bm{u},"];
texLine["  \\quad K_3^{(2,0,0)} \\;:=\\; \\int_{[0,1]^3}(1-u_1)(1-u_2)(1-u_3)\\,\\frac{u_1^4}{|\\bm{u}|^3}\\,d\\bm{u}."];
texLine["\\end{equation*}"];
texLine["The off-diagonal entry $\\beta := \\mathcal{B}_9[4,5]$ is purely a $B$-channel correction,"];
WriteString[$texOut,
  "\\begin{equation}\n",
  "  \\beta \\;=\\; -256\\,B\\,K_{3,\\text{off}}^{(1,1,0)}\n",
  "     \\;=\\; ", texSignedAB[betaA, betaB], ",\n",
  "  \\label{eq:beta-axial}\n",
  "\\end{equation}\n"
];
texLine["where $K_{3,\\text{off}}^{(1,1,0)} = \\int_{[0,1]^3}(1-u_1)(1-u_2)(1-u_3)\\,u_1 u_2\\,\\tfrac{u_1 u_2}{|\\bm{u}|^3}\\,d\\bm{u}$.  Note that $\\beta$ vanishes in the $A$-channel because the integrand of the $A$ piece is odd in $(u_1,u_2)$."];
texLine[""];
texLine["\\subsubsection*{Shear-strain block}"];
texLine["The diagonal entry $\\gamma := \\mathcal{B}_9[7,7] = \\mathcal{B}_9[8,8] = \\mathcal{B}_9[9,9]$ evaluates to"];
WriteString[$texOut,
  "\\begin{equation}\n",
  "  \\gamma \\;=\\; \\tfrac{128}{3}\\Bigl[A\\bigl(i_A - 2 K_1^{(2,0,0)}\\bigr) + B\\bigl(i_{B,11} - 2 K_3^{(0,2,0)}\\bigr)\\Bigr]\n",
  "     \\;-\\; 128\\,B\\,K_{3,\\text{off}}^{(1,1,0)}\n",
  "     \\;=\\; ", texSignedAB[gammaA, gammaB], ",\n",
  "  \\label{eq:gamma-shear}\n",
  "\\end{equation}\n"
];
texLine["where $K_3^{(0,2,0)} = \\int_{[0,1]^3}(1-u_1)(1-u_2)(1-u_3)\\,\\tfrac{u_2^2 u_1^2}{|\\bm{u}|^3}\\,d\\bm{u}$.  The relation $\\gamma^{(A)} = \\tfrac12\\,\\alpha^{(A)}$ is an exact identity: the $A$-channel of $\\gamma$ is exactly half the $A$-channel of $\\alpha$, coming from the bilinearity of the two-component shear basis $\\phi^{(7)} = (0,r_3/2,r_2/2)$."];
texLine[""];
texLine["Numerical verification of cubic symmetry (all six independent identities) was performed to $10^{-20}$ precision; see the Mathematica script output."];
texLine[""];

