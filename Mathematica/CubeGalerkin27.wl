(* ============================================================ *)
(* Section 5. Trial space T_9 = (constants ⊕ symmetric linear)  *)
(* ============================================================ *)
(* Vector basis functions over V = [-1,1]^3, with the same Voigt    *)
(* ordering as cubic_scattering/effective_contrasts.py.              *)
(* Index order:                                                       *)
(*   1..3 = displacement modes (constants)                             *)
(*   4..6 = axial strain modes  (epsilon_xx, epsilon_yy, epsilon_zz)   *)
(*   7..9 = shear strain modes  (epsilon_yz, epsilon_xz, epsilon_xy)   *)

ClearAll[basisT9, polyDot, massEntry];
basisT9 = {
  {1, 0, 0},                           (* u_x *)
  {0, 1, 0},                           (* u_y *)
  {0, 0, 1},                           (* u_z *)
  {r1, 0, 0},                          (* eps_xx *)
  {0, r2, 0},                          (* eps_yy *)
  {0, 0, r3},                          (* eps_zz *)
  {0, r3/2, r2/2},                     (* eps_yz (symmetric) *)
  {r3/2, 0, r1/2},                     (* eps_xz *)
  {r2/2, r1/2, 0}                      (* eps_xy *)
};

(* Inner product of two vector fields (no kernel): pointwise dot.     *)
polyDot[v1_, v2_] := Sum[v1[[p]] v2[[p]], {p, 3}];

(* L^2 mass-matrix entry for V = [-1,1]^3.                            *)
massEntry[v1_, v2_] := Integrate[polyDot[v1, v2],
  {r1, -1, 1}, {r2, -1, 1}, {r3, -1, 1}];

M9 = Table[massEntry[basisT9[[i]], basisT9[[j]]], {i, 9}, {j, 9}];

Print[];
