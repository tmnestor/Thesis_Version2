(* ::Package:: *)
(* CubeGalerkin27.wl
   Path-B Galerkin closure for the 27-component cube T-matrix.

   This package derives — analytically — every bilinear form needed for
   the rigorous Galerkin projection of the elastodynamic Lippmann–
   Schwinger equation onto the polynomial trial space T_27 ⊂ (P_2(V))^3.

   Run with:
     /Applications/Wolfram.app/Contents/MacOS/wolframscript \
        -file Mathematica/CubeGalerkin27.wl

   Outputs:
     - Console log of every master integral and its closed form.
     - LaTeX fragment docs/cube_galerkin27_results.tex with the same
       results, included by docs/cube_galerkin27.tex.
*)

(* ============================================================ *)
(* Section 0. Output stream                                       *)
(* ============================================================ *)
$resultPath = FileNameJoin[{
  ParentDirectory[NotebookDirectory[] /. (NotebookDirectory[] -> DirectoryName[$InputFileName])],
  "docs", "cube_galerkin27_results.tex"
}];
Print["Writing LaTeX results to: ", $resultPath];

$texOut = OpenWrite[$resultPath, CharacterEncoding -> "UTF8"];
WriteString[$texOut,
  "% Auto-generated by Mathematica/CubeGalerkin27.wl --- do not edit by hand.\n",
  "\\subsection{Verified analytical master integrals}\n",
  "\\label{sec:results}\n\n"
];

texEq[label_String, lhs_String, rhs_] := WriteString[$texOut,
  "\\begin{equation}\n", lhs, " \\;=\\; ",
  ToString[TeXForm[rhs]], "\n",
  "\\label{eq:", label, "}\n\\end{equation}\n\n"
];

texLine[s_String] := WriteString[$texOut, s, "\n"];

(* ============================================================ *)
(* Section 1. Master integrals over the unit cube [-1,1]^3       *)
(* ============================================================ *)
(* M[p,q,r] = int_{[-1,1]^3} x^p y^q z^r / sqrt(x^2+y^2+z^2) dV  *)
(* By parity these vanish unless p,q,r are all even.             *)
(* By cubic symmetry M depends only on the multiset {p,q,r}.     *)

ClearAll[M];
M[p_, q_, r_] := M[p, q, r] = If[OddQ[p] || OddQ[q] || OddQ[r],
  0,
  Integrate[
    x^p y^q z^r/Sqrt[x^2 + y^2 + z^2],
    {x, -1, 1}, {y, -1, 1}, {z, -1, 1}
  ]
];

Print["==== Tier-1 master integrals over [-1,1]^3 ===="];
Print["M[0,0,0] = g0Cube = ", FullSimplify[M[0, 0, 0]]];
Print["  numerical = ", N[M[0, 0, 0], 30]];

(* Pell-stable form check *)
g0Pell = (4/3) Log[70226 + 40545 Sqrt[3]] - 2 Pi;
Print["g0Pell    = ", g0Pell];
Print["  numerical = ", N[g0Pell, 30]];
Print["  difference = ", N[M[0, 0, 0] - g0Pell, 30]];

texLine["The verification at degree 0 was reported in Section~\\ref{sec:tier1}."];
texLine["We extend the table to include all parity-allowed master integrals up to degree~6:"];
texLine[""];
texLine["\\begin{table}[h]"];
texLine["\\centering"];
texLine["\\begin{tabular}{lll}"];
texLine["\\toprule"];
texLine["$(p,q,r)$ & $\\mathcal{M}_{p,q,r} = \\int_{[-1,1]^3}\\!\\frac{x^p y^q z^r}{|\\bm{r}|}\\,dV$ & numerical \\\\"];
texLine["\\midrule"];

emitRow[{p_, q_, r_}] := Module[{val, num, lhs},
  val = M[p, q, r];
  num = N[val, 16];
  lhs = "$(" <> ToString[p] <> "," <> ToString[q] <> "," <> ToString[r] <> ")$";
  WriteString[$texOut,
    lhs, " & $", ToString[TeXForm[FullSimplify[val]]], "$ & ",
    "$", ToString[N[val, 8]], "$ \\\\\n"
  ];
  Print["M[", p, ",", q, ",", r, "] = ", FullSimplify[val], "  ≈ ", num];
];

(* All parity-allowed (p,q,r) with p>=q>=r>=0 (canonical form by sym) and p+q+r <= 6 *)
allMoments = Sort@DeleteDuplicates[
  Reverse /@ Sort /@ Tuples[{0, 2, 4, 6}, 3]
];
allMoments = Select[allMoments, Total[#] <= 6 &];
allMoments = Sort[allMoments, Total[#1] < Total[#2] || (Total[#1] == Total[#2] && #1 > #2) &];
Do[emitRow[m], {m, allMoments}];

texLine["\\bottomrule"];
texLine["\\end{tabular}"];
texLine["\\caption{Closed-form values of the scalar master integrals $\\mathcal{M}_{p,q,r}$ over the unit cube.  Cubic symmetry equates entries that are permutations of each other; only canonical orderings $p\\ge q \\ge r$ are listed.}"];
texLine["\\label{tab:tier1-masters}"];
texLine["\\end{table}"];
texLine[""];

(* ============================================================ *)
(* Section 2. The "tent" master integrals over [-2,2]^3          *)
(* ============================================================ *)
(* For Path-B body bilinear form we need                          *)
(*   T[a,b,c] = int_{[-2,2]^3} (2-|x|)^a (2-|y|)^b (2-|z|)^c / |s| ds *)
(* with a,b,c in {0,1}.  Here a+b+c <= 3 and a,b,c are tent     *)
(* exponents from the cube autocorrelation                       *)
(*   chi_V * chi_V (s) = (2-|s_1|)(2-|s_2|)(2-|s_3|).           *)
(* By symmetry s_i -> -s_i, the integrand is even in each axis  *)
(* component, so T[1,1,1] = 8 * int_{[0,2]^3} (2-x)(2-y)(2-z)/r *)

(* The clean way: substitute s = 2 u with ds = 8 du, |s| = 2|u| *)
(*   T[1,1,1] = int_{[-1,1]^3} 8(1-|u_x|)(1-|u_y|)(1-|u_z|) * (8/(2|u|)) du
              = 32 int_{[-1,1]^3} (1-|u_x|)(1-|u_y|)(1-|u_z|)/|u| du *)
(* Expand and use M[*,*,*]:                                      *)
(*   (1-|x|)(1-|y|)(1-|z|) = 1 - |x| - |y| - |z| + |x||y| + ... *)

(* Even-symmetric monomial integrals over [-1,1]^3 are M[2k,2l,2m]. *)
(* The |x| terms must be reformulated.  By symmetry,                  *)
(*   int_{[-1,1]^3} |x|^a y^q z^r/|u| du = 2 int_{[0,1] x [-1,1]^2} x^a y^q z^r/|u| du *)
(* and by similar symmetry in y, z.                                   *)
(* For a clean approach, restrict to positive octant from the start.  *)

ClearAll[Mp];
(* For all-even (p,q,r), the integrand is even in each axis, so       *)
(* M[p,q,r] = 8 Mp[p,q,r] and we can recycle the closed form from M.  *)
(* For mixed parity, we integrate directly over the positive octant.  *)
(* Mathematica sometimes returns a symbolic form with a spurious      *)
(* imaginary part (it cancels algebraically); we project onto the     *)
(* reals and FullSimplify to get a clean real closed form.            *)
(* Canonicalize the argument list (the integrand and the cube are    *)
(* permutation-symmetric in (x,y,z), so Mp depends only on the        *)
(* multiset).  Without this rule Mathematica's Integrate produces     *)
(* different symbolic forms for Mp[1,0,0], Mp[0,1,0], Mp[0,0,1] etc.,  *)
(* which prevents downstream Simplify from collapsing differences.    *)
Mp[p_Integer, q_Integer, r_Integer] /; ! OrderedQ[{p, q, r}] :=
  Mp @@ Sort[{p, q, r}];
Mp[p_, q_, r_] := Mp[p, q, r] = Module[{raw, real},
  raw = If[EvenQ[p] && EvenQ[q] && EvenQ[r],
    M[p, q, r]/8,
    Integrate[
      x^p y^q z^r/Sqrt[x^2 + y^2 + z^2],
      {x, 0, 1}, {y, 0, 1}, {z, 0, 1}
    ]
  ];
  real = FullSimplify[Re[ComplexExpand[raw]]];
  real
];

Print[];
Print["==== Tier-2 positive-octant master integrals over [0,1]^3 ===="];
Print["Mp[0,0,0] = ", Simplify[Mp[0, 0, 0]], "  ≈ ", N[Mp[0, 0, 0], 16]];
Print["Mp[1,0,0] = ", Simplify[Mp[1, 0, 0]], "  ≈ ", N[Mp[1, 0, 0], 16]];
Print["Mp[2,0,0] = ", Simplify[Mp[2, 0, 0]], "  ≈ ", N[Mp[2, 0, 0], 16]];
Print["Mp[1,1,0] = ", Simplify[Mp[1, 1, 0]], "  ≈ ", N[Mp[1, 1, 0], 16]];
Print["Mp[1,1,1] = ", Simplify[Mp[1, 1, 1]], "  ≈ ", N[Mp[1, 1, 1], 16]];
Print["Mp[2,1,0] = ", Simplify[Mp[2, 1, 0]], "  ≈ ", N[Mp[2, 1, 0], 16]];
Print["Mp[2,1,1] = ", Simplify[Mp[2, 1, 1]], "  ≈ ", N[Mp[2, 1, 1], 16]];
Print["Mp[2,2,0] = ", Simplify[Mp[2, 2, 0]], "  ≈ ", N[Mp[2, 2, 0], 16]];

(* Emit a LaTeX table of the positive-octant master integrals.       *)
texLine["The same family of integrals over the positive octant $[0,1]^3$ supplies the body-bilinear-form building blocks; we collect them in Table~\\ref{tab:tier2-masters}."];
texLine[""];
texLine["\\begin{table}[h]"];
texLine["\\centering"];
texLine["\\begin{tabular}{lll}"];
texLine["\\toprule"];
texLine["$(p,q,r)$ & $\\mathcal{M}^+_{p,q,r} = \\int_{[0,1]^3}\\!\\frac{x^p y^q z^r}{|\\bm{r}|}\\,dV$ & numerical \\\\"];
texLine["\\midrule"];

emitMpRow[{p_, q_, r_}] := Module[{val, lhs},
  val = Mp[p, q, r];
  lhs = "$(" <> ToString[p] <> "," <> ToString[q] <> "," <> ToString[r] <> ")$";
  WriteString[$texOut,
    lhs, " & $", ToString[TeXForm[val]], "$ & ",
    "$", ToString[N[val, 8]], "$ \\\\\n"
  ];
];

(* List all (p,q,r) with p,q,r in {0,1,2}, p+q+r<=3 — these are the      *)
(* ones that actually appear in the constant + linear bilinear forms.   *)
mpMoments = Sort@DeleteDuplicates[
  Reverse /@ Sort /@ Tuples[{0, 1, 2}, 3]
];
mpMoments = Select[mpMoments, Total[#] <= 3 &];
mpMoments = Sort[mpMoments, Total[#1] < Total[#2] || (Total[#1] == Total[#2] && #1 > #2) &];
Do[emitMpRow[m], {m, mpMoments}];

texLine["\\bottomrule"];
texLine["\\end{tabular}"];
texLine["\\caption{Closed-form values of the positive-octant master integrals $\\mathcal{M}^+_{p,q,r}$ over $[0,1]^3$. Up to canonical ordering $p\\ge q \\ge r$ and $p+q+r\\le 3$ they exhaust all polynomial weights needed by the Path-B body bilinear form on the constant-and-linear subspace.}"];
texLine["\\label{tab:tier2-masters}"];
texLine["\\end{table}"];
texLine[""];

(* Sanity check: 8 * Mp[0,0,0] should equal M[0,0,0] = g0Cube.        *)
(* The two analytic forms differ by a Pell-unit identity in Z[Sqrt[3]];*)
(* RootReduce/FullSimplify forces it to 0, and we double-check         *)
(* numerically with extra precision.                                   *)
Print[];
Print["Sanity check (analytic) : 8*Mp[0,0,0] - M[0,0,0] = ",
  RootReduce[8 Mp[0, 0, 0] - M[0, 0, 0]]];
Print["Sanity check (numerical): ",
  N[8 Mp[0, 0, 0] - M[0, 0, 0], 30]];

(* ============================================================ *)
(* Section 3. Body bilinear form on the constant subspace        *)
(* ============================================================ *)
(* B_body^{(0,0)}[i,n] := int_{V x V} G_in(r-r') dV dV'           *)
(* For V = [-1,1]^3, G_in(s) = A/|s| delta_in + B s_i s_n / |s|^3 *)
(* where A = (2-C)/(8 pi mu), B = C/(8 pi mu), C = (lam+mu)/(lam+2mu) *)

(* The 6-fold integral reduces via center-of-mass / relative      *)
(* coordinates to                                                   *)
(*   B_body^{(0,0)}[i,n] = int_{[-2,2]^3} G_in(s) * Lambda(s) ds   *)
(* with Lambda(s) = (2-|s_1|)(2-|s_2|)(2-|s_3|) the cube autocorr  *)

(* Substitute s = 2 u:                                              *)
(*   ds = 8 du, |s| = 2|u|, s_i = 2 u_i                            *)
(*   Lambda(s) = 8 (1-|u_1|)(1-|u_2|)(1-|u_3|)                     *)
(*   1/|s| = 1/(2|u|), s_i s_n / |s|^3 = (4 u_i u_n)/(8 |u|^3)    *)
(*                                       = u_i u_n/(2 |u|^3)       *)

(* So:
   B_body^{(0,0)}[i,n] = int_{[-1,1]^3} 8(1-|u|...)*[A/(2|u|) delta_in + B u_i u_n/(2|u|^3)] * 8 du
                      = 32 int_{[-1,1]^3} (1-|u_1|)(1-|u_2|)(1-|u_3|) [A delta_in/|u| + B u_i u_n/|u|^3] du
*)
(* By 8-fold cube symmetry, restrict to positive octant and multiply by 8: *)
(*  B_body^{(0,0)}[i,n] = 256 int_{[0,1]^3} (1-u_1)(1-u_2)(1-u_3) [A delta_in/|u| + B u_i u_n/|u|^3] du *)

(* Diagonal element B_body^{(0,0)}[1,1] = 256 (A * I_A + B * I_B11) *)
(* where:
   I_A    = int_{[0,1]^3} (1-u_1)(1-u_2)(1-u_3) / |u| du
   I_B11  = int_{[0,1]^3} (1-u_1)(1-u_2)(1-u_3) u_1^2 / |u|^3 du
*)

Print[];
Print["==== Tier-3 body bilinear form (positive-octant integrals) ===="];
Print["NB: variable names avoid `I` (Mathematica's imaginary unit)."];
Print["NB: kernels with 1/|u|^3 are reduced to 2D form by IBP on u_1."];

ClearAll[iA, iB11, iB12, K11kernel, K12kernel];

(* ----- iA: scalar tent / |u| as a closed-form sum of Mp values ----- *)
(* By linearity:                                                       *)
(*   (1 - u1)(1 - u2)(1 - u3) = sum (-1)^(a+b+c) u1^a u2^b u3^c        *)
(* and Mp is symmetric in its arguments, so:                           *)
(*   iA = Mp[0,0,0] - 3 Mp[1,0,0] + 3 Mp[1,1,0] - Mp[1,1,1].           *)
iA = Mp[0, 0, 0] - 3 Mp[1, 0, 0] + 3 Mp[1, 1, 0] - Mp[1, 1, 1];
Print["iA (signed sum) = ", iA];
Print["iA  numerical   ≈ ", N[iA, 20]];

(* ----- iB11: tent * u_1^2 / |u|^3 via integration by parts ---------- *)
(* Identity: u_1^2/|u|^3 = 1/|u| - d/du1 (u1/|u|).                     *)
(* IBP on the u_1 integral with weight (1-u1):                         *)
(*   int_0^1 (1-u1) d/du1 (u1/|u|) du1                                 *)
(*     = [(1-u1) u1/|u|]_0^1 + int_0^1 (u1/|u|) du1                    *)
(*     = sqrt(1+u2^2+u3^2) - sqrt(u2^2+u3^2),                          *)
(* and the boundary contributions vanish.                              *)
(* Therefore                                                            *)
(*   iB11 = iA - J11,                                                  *)
(*   J11  = int_{[0,1]^2} (1-u2)(1-u3) [sqrt(1+u2^2+u3^2)              *)
(*                                       - sqrt(u2^2+u3^2)] du2 du3.   *)

K11kernel[u2_, u3_] := (1 - u2) (1 - u3) (
  Sqrt[1 + u2^2 + u3^2] - Sqrt[u2^2 + u3^2]);

J11exact = Integrate[K11kernel[u2, u3], {u2, 0, 1}, {u3, 0, 1}];
Print["J11  symbolic  = ", J11exact];
J11num = NIntegrate[K11kernel[u2, u3], {u2, 0, 1}, {u3, 0, 1},
  WorkingPrecision -> 30, PrecisionGoal -> 25, MaxRecursion -> 30];
Print["J11  numerical ≈ ", J11num];

iB11 = iA - J11exact;
iB11num = N[iA, 30] - J11num;
Print["iB11 (= iA - J11) = ", iB11];
Print["iB11 numerical    ≈ ", iB11num];

(* ----- iB12: tent * u_1 u_2 / |u|^3 via integration by parts ------- *)
(* Identity: u_1 u_2/|u|^3 = - d/du1 (u_2/|u|).                        *)
(* IBP on the u_1 integral with weight (1-u1):                         *)
(*   int_0^1 (1-u1) d/du1 (u_2/|u|) du1                                *)
(*     = [(1-u1) u2/|u|]_0^1 + int_0^1 (u2/|u|) du1                    *)
(*     = -u2/sqrt(u2^2+u3^2) + u2 * ArcSinh(1/sqrt(u2^2+u3^2)).        *)
(* So                                                                  *)
(*   iB12 = int_{[0,1]^2} (1-u2)(1-u3) u_2 *                           *)
(*            [1/s - ArcSinh(1/s)] du2 du3,   s = sqrt(u2^2+u3^2).     *)
(* (Sign comes from the leading minus in u1u2/|u|^3 = -d/du1(u2/|u|).) *)

K12kernel[u2_, u3_] := With[{s = Sqrt[u2^2 + u3^2]},
  (1 - u2) (1 - u3) u2 (1/s - ArcSinh[1/s])];

iB12exact = Integrate[K12kernel[u2, u3], {u2, 0, 1}, {u3, 0, 1}];
Print["iB12 symbolic  = ", iB12exact];
iB12num = NIntegrate[K12kernel[u2, u3], {u2, 0, 1}, {u3, 0, 1},
  WorkingPrecision -> 30, PrecisionGoal -> 25, MaxRecursion -> 30];
Print["iB12 numerical ≈ ", iB12num];

iB12 = iB12exact;

(* ----- Trace identity check: 3 iB11 == iA -------------------------- *)
(* Because the trace of u_i u_n / |u|^3 over i=n equals 1/|u|, and the *)
(* tent weight is symmetric, summing iB11 over the three diagonal      *)
(* directions gives iA exactly.                                        *)
Print[];
Print["Trace identity (numerical): 3*iB11 - iA = ",
  N[3 iB11num - iA, 25]];
Print["  (should be 0 to working precision)"];

(* ---- Symbolic vs numeric cross-checks for the IBP-reduced forms --- *)
Print[];
Print["==== Symbolic vs numeric cross-check ===="];
Module[{j11sym, ib12sym},
  j11sym = N[J11exact, 30];
  ib12sym = N[iB12exact, 30];
  Print["J11  symbolic     ≈ ", j11sym];
  Print["J11  NIntegrate   ≈ ", J11num];
  Print["J11  difference   = ", j11sym - J11num];
  Print["iB12 symbolic     ≈ ", ib12sym];
  Print["iB12 NIntegrate   ≈ ", iB12num];
  Print["iB12 difference   = ", ib12sym - iB12num];
  Print["  (both should be < 1e-20 in absolute value)"];
];

(* ---- Emit the Tier-3 results to the LaTeX fragment ---------------- *)
texLine["\\subsection{Body bilinear-form building blocks}"];
texLine["\\label{sec:results-tier3}"];
texLine[""];
texLine["For the constant subspace of $T_{27}$ the diagonal and off-diagonal entries of the body bilinear form $\\mathcal{B}_{\\mathrm{body}}$ reduce, after the centre-of-mass / relative-coordinate substitution and an octant-symmetry restriction, to three positive scalars."];
texLine["Define"];
texLine["\\begin{align}"];
texLine["  i_A      &:= \\int_{[0,1]^3}\\!(1-u_1)(1-u_2)(1-u_3)\\,\\frac{1}{|\\bm{u}|}\\,d\\bm{u},\\\\"];
texLine["  i_{B,11} &:= \\int_{[0,1]^3}\\!(1-u_1)(1-u_2)(1-u_3)\\,\\frac{u_1^2}{|\\bm{u}|^3}\\,d\\bm{u},\\\\"];
texLine["  i_{B,12} &:= \\int_{[0,1]^3}\\!(1-u_1)(1-u_2)(1-u_3)\\,\\frac{u_1 u_2}{|\\bm{u}|^3}\\,d\\bm{u}."];
texLine["\\end{align}"];
texLine["The first reduces by linearity to a signed combination of $\\mathcal{M}^+_{p,q,r}$ values (Table~\\ref{tab:tier2-masters}):"];
WriteString[$texOut,
  "\\begin{equation}\n",
  "  i_A \\;=\\; \\mathcal{M}^+_{0,0,0} \\;-\\; 3\\mathcal{M}^+_{1,0,0} \\;+\\; 3\\mathcal{M}^+_{1,1,0} \\;-\\; \\mathcal{M}^+_{1,1,1}\n",
  "       \\;\\approx\\; ", ToString[N[iA, 16]], ".\n",
  "  \\label{eq:iA-closed}\n",
  "\\end{equation}\n\n"
];
texLine["The remaining two are obtained by integrating once by parts in the $u_1$ direction; the singular kernel $|\\bm{u}|^{-3}$ collapses to a $|\\bm{u}|^{-1}$-class kernel and a clean two-dimensional residual:"];
WriteString[$texOut,
  "\\begin{align}\n",
  "  i_{B,11} &\\;=\\; i_A \\;-\\; J_{11},\\qquad\n",
  "  J_{11} \\;=\\; \\int_{[0,1]^2}\\!(1-u_2)(1-u_3)\\Bigl[\\sqrt{1+u_2^2+u_3^2} - \\sqrt{u_2^2+u_3^2}\\,\\Bigr]\\,du_2\\,du_3,\\\\\n",
  "  i_{B,12} &\\;=\\; \\int_{[0,1]^2}\\!(1-u_2)(1-u_3)\\,u_2\\,\\Bigl[\\frac{1}{\\sqrt{u_2^2+u_3^2}} \\;-\\; \\operatorname{arcsinh}\\!\\Bigl(\\frac{1}{\\sqrt{u_2^2+u_3^2}}\\Bigr)\\Bigr]\\,du_2\\,du_3.\n",
  "\\end{align}\n\n"
];
texLine["Mathematica evaluates both two-dimensional integrals in closed form:"];
WriteString[$texOut,
  "\\begin{align}\n",
  "  J_{11}   &\\;=\\; ", ToString[TeXForm[J11exact]], "\\\\\n",
  "           &\\;\\approx\\; ", ToString[N[J11exact, 16]], ",\\\\\n",
  "  i_{B,12} &\\;=\\; ", ToString[TeXForm[iB12exact]], "\\\\\n",
  "           &\\;\\approx\\; ", ToString[N[iB12exact, 16]], ".\n",
  "\\end{align}\n\n"
];
texLine["A non-trivial consistency check is supplied by the trace identity"];
texLine["\\begin{equation*}"];
texLine["  3\\,i_{B,11} \\;=\\; \\int_{[0,1]^3}\\!(1-u_1)(1-u_2)(1-u_3)\\,\\frac{u_1^2+u_2^2+u_3^2}{|\\bm{u}|^3}\\,d\\bm{u} \\;=\\; i_A,"];
texLine["\\end{equation*}"];
texLine["which is verified analytically and numerically to working precision."];
texLine[""];

Print[];
Print["==== Body bilinear form Tier-3 (constants) DONE ===="];
Print["Closed forms above are the analytical building blocks of the 9x9 Path-B mass-coupling matrix."];

(* ============================================================ *)
(* Section 4. Generic K1 and K3 helpers                           *)
(* ============================================================ *)
(* For any non-negative integer triple (p,q,r), define              *)
(*   K1[p,q,r] = int_{[0,1]^3} (1-u1)(1-u2)(1-u3) u1^p u2^q u3^r/|u| du *)
(*   K3[p,q,r,i,j] = int_{[0,1]^3} (1-u1)(1-u2)(1-u3) u1^p u2^q u3^r u_i u_j /|u|^3 du *)
(*                                                                   *)
(* K1 reduces to a signed sum of Mp values via                       *)
(*   (1-u1)(1-u2)(1-u3) = sum_{a,b,c=0}^{1} (-1)^{a+b+c} u1^a u2^b u3^c *)
(* K3 reduces via integration by parts on the u_i variable to a 2D    *)
(* residual integral whose integrand contains only |u|^{-1}-class      *)
(* singularities.                                                     *)

ClearAll[K1at, K3at, K3diag, K3off];

(* K1at: closed-form by linearity *)
K1at[p_Integer, q_Integer, r_Integer] := K1at[p, q, r] = Sum[
  (-1)^(a + b + c) Mp[p + a, q + b, r + c],
  {a, 0, 1}, {b, 0, 1}, {c, 0, 1}
];

(* K3 diagonal block: kernel u_1^2/|u|^3.  IBP recursion              *)
(*   u_1^{p+2}/|u|^3 = (p+1) u_1^p/|u| - d/du1 (u_1^{p+1}/|u|),       *)
(* combined with the box weight (1-u_1) and integration by parts in    *)
(* u_1, gives                                                         *)
(*   K3[p,q,r;1,1] = (p+1) K1[p,q,r] - residual2D[p+1, q, r],          *)
(* where                                                              *)
(*   residual2D[k,q,r] := int_{[0,1]^2} (1-u_2)(1-u_3) u_2^q u_3^r *  *)
(*                       int_0^1 u_1^k/sqrt(u_1^2+u_2^2+u_3^2) du1    *)
(*                       du_2 du_3                                    *)
(* (See cube_galerkin27.tex section 4 for the derivation.)            *)

ClearAll[u1RadInt, residual2D];
u1RadInt[k_Integer] := u1RadInt[k] = Integrate[
  u1^k/Sqrt[u1^2 + u2^2 + u3^2], {u1, 0, 1},
  Assumptions -> u2 > 0 && u2 < 1 && u3 > 0 && u3 < 1
];

residual2D[k_Integer, q_Integer, r_Integer] :=
  residual2D[k, q, r] = Integrate[
    (1 - u2) (1 - u3) u2^q u3^r u1RadInt[k],
    {u2, 0, 1}, {u3, 0, 1}
  ];

K3diag[p_Integer, q_Integer, r_Integer] :=
  K3diag[p, q, r] = (p + 1) K1at[p, q, r] - residual2D[p + 1, q, r];

(* K3 off-diagonal (symbolic via IBP).                                *)
(* The integrand is                                                   *)
(*   (1-u1)(1-u2)(1-u3) u1^p u2^q u3^r * u1 u2 / |u|^3                *)
(*   = (1-u1)(1-u2)(1-u3) u2^{q+1} u3^r * u1^{p+1}/|u|^3.             *)
(* Use the algebraic identity                                         *)
(*   u1^{p+1}/|u|^3 = -d/du1(u1^p/|u|) + p u1^{p-1}/|u|,              *)
(* then integrate by parts in u_1 with weight (1-u_1).  The boundary  *)
(* contribution from the d/du1 piece is                               *)
(*    [(1-u1) u1^p/|u|]_0^1 = -0^p / sqrt(u_2^2+u_3^2),               *)
(* which vanishes for p>=1 and equals -1/s for p=0 (s=sqrt(u_2^2+u_3^2)).*)
(*                                                                    *)
(* Combining and integrating the resulting 1D u_1-integral gives      *)
(*   K3off[p,q,r] = p * K1at[p-1, q+1, r]                             *)
(*                   + R[p, q+1, r],                                  *)
(* where                                                              *)
(*   R[0,Q,r] = int_{[0,1]^2}(1-u_2)(1-u_3) u_2^Q u_3^r *             *)
(*               [1/s - arcsinh(1/s)] du_2 du_3,                      *)
(*   R[p,Q,r] = -int_{[0,1]^2}(1-u_2)(1-u_3) u_2^Q u_3^r *            *)
(*               u1RadInt[p] du_2 du_3        (p>=1).                 *)

ClearAll[K3offRes2D, K3off];

K3offRes2D[0, Q_Integer, r_Integer] :=
  K3offRes2D[0, Q, r] = Integrate[
    (1 - u2) (1 - u3) u2^Q u3^r (1/Sqrt[u2^2 + u3^2] -
       ArcSinh[1/Sqrt[u2^2 + u3^2]]),
    {u2, 0, 1}, {u3, 0, 1}];

K3offRes2D[p_Integer, Q_Integer, r_Integer] /; p >= 1 :=
  K3offRes2D[p, Q, r] = -Integrate[
    (1 - u2) (1 - u3) u2^Q u3^r u1RadInt[p],
    {u2, 0, 1}, {u3, 0, 1}];

K3off[p_Integer, q_Integer, r_Integer] :=
  K3off[p, q, r] = If[p == 0,
    K3offRes2D[0, q + 1, r],
    p K1at[p - 1, q + 1, r] + K3offRes2D[p, q + 1, r]
  ];

