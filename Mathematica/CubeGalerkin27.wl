  M9 === Transpose[M9]];
Print["M9 eigenvalues = ", Eigenvalues[M9]];

(* ============================================================ *)
(* Section 6. Body bilinear matrix B9 on T_9                      *)
(* ============================================================ *)
(* B9[i,j] := int int_{V x V} phi^(i)_p G_pq(r-r') phi^(j)_q dV dV'  *)
(*                                                                    *)
(* Reduction to (s, xi) coordinates and then to [0,1]^3:              *)
(*   r = xi + s/2, r' = xi - s/2, dr dr' = dxi ds                     *)
(* Inner xi-integral over the centred box B(s) = product[-(1-|s_i|/2),(1-|s_i|/2)] *)
(* Then s in Omega = [-2,2]^3 substituted by s = 2 u, u in [-1,1]^3,  *)
(* and finally restricted to [0,1]^3 by 8-fold octant symmetry.       *)
(*                                                                    *)
(* The Green's tensor in this rescaled form is                        *)
(*   G_pq(2u) = (A delta_pq)/(2|u|) + B u_p u_q/(2|u|^3)              *)
(* and the overall Jacobian/symmetry prefactor (for an integrand even *)
(* in each axis) is 256.                                              *)

ClearAll[bbBody, bbBodyAB, kernelParity, parityOK];

(* bbBodyAB[poly, p, q] returns the pair {aPiece, bPiece} where         *)
(*   aPiece = int_{[0,1]^3} (tent) * poly(u) / |u| du   [positive oct], *)
(*   bPiece = int_{[0,1]^3} (tent) * poly(u) u_p u_q/|u|^3 du.          *)
(* Parity filtering: a monomial u1^a u2^b u3^c whose combined parity    *)
(* with the kernel is odd in any axis contributes zero to the FULL      *)
(* [-1,1]^3 integral; we mask those out here.  The caller (b9entry)    *)
(* multiplies aPiece and bPiece by a single prefactor 32 that absorbs   *)
(* both the (s, xi) substitution factor and the 8-fold octant factor.   *)

(* kernelParity[p, q] is the parity vector in (u1, u2, u3) of the      *)
(* tensor piece u_p u_q.                                                *)
kernelParity[pIdx_Integer, qIdx_Integer] :=
  Mod[
    {KroneckerDelta[pIdx, 1] + KroneckerDelta[qIdx, 1],
     KroneckerDelta[pIdx, 2] + KroneckerDelta[qIdx, 2],
     KroneckerDelta[pIdx, 3] + KroneckerDelta[qIdx, 3]},
    2
  ];

(* parityOK checks whether a monomial (u1^a u2^b u3^c) combined with a *)
(* kernel of parity vector kp gives an even integrand in every axis.   *)
parityOK[exps_List, kp_List] :=
  AllTrue[Range[3], EvenQ[exps[[#]] + kp[[#]]] &];

ClearAll[u1, u2, u3];

bbBodyAB[poly_, pIdx_Integer, qIdx_Integer] :=
  Module[{coeffs, aPiece, bPiece, kpA = {0, 0, 0}, kpB},
    kpB = kernelParity[pIdx, qIdx];
    coeffs = CoefficientRules[Expand[poly], {u1, u2, u3}];
    aPiece = Sum[
      If[parityOK[pair[[1]], kpA],
        pair[[2]] K1at @@ pair[[1]],
        0],
      {pair, coeffs}
    ];
    bPiece = Sum[
      If[parityOK[pair[[1]], kpB],
        pair[[2]] K3kernel[pair[[1]], pIdx, qIdx],
        0],
      {pair, coeffs}
    ];
    {aPiece, bPiece}
  ];

(* Convenience wrapper that multiplies by symbolic A and B.            *)
bbBody[poly_, pIdx_Integer, qIdx_Integer] :=
  Module[{ab = bbBodyAB[poly, pIdx, qIdx]},
    KroneckerDelta[pIdx, qIdx] Aelas ab[[1]] + Belas ab[[2]]
  ];

(* K3kernel[(p,q,r), i, j] := int_{[0,1]^3} (tent) u1^p u2^q u3^r *    *)
(*                            u_i u_j/|u|^3 du                        *)
(* All six (i,j) cases are reduced to the canonical (1,1) and (1,2)    *)
(* forms by relabelling integration variables.  K3diag handles (i,i)   *)
(* via the IBP recursion in u_i; K3off handles (i,j), i!=j.           *)
ClearAll[K3kernel];
K3kernel[{p_, q_, r_}, i_, j_] := K3kernel[{p, q, r}, i, j] = Which[
  (* Diagonal cases via K3diag, recycling cubic symmetry of the tent. *)
  i == 1 && j == 1, K3diag[p, q, r],
  i == 2 && j == 2, K3diag[q, p, r],   (* swap u1<->u2 *)
  i == 3 && j == 3, K3diag[r, q, p],   (* swap u1<->u3 *)
  (* Off-diagonal cases via the symbolic K3off, recycling symmetries. *)
  (i == 1 && j == 2) || (i == 2 && j == 1), K3off[p, q, r],
  (i == 1 && j == 3) || (i == 3 && j == 1), K3off[p, r, q],  (* swap u2<->u3 *)
  (i == 2 && j == 3) || (i == 3 && j == 2), K3off[q, r, p],  (* swap u1<->u2 then u2<->u3 *)
  True, $Failed
];

Print[];
Print["==== Section 6: kernel helper self-tests ===="];
Print["K3kernel[(0,0,0),1,1] (should equal iB11) = ",
  N[K3kernel[{0, 0, 0}, 1, 1] - iB11, 20]];
Print["K3kernel[(0,0,0),2,2] - iB11 = ",
  N[K3kernel[{0, 0, 0}, 2, 2] - iB11, 20]];
Print["K3kernel[(0,0,0),3,3] - iB11 = ",
  N[K3kernel[{0, 0, 0}, 3, 3] - iB11, 20]];
Print["K3kernel[(0,0,0),1,2] (should equal iB12) = ",
  K3kernel[{0, 0, 0}, 1, 2] - N[iB12, 30]];

Print[];
Print["==== Tier-4 generic framework DONE ===="];
Print["The K1at, K3diag, K3off, K3kernel and bbBody helpers are ready"];
