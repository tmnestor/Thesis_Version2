Print["K3diag[0,0,0] (numerical) ≈ ", N[K3diag[0, 0, 0], 20]];
Print["iB11 (numerical)         ≈ ", N[iB11, 20]];
Print["K3diag[0,0,0] - iB11 (numerical) = ",
