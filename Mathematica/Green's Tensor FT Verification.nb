Print[TeXForm[mTp]]
Print[\"\\nS-wave upgoing (-\\!\\(\\*SubscriptBox[\\(\[Nu]\\), \\(T\\)]\\)):\"]
Print[TeXForm[fTm], \" \\\\times \"]
Print[TeXForm[mTm]]\
\>", "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"4191d312-9c86-47f1-9e1d-3e76b67be6d4"],

