         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]T"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]]}], 
      RowBox[{
       FractionBox["\[Xi]2", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]L"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "+", 
       FractionBox["\[Xi]2", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Nu]L", "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "-", 
       FractionBox["\[Xi]2", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]T"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "-", 
       FractionBox["\[Xi]2", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Nu]T", "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]]}], 
      RowBox[{
       FractionBox["\[Xi]3", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]L"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "+", 
       FractionBox["\[Xi]3", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Nu]L", "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "-", 
       FractionBox["\[Xi]3", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]T"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
