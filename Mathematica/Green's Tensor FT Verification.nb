Cell[CellGroupData[{

Cell["8. LaTeX Export", "Section",ExpressionUUID->"55781fa0-2c48-49a5-88af-be673efe2ea5"],

Cell["\<\
The factored contour contributions can be exported to LaTeX for inclusion in \
the thesis. TeXForm converts Mathematica expressions to LaTeX notation.\
\>", "Text",ExpressionUUID->"aa5c81ee-c437-4f92-b64d-9f105bb90bd8"],

Cell[CellGroupData[{

Cell["\<\
Print[\"P-wave downgoing (+\\!\\(\\*SubscriptBox[\\(\[Nu]\\), \
\\(L\\)]\\)):\"]
Print[TeXForm[fLp], \" \\\\times \"]
Print[TeXForm[mLp]]
Print[\"\\nP-wave upgoing (-\\!\\(\\*SubscriptBox[\\(\[Nu]\\), \\(L\\)]\\)):\"]
Print[TeXForm[fLm], \" \\\\times \"]
Print[TeXForm[mLm]]
Print[\"\\nS-wave downgoing (+\\!\\(\\*SubscriptBox[\\(\[Nu]\\), \
\\(T\\)]\\)):\"]
