        RowBox[{"\[Xi]2", " ", "\[Xi]3"}], 
        RowBox[{"2", " ", "\[Nu]L", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]L"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "-", 
       FractionBox[
        RowBox[{"\[Xi]2", " ", "\[Xi]3"}], 
