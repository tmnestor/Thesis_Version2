Cell[CellGroupData[{

Cell["7. Contour Integral Contributions (Cauchy Residue Theorem)", "Section",ExpressionUUID->"a8407b59-7e96-4fe5-9017-2b171e956133"],

Cell["\<\
By the Cauchy Residue Theorem, the contour integral around a simple pole \
gives 2\[Pi]I times the residue. Each pole contributes a term to the inverse \
Fourier transform:

  \[ContourIntegral] \[UHat]ik(\[Xi]) d\[Xi]1 = 2\[Pi]I \[Times] \
\[CapitalSigma] (residues at enclosed poles)

We multiply each residue matrix by 2\[Pi]I, substitute back the physical \
parameters, and extract the common scalar factor from each matrix.\
\>", "Text",ExpressionUUID->"bd8e8e46-4b9f-44ca-95ee-af0c924c4635"],

Cell[CellGroupData[{

Cell["\<\
(* Apply Cauchy Residue Theorem: contour integral = 2\[Pi]I \[Times] residue *)
(* Substitute back \[Nu]L, \[Nu]T in terms of original parameters *)
(* Factor out the common scalar from each matrix *)
cLp = FullSimplify[2 \[Pi] I resLp /. sub];
cLm = FullSimplify[2 \[Pi] I resLm /. sub];
cTp = FullSimplify[2 \[Pi] I resTp /. sub];
cTm = FullSimplify[2 \[Pi] I resTm /. sub];
extractFactor[mat_] := Module[{g},
  g = PolynomialGCD @@ Flatten[Numerator /@ mat];
  g = g / PolynomialLCM @@ Flatten[Denominator /@ mat];
  {FullSimplify[g], FullSimplify[mat/g]}];
{fLp, mLp} = extractFactor[cLp];
{fLm, mLm} = extractFactor[cLm];
{fTp, mTp} = extractFactor[cTp];
{fTm, mTm} = extractFactor[cTm];
Column[{
Style[\"Contour contribution at \[Xi]1 = +\[Nu]L (P-wave, downgoing):\", \
Bold], Row[{fLp, \" \[Times] \", MatrixForm[mLp]}],
Style[\"Contour contribution at \[Xi]1 = -\[Nu]L (P-wave, upgoing):\", Bold], \
Row[{fLm, \" \[Times] \", MatrixForm[mLm]}],
Style[\"Contour contribution at \[Xi]1 = +\[Nu]T (S-wave, downgoing):\", \
Bold], Row[{fTp, \" \[Times] \", MatrixForm[mTp]}],
Style[\"Contour contribution at \[Xi]1 = -\[Nu]T (S-wave, upgoing):\", Bold], \
Row[{fTm, \" \[Times] \", MatrixForm[mTm]}]
}, Spacings -> 1]\
\>", "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"117f3d8f-1d95-4fc8-9966-c0e9ef1eb6e9"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"Contour contribution at \[Xi]1 = +\[Nu]L (P-wave, \
downgoing):\"\>",
      StripOnInput->False,
      FontWeight->Bold]},
    {
     TemplateBox[{
       FractionBox["\[Pi]", 
        RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
          SuperscriptBox["\[Omega]", "2"]}]], "\" \[Times] \"", 
       TagBox[
        RowBox[{"(", "\[NoBreak]", 
          GridBox[{{
             RowBox[{"\[ImaginaryI]", " ", 
               SuperscriptBox["\[Nu]L", "2"]}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]2"}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]3"}]}, {
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]2"}], 
             RowBox[{"\[ImaginaryI]", " ", 
               SuperscriptBox["\[Xi]2", "2"]}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Xi]2", " ", "\[Xi]3"}]}, {
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]3"}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Xi]2", " ", "\[Xi]3"}], 
             RowBox[{"\[ImaginaryI]", " ", 
               SuperscriptBox["\[Xi]3", "2"]}]}}, RowSpacings -> 1, 
           ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> 
           Center], "\[NoBreak]", ")"}], 
        Function[BoxForm`e$, 
         MatrixForm[BoxForm`e$]]]},
      "RowDefault"]},
    {
     StyleBox["\<\"Contour contribution at \[Xi]1 = -\[Nu]L (P-wave, \
upgoing):\"\>",
      StripOnInput->False,
      FontWeight->Bold]},
    {
     TemplateBox[{
       FractionBox["\[Pi]", 
        RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
          SuperscriptBox["\[Omega]", "2"]}]], "\" \[Times] \"", 
       TagBox[
        RowBox[{"(", "\[NoBreak]", 
          GridBox[{{
             RowBox[{
               RowBox[{"-", "\[ImaginaryI]"}], " ", 
               SuperscriptBox["\[Nu]L", "2"]}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]2"}], 
             RowBox[{"\[ImaginaryI]", " ", "\[Nu]L", " ", "\[Xi]3"}]}, {
