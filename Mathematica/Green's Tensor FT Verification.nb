Cell["9. Summary of Verifications", "Section",ExpressionUUID->"884b4c16-e9e0-44c7-bede-f759a704ef89"],

Cell[CellGroupData[{

Cell["\<\
z = ConstantArray[0, {3, 3}];
t1 = (res1 === z);
t2 = (res2 === z);
t3 = (diff === z);
t4 = (equivR === z);
t5 = (diffR === z);
Column[{
If[t1, Style[\"[PASS] Form 1 satisfies the PDE.\", Bold, Darker[Green]], \
Style[\"[FAIL] Form 1\", Bold, Red]],
If[t2, Style[\"[PASS] Form 2 satisfies the PDE.\", Bold, Darker[Green]], \
Style[\"[FAIL] Form 2\", Bold, Red]],
If[t3, Style[\"[PASS] Forms 1 and 2 are algebraically equivalent.\", Bold, \
Darker[Green]], Style[\"[FAIL] Forms not equivalent\", Bold, Red]],
If[t4, Style[\"[PASS] Form 3 reduces to Form 2 under substitution.\", Bold, \
Darker[Green]], Style[\"[FAIL] Form 3 != Form 2\", Bold, Red]],
If[t5, Style[\"[PASS] Partial fractions preserve Form 3.\", Bold, \
Darker[Green]], Style[\"[FAIL] Partial fractions error\", Bold, Red]]
}]\
\>", "Input",
 CellLabel->"In[65]:=",ExpressionUUID->"6cf8958f-b4ed-4e40-830f-93f0ad3fcc9c"],

