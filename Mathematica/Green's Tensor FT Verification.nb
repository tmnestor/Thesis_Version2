Notebook[{

Cell[CellGroupData[{
Cell["\<\
The Frequency-Domain Elastodynamic Green\[CloseCurlyQuote]s Tensor
via the Calculus of Residues\
\>", "Title",ExpressionUUID->"aa869ffb-58ae-4fd5-ae90-8f06146ec73d"],

Cell[TextData[{
 "The Fourier-domain Green\[CloseCurlyQuote]s tensor satisfies the elastic \
wave equation by substituting back into the PDE.\nThe PDE (frequency domain):\
\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Mu]", " ", 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[PartialD]", "2"], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["x", "j"], "\[PartialD]", 
         SubscriptBox["x", "j"]}]], " ", 
       SubscriptBox[
        OverscriptBox["U", "^"], "ik"]}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "+", "\[Mu]"}], ")"}], 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[PartialD]", "2"], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["x", "i"], "\[PartialD]", 
         SubscriptBox["x", "j"]}]], 
       SubscriptBox[
        OverscriptBox["U", "^"], "jk"]}]}], " ", "+", " ", 
     RowBox[{"\[Rho]", 
      SuperscriptBox["\[Omega]", "2"], 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["\[Delta]", "ik"]}], " ", 
     RowBox[{"\[Delta]", "(", 
      RowBox[{"x", "-", "y"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "2672866a-936d-4b46-8be7-905bf886ca36"],
 "\nIn Fourier space (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", 
     SubscriptBox["x", "j"]], " ", 
    RowBox[{"\[Rule]", " ", 
     RowBox[{"i", " ", 
      SubscriptBox["\[Xi]", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "49793c7f-8915-4b25-83db-1b7c4b1ec5e1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Delta]", "(", 
     RowBox[{"x", "-", "y"}], ")"}], " ", "\[Rule]", " ", 
    SuperscriptBox["e", 
     RowBox[{"i", " ", "\[Xi]", "\[CenterDot]", "y"}]]}], TraditionalForm]],
  ExpressionUUID->"ff49e7b0-8473-4220-8601-8b7fc72927a6"],
 "), the PDE becomes:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[Mu]"}], " ", 
      SuperscriptBox["\[Xi]", "2"], " ", 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}], " ", "-", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "+", "\[Mu]"}], ")"}], " ", 
      SubscriptBox["\[Xi]", "i"], 
      SubscriptBox["\[Xi]", "j"], " ", 
      SubscriptBox[
       OverscriptBox["U", "^"], "jk"]}], " ", "+", " ", 
     RowBox[{"\[Rho]", 
      SuperscriptBox["\[Omega]", "2"], 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["\[Delta]", "ik"]}], " ", 
     SuperscriptBox["e", 
      RowBox[{"i", " ", "\[Xi]", "\[CenterDot]", "y"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"25229f2b-f959-4805-86ce-eadbb006fa6b"],
 "\n\nThis notebook derives the elastodynamic Green\[CloseCurlyQuote]s tensor \
in the spatial Fourier domain, verifies it satisfies the governing PDE, \
decomposes it into simple poles, and evaluates the inverse Fourier transform \
in \[Xi]1 using the calculus of residues."
}], "Text",
 CellChangeTimes->{{3.981658673439118*^9, 
  3.9816586930597982`*^9}},ExpressionUUID->"d85e825b-5619-483c-98eb-\
98080b0a7cb8"],

Cell[CellGroupData[{

Cell["1. Setup and Notation", "Section",ExpressionUUID->"199868ea-1a16-49eb-9660-63261d633283"],

Cell["\<\
We denote the spatial Fourier transform variable by \[Xi] = (\[Xi]1, \[Xi]2, \
\[Xi]3), with \[Xi]1 the vertical (depth) direction. The elastic moduli are \
\[Lambda], \[Mu] (Lam\[EAcute] parameters), \[Rho] is density, and \[Omega] \
is angular frequency. The longitudinal and transverse wavenumbers are kL and \
kT.\
\>", "Text",ExpressionUUID->"214b6c88-0f45-4c46-b711-113b7fc78cb6"],

Cell["ClearAll[\"Global`*\"]", "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"45d8ff4e-1f42-483c-9508-8bea93b29057"],

Cell["\<\
\[Xi] = {\[Xi]1, \[Xi]2, \[Xi]3};
\[Xi]sq = \[Xi]1^2 + \[Xi]2^2 + \[Xi]3^2;\
\>", "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"e1696ab5-8258-476e-b823-6900e2fd99b6"],

Cell["\<\
kL2 = \[Rho] \[Omega]^2/(\[Lambda] + 2 \[Mu]);
kT2 = \[Rho] \[Omega]^2/\[Mu];\
\>", "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"0bfabed6-c7f5-4c69-a0e4-a13d284a6619"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. The Green\[CloseCurlyQuote]s Tensor in Fourier Space (Form 1)", \
"Section",ExpressionUUID->"5c33136a-3544-4507-b549-401c1228068b"],

Cell["\<\
The elastodynamic equation of motion in the frequency domain is:
  -\[Mu] \[Xi]\\[Squared] \[UHat]ik - (\[Lambda]+\[Mu]) \[Xi]i \[Xi]j \
\[UHat]jk + \[Rho]\[Omega]\\[Squared] \[UHat]ik = -\[Delta]ik
The Green\[CloseCurlyQuote]s tensor \[UHat]ik(\[Xi]) is the solution. Form 1 \
writes it as a single combined fraction with both longitudinal (P) and \
transverse (S) wave contributions coupled in the denominator.\
\>", "Text",ExpressionUUID->"7eb62784-89e8-4cd5-8ba1-66fd133f8ffc"],

Cell["\<\
Uhat[i_, k_] := -(1/\[Mu]) ((kL2 - \[Xi]sq) KroneckerDelta[i, k] + (1 - \
kL2/kT2) \[Xi][[i]] \[Xi][[k]])/((kL2 - \[Xi]sq) (kT2 - \[Xi]sq))\
\>", "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"8150d0c5-50cd-41b9-8fab-25d79b571edf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Partial Fraction Decomposition (Form 2)", "Section",ExpressionUUID->"ff690209-6eba-4499-a659-8c848bd7c96b"],

Cell["\<\
We separate the P-wave and S-wave contributions by partial fractions in \
|\[Xi]|\\[Squared]. The denominator factors as (\[Xi]sq - kL2)(\[Xi]sq - \
kT2), giving terms with single poles at \[Xi]sq = kL2 and \[Xi]sq = kT2 \
respectively.\
\>", "Text",ExpressionUUID->"be6bc96b-f5de-433a-8bdf-7587294426ca"],

Cell["\<\
Ohat[i_, k_] := (1/\[Mu]) (\[Xi][[i]] \[Xi][[k]]/kT2 (1/(\[Xi]sq - kL2) - 1/(\
\[Xi]sq - kT2)) + KroneckerDelta[i, k]/(\[Xi]sq - kT2))\
\>", "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"511a019e-f50c-4b95-bb30-edb34fb802ef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Verification", "Section",ExpressionUUID->"d72e2096-33b5-4660-915a-5b5294047320"],

Cell["\<\
We verify that both forms satisfy the elastodynamic equation (the left-hand \
side plus \[Delta]ik should vanish) and that they are algebraically \
equivalent.\
\>", "Text",ExpressionUUID->"36fe3853-dff8-4091-8f96-3d607f5c2746"],

Cell[CellGroupData[{

Cell["\<\
(* Test 1: Form 1 satisfies the PDE *)
LHS1[i_, k_] := -\[Mu] \[Xi]sq Uhat[i, k] - (\[Lambda] + \[Mu]) \[Xi][[i]] \
Sum[\[Xi][[j]] Uhat[j, k], {j, 1, 3}] + \[Rho] \[Omega]^2 Uhat[i, k]
res1 = FullSimplify[Table[LHS1[i, k] + KroneckerDelta[i, k], {i, 1, 3}, {k, \
1, 3}]];
MatrixForm[res1]\
\>", "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"d3e7454a-7e9a-423d-9a57-6df62af1fb8e"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", "0", "0"},
     {"0", "0", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.981658787773642*^9},
 CellLabel->
  "Out[11]//MatrixForm=",ExpressionUUID->"fe89c386-31c0-462a-ac18-\
2401a444e92e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* Test 2: Form 2 satisfies the PDE *)
LHS2[i_, k_] := -\[Mu] \[Xi]sq Ohat[i, k] - (\[Lambda] + \[Mu]) \[Xi][[i]] \
Sum[\[Xi][[j]] Ohat[j, k], {j, 1, 3}] + \[Rho] \[Omega]^2 Ohat[i, k]
res2 = FullSimplify[Table[LHS2[i, k] + KroneckerDelta[i, k], {i, 1, 3}, {k, \
1, 3}]];
MatrixForm[res2]\
\>", "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"258c0886-7132-4d7f-b7ef-69ac8039f4dc"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", "0", "0"},
     {"0", "0", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.981658787802792*^9},
 CellLabel->
  "Out[15]//MatrixForm=",ExpressionUUID->"fd385a5c-3f32-4a85-af2e-\
daf836f4e17f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* Test 3: Algebraic equivalence of Forms 1 and 2 *)
diff = FullSimplify[Table[Uhat[i, k] - Ohat[i, k], {i, 1, 3}, {k, 1, 3}]];
MatrixForm[diff]\
\>", "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"088efbf7-bfd1-418b-8837-c27b8b6da04f"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", "0", "0"},
     {"0", "0", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.981658787811495*^9},
 CellLabel->
  "Out[18]//MatrixForm=",ExpressionUUID->"e3b6ddf1-4d78-4a8a-8fe4-\
9c846f40d26c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Decomposition into Simple Poles in \[Xi]1", "Section",ExpressionUUID->"86151338-d94b-4874-95f6-413b9101dece"],

Cell["\<\
To evaluate the inverse Fourier transform in \[Xi]1 (the depth direction) by \
contour integration, we must express the integrand in terms of simple poles \
in \[Xi]1.

Since \[Xi]sq = \[Xi]1\\[Squared] + \[Xi]2\\[Squared] + \[Xi]3\\[Squared], \
each factor (\[Xi]sq - kL2) can be written as (\[Xi]1\\[Squared] - \
\[Nu]L\\[Squared]) where \[Nu]L\\[Squared] = kL\\[Squared] - \
\[Xi]2\\[Squared] - \[Xi]3\\[Squared] is the squared vertical wavenumber for \
P-waves. Similarly \[Nu]T\\[Squared] = kT\\[Squared] - \[Xi]2\\[Squared] - \
\[Xi]3\\[Squared] for S-waves.

The quadratic denominators then factor into linear poles:
  \[Xi]1\\[Squared] - \[Nu]L\\[Squared] = (\[Xi]1 - \[Nu]L)(\[Xi]1 + \[Nu]L)
  \[Xi]1\\[Squared] - \[Nu]T\\[Squared] = (\[Xi]1 - \[Nu]T)(\[Xi]1 + \[Nu]T)

Mathematica\[CloseCurlyQuote]s Apart function performs this decomposition \
automatically.\
\>", "Text",ExpressionUUID->"1f859da3-0c0e-428a-a9ff-c6dd2f4a81b3"],

Cell["\<\
(* Rewrite Form 2 with denominators in terms of \[Xi]1 and \[Nu]L, \[Nu]T *)
OhatR[i_, k_] := (1/\[Mu]) (\[Xi][[i]] \[Xi][[k]]/kT2 (1/(\[Xi]1^2 - \
\[Nu]L^2) - 1/(\[Xi]1^2 - \[Nu]T^2)) + KroneckerDelta[i, k]/(\[Xi]1^2 - \
\[Nu]T^2))\
\>", "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"d303386c-64f5-4902-a447-e9aa70fa56aa"],

Cell[CellGroupData[{

Cell["\<\
(* Verify OhatR reduces to Ohat under substitution *)
sub = {\[Nu]L^2 -> kL2 - \[Xi]2^2 - \[Xi]3^2, \[Nu]T^2 -> kT2 - \[Xi]2^2 - \
\[Xi]3^2};
equivR = FullSimplify[Table[OhatR[i, k] - Ohat[i, k], {i, 1, 3}, {k, 1, 3}] \
/. sub];
MatrixForm[equivR]\
\>", "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"52772e9a-870d-4bdf-bfd1-24a4e24aeafb"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", "0", "0"},
     {"0", "0", "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.981658787825368*^9},
 CellLabel->
  "Out[24]//MatrixForm=",ExpressionUUID->"fb27946c-c2f2-4cfa-a79f-\
679eb5a1d8c3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* Partial fraction decomposition of each component wrt \[Xi]1 *)
Rhat[i_, k_] := Apart[OhatR[i, k], \[Xi]1]
resR = Table[Rhat[i, k], {i, 1, 3}, {k, 1, 3}];
MatrixForm[resR]\
\>", "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"6ca9c8d6-f6dd-4f0e-8a09-9f3d05302799"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       FractionBox["\[Nu]L", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "\[Nu]L"}], "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "-", 
       FractionBox["\[Nu]L", 
        RowBox[{"2", " ", 
         RowBox[{"(", 
          RowBox[{"\[Nu]L", "+", "\[Xi]1"}], ")"}], " ", "\[Rho]", " ", 
         SuperscriptBox["\[Omega]", "2"]}]], "+", 
       FractionBox[
        RowBox[{
         RowBox[{"\[Mu]", " ", 
          SuperscriptBox["\[Nu]T", "2"]}], "-", 
