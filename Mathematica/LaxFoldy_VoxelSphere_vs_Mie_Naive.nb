   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Amplitude comparison (first few angles) ---\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"PaddedForm", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"TableForm", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", "\n", "      ", 
            RowBox[{
             RowBox[{
              RowBox[{"thetaGrid", "[", 
               RowBox[{"[", "i", "]"}], "]"}], " ", 
              RowBox[{"180", "/", "Pi"}]}], ",", "\n", "      ", 
             RowBox[{"Abs", "[", 
              RowBox[{"lfAmplitude", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", "\n", "      ", 
             RowBox[{"Abs", "[", 
              RowBox[{"mieAmplitude", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", "\n", "      ", 
             RowBox[{"If", "[", 
