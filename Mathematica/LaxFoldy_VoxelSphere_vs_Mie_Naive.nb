          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{
            "Include", " ", "phase", " ", "factor", " ", "to", " ", "match", " ",
              "Lax"}], "-", "Foldy"}], " ", "*)"}], "\n", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{"Direct", " ", "far", "-", 
            RowBox[{"field", " ", "amplitude"}]}], " ", "*)"}], "\n", "    ", 
          "fP"}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nAngles"}], "}"}]}], "\n", "]"}]}], ";"}], 
