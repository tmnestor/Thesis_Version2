           RowBox[{"thetaGrid", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"kPv", " ", "=", " ", 
           RowBox[{"omega", "/", "alphaBg"}]}], ";", "\n", "    ", 
