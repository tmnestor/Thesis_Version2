Cell[CellGroupData[{

Cell["10. Comparison Plots", "Section",ExpressionUUID->"a1b00011-0001-0001-0001-000000000001"],

Cell["\<\
Plot the Lax\[Dash]Foldy voxelized result against exact Mie on the same axes. \
We show both amplitude and phase of the far-field P-wave scattering pattern.\
\>", "Text",ExpressionUUID->"a1b00011-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "thetaGrid", " ", "already", " ", "covers", " ", "0", " ", "to", " ", 
    "Pi"}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", " ", 
     RowBox[{"Plot", " ", "1"}]}], ":", " ", 
    RowBox[{"Re", " ", "==="}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"pltRe", " ", "=", " ", 
     RowBox[{"Show", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Re", "[", "mieAmplitude", "]"}]}], "}"}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Blue"}], "}"}]}], ",", "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", "\"\<Mie (exact)\>\"", "}"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Re", "[", "lfAmplitude", "]"}]}], "}"}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<Lax-Foldy 9x9 (\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
            " ", "\"\< cubes)\>\""}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n",
        "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<Re[f_P]\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Re[f_P]: 9x9 Lax-Foldy vs Mie\>\""}], ",", "\n", 
       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltRe", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", " ", 
      RowBox[{"Plot", " ", "2"}]}], ":", " ", 
     RowBox[{"Im", " ", "==="}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"pltIm", " ", "=", " ", 
     RowBox[{"Show", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Im", "[", "mieAmplitude", "]"}]}], "}"}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Blue"}], "}"}]}], ",", "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", "\"\<Mie (exact)\>\"", "}"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Im", "[", "lfAmplitude", "]"}]}], "}"}], "]"}], ",", 
