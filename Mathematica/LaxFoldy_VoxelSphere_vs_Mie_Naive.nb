  RowBox[{"\<\"Volume of voxels: \"\>", "\[InvisibleSpace]", 
   "0.5336076817558298`", 
   "\[InvisibleSpace]", "\<\" km\\\\[ThreeSuperior]\"\>"}],
  SequenceForm[
  "Volume of voxels: ", 0.5336076817558298, " km\\[ThreeSuperior]"],
