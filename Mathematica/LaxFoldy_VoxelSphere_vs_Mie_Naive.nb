         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<Lax-Foldy 9x9 (\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
            " ", "\"\< cubes)\>\""}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n",
        "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<Im[f_P]\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Im[f_P]: 9x9 Lax-Foldy vs Mie\>\""}], ",", "\n", 
       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltIm", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", " ", 
      RowBox[{"Plot", " ", "3"}]}], ":", " ", 
     RowBox[{
      RowBox[{"Amplitude", " ", "ratio"}], " ", "==="}]}], " ", "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"ratioData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"thetaGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", 
          RowBox[{"180", "/", "Pi"}]}], ",", "\n", "   ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", ">", " ", 
            RowBox[{"10", "^", 
             RowBox[{"-", "15"}]}]}], ",", "\n", "     ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"lfAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", 
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", " ", "1"}], 
          "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nAngles"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltRatio", " ", "=", " ", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"ratioData", ",", "\n", "  ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", " ", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<|Lax-Foldy| / |Mie|\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Amplitude Ratio: 9x9 Lax-Foldy / Mie\>\""}], ",", "\n", 
       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"All", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "2"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Epilog", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Gray", ",", " ", "Dashed", ",", " ", 
          RowBox[{"InfiniteLine", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltRatio", "]"}], ";"}], "\n"}]}]], "Input",
