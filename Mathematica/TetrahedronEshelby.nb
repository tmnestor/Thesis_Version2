Cell[CellGroupData[{

Cell["6. T-Matrix Assembly and Effective Contrasts", "Section",ExpressionUUID->"a1b2c3d4-0007-0001-0001-000000000001"],

Cell["\<\
Assemble the self-consistent T-matrix using the same formulas as the cube \
(assuming cubic A,B,C decomposition holds). Compute T1, T2, T3 coupling \
coefficients, amplification factors, and effective contrasts.\
\>", "Text",ExpressionUUID->"a1b2c3d4-0007-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === Material contrast (moderate, positive, ~10%) === *)
\[CapitalDelta]\[Lambda] = 2 10^9;    (* +2 GPa, exact *)
\[CapitalDelta]\[Mu] = 1 10^9;        (* +1 GPa *)
\[CapitalDelta]\[Rho] = 100;           (* +100 kg/m^3 *)

Print[\"Material contrast:\"];
Print[\"  \[CapitalDelta]\[Lambda] = \", \[CapitalDelta]\[Lambda]/10^9, \" \
GPa\"];
Print[\"  \[CapitalDelta]\[Mu] = \", \[CapitalDelta]\[Mu]/10^9, \" GPa\"];
Print[\"  \[CapitalDelta]\[Rho] = \", \[CapitalDelta]\[Rho], \" \
kg/m\\[ThreeSuperior]\"];

(* === T1, T2, T3 coupling coefficients === *)
Itens[i_, j_, k_, l_, Av_, Bv_, Cv_] :=
  Av KroneckerDelta[i, j] KroneckerDelta[k, l] +
  Bv (KroneckerDelta[i, k] KroneckerDelta[j, l] +
       KroneckerDelta[i, l] KroneckerDelta[j, k]) +
  Cv Boole[i == j == k == l];

Stens[m_, n_, j_, k_, Av_, Bv_, Cv_] :=
  (Itens[m, j, k, n, Av, Bv, Cv] + Itens[n, j, k, m, Av, Bv, Cv])/2;

DcTens[j_, k_, l_, p_] :=
  \[CapitalDelta]\[Lambda] KroneckerDelta[j, k] KroneckerDelta[l, p] +
  \[CapitalDelta]\[Mu] (KroneckerDelta[j, l] KroneckerDelta[k, p] +
                         KroneckerDelta[j, p] KroneckerDelta[k, l]);

Ttens[m_, n_, l_, p_, Av_, Bv_, Cv_] :=
  Sum[Stens[m, n, j, k, Av, Bv, Cv] DcTens[j, k, l, p], {j, 3}, {k, 3}];

T1tet = Ttens[1, 1, 2, 2, AtotTet, BtotTet, CtotTet];
T2tet = Ttens[1, 2, 1, 2, AtotTet, BtotTet, CtotTet];
T3tet = Ttens[1, 1, 1, 1, AtotTet, BtotTet, CtotTet] - T1tet - 2 T2tet;

Print[\"\\nT-matrix coupling coefficients:\"];
Print[\"  T1 = \", N[T1tet]];
Print[\"  T2 = \", N[T2tet]];
Print[\"  T3 = \", N[T3tet]];

(* === Amplification factors === *)
ampU = 1/(1 - \[Omega]test^2 \[CapitalDelta]\[Rho] Gamma0tet);
ampTheta = 1/(1 - 3 T1tet - 2 T2tet - T3tet);
ampEoff = 1/(1 - 2 T2tet);
ampEdiag = 1/(1 - 2 T2tet - T3tet);

Print[\"\\nAmplification factors:\"];
Print[\"  A_u     = \", N[ampU]];
Print[\"  A_\[Theta]   = \", N[ampTheta]];
Print[\"  A_e^off = \", N[ampEoff]];
Print[\"  A_e^diag= \", N[ampEdiag]];

(* === Effective contrasts === *)
\[CapitalDelta]\[Rho]star = \[CapitalDelta]\[Rho] ampU;
\[CapitalDelta]\[Mu]starOff = \[CapitalDelta]\[Mu] ampEoff;
\[CapitalDelta]\[Mu]starDiag = \[CapitalDelta]\[Mu] ampEdiag;
\[CapitalDelta]\[Lambda]star = (\[CapitalDelta]\[Lambda] + 2/3 \
\[CapitalDelta]\[Mu]) ampTheta -
                               2/3 \[CapitalDelta]\[Mu] ampEdiag;

Print[\"\\nEffective contrasts:\"];
Print[\"  \[CapitalDelta]\[Rho]* = \", N[\[CapitalDelta]\[Rho]star]];
Print[\"  \[CapitalDelta]\[Lambda]* = \", N[\[CapitalDelta]\[Lambda]star]];
Print[\"  \[CapitalDelta]\[Mu]*_off = \", N[\[CapitalDelta]\[Mu]starOff]];
Print[\"  \[CapitalDelta]\[Mu]*_diag = \", N[\[CapitalDelta]\[Mu]starDiag]];
Print[\"  Cubic anisotropy \[CapitalDelta]\[Mu]*_diag - \
\[CapitalDelta]\[Mu]*_off = \",
       N[\[CapitalDelta]\[Mu]starDiag - \[CapitalDelta]\[Mu]starOff]];\
\>", "Input",
 CellLabel->
  "In[245]:=",ExpressionUUID->"a1b2c3d4-0007-0001-0001-000000000003"],

