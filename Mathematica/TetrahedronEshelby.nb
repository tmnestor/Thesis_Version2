Cell[CellGroupData[{

Cell["\<\
(* === Summary: exact Eshelby constants for the regular tetrahedron === *)
Print[\"\\n=== EXACT ESHELBY CONSTANTS ===\"];
Print[\"Geometric integrals (material-independent):\"];
Print[\"  Ja_{1122} = \", Ja1122];
Print[\"  Jb_{1122} = \", Jb1122];
Print[\"  Jb_{1212} = \", Jb1212];
Print[\"  Ja_{1111} = \", Ja1111];
Print[\"  Jb_{1111} = \", Jb1111];
Print[\"\\nGeneral formula: I_{ijkl} = a0 * Ja + b0 * Jb\"];
Print[\"  a0 = (\[Alpha]^2+\[Beta]^2)/(8\[Pi]\[Rho]\[Alpha]^2\[Beta]^2)\"];
Print[\"  b0 = (\[Alpha]^2-\[Beta]^2)/(8\[Pi]\[Rho]\[Alpha]^2\[Beta]^2)\"];
Print[\"\\nTetrahedron Eshelby (numerical, for test parameters):\"];
Print[\"  A_tet = \", N[Atet]];
Print[\"  B_tet = \", N[Btet]];
Print[\"  C_tet = \", N[Ctet]];
Print[\"\\ng0_tet = \", g0Tet];\
\>", "Input",
 CellLabel->
  "In[318]:=",ExpressionUUID->"a1b2c3d4-0008-0001-0001-000000000005"],

