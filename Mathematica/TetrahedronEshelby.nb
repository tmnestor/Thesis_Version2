Cell[CellGroupData[{

Cell["\<\
2. Static Eshelby Depolarization \[Dash] Analytical Surface Integrals\
\>", "Section",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000001"],

Cell["\<\
The static Kelvin Green\[CloseCurlyQuote]s tensor G\[Degree]_{ij} = \
a\\[SubZero] \[Delta]_{ij}/r + b\\[SubZero] x_i x_j/r\\[ThreeSuperior] has \
gradient:

  H_{ijk} = a\\[SubZero](\[Minus]x_k/r\\[ThreeSuperior])\[Delta]_{ij} + \
b\\[SubZero](\[Delta]_{ik} x_j + \[Delta]_{jk} x_i)/r\\[ThreeSuperior] \
\[Minus] 3b\\[SubZero] x_i x_j x_k/r\\[FiveSuperior]

Via the divergence theorem:
  I_{ijkl} = \[CapitalSigma]_faces \[Integral]_face H_{ijk} n_l dS

On each parametric triangle x(s,t) = v\\[SubZero] + s e\\[SubOne] + t \
e\\[SubTwo], the integrand is polynomial/(quadratic)^{n/2}.  Mathematica\
\[CloseCurlyQuote]s symbolic Integrate handles these exactly (results involve \
ArcTan, Log, Sqrt).

We factor I_{ijkl} = a\\[SubZero] Ja_{ijkl} + b\\[SubZero] Jb_{ijkl} where \
Ja, Jb are purely geometric.\
\>", "Text",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === Analytical Eshelby tensor via symbolic Integrate === *)
(* Factor: I_{ijkl} = a0 * Ja_{ijkl} + b0 * Jb_{ijkl} *)
(* Ja, Jb are purely geometric integrals with exact algebraic results *)

(* Helper: symbolic surface integral over one parametric triangle *)
(* Returns the integral of integrand(x, rsq) * nJac_l over the triangle *)
faceIntegral[ff_, integrand_] :=
  Module[{fc = tetFaces[[ff]], x, rsq},
    x = fc[\"v0\"] + s fc[\"e1\"] + t fc[\"e2\"];
    rsq = Expand[x . x];
    Integrate[integrand[x, rsq], {s, 0, 1}, {t, 0, 1 - s}]//Simplify
  ];

(* Geometric kernel Ja: from a0 * (-x_k/r^3) * delta_ij term *)
(* Ja_{ijkl} = delta_ij * sum_f nJac_l * integral(-x_k / rsq^{3/2}) *)
computeJa[kk_, ll_] :=
  Sum[
    tetFaces[[ff]][\"nJac\"][[ll]] *
    faceIntegral[ff,
      Function[{x, rsq}, -x[[kk]] / rsq^(3/2)]],
    {ff, 4}];

(* Geometric kernel Jb: from b0 * [(delta_ik xj + delta_jk xi)/r^3 - 3 xi xj \
xk/r^5] *)
computeJb[ii_, jj_, kk_, ll_] :=
  Sum[
    Module[{nJl = tetFaces[[ff]][\"nJac\"][[ll]]},
      nJl * faceIntegral[ff,
        Function[{x, rsq},
          (KroneckerDelta[ii, kk] x[[jj]] +
           KroneckerDelta[jj, kk] x[[ii]]) / rsq^(3/2) -
          3 x[[ii]] x[[jj]] x[[kk]] / rsq^(5/2)
        ]]],
    {ff, 4}];

Print[\"Analytical surface integral functions defined.\"];\
\>", "Input",
 CellChangeTimes->{{3.982198366339753*^9, 3.982198369741997*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000003"],

Cell[BoxData["\<\"Analytical surface integral functions defined.\"\>"], \
"Print",
 CellChangeTimes->{3.9821985773500853`*^9},
 CellLabel->
  "During evaluation of \
In[39]:=",ExpressionUUID->"1f9a96d5-42bb-4623-97e2-e2af3f306de1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* === Compute the 3 independent components === *)
(* By T_d symmetry: only I_{1111}, I_{1122}, I_{1212} are independent *)
(* All others either equal these or are zero *)

Print[\"Computing 3 independent Eshelby components analytically...\"];
Print[\"(Each requires symbolic integration over 4 triangular faces)\"];

(* I_{1122}: i=1, j=1, k=2, l=2 *)
(* H_{112} = a0*(-x2/r^3)*1 + b0*(0) - 3*b0*x1^2*x2/r^5 *)
(* Ja part: delta_{11} * sum nJac_2 * integral(-x_2/rsq^{3/2}) *)
Print[\"\\nComputing I_{1122} (= A)...\"];
Ja1122 = computeJa[2, 2];
Jb1122 = computeJb[1, 1, 2, 2];
I1122 = a0 Ja1122 + b0 Jb1122;
Print[\"  Ja_{1122} = \", Ja1122, \" = \", N[Ja1122]];
Print[\"  Jb_{1122} = \", Jb1122, \" = \", N[Jb1122]];
Print[\"  I_{1122} = \", N[I1122]];

(* I_{1212}: i=1, j=2, k=1, l=2 *)
(* H_{121} = 0 + b0*x2/r^3 - 3*b0*x1^2*x2/r^5 *)
(* Ja part: delta_{12}=0, so Ja_{1212} = 0 *)
Print[\"\\nComputing I_{1212} (= B)...\"];
Jb1212 = computeJb[1, 2, 1, 2];
I1212 = b0 Jb1212;   (* Ja part is zero since delta_{12}=0 *)
Print[\"  Jb_{1212} = \", Jb1212, \" = \", N[Jb1212]];
Print[\"  I_{1212} = \", N[I1212]];

(* I_{1111}: i=1, j=1, k=1, l=1 *)
(* H_{111} = -a0*x1/r^3 + 2*b0*x1/r^3 - 3*b0*x1^3/r^5 *)
Print[\"\\nComputing I_{1111} (= A + 2B + C)...\"];
Ja1111 = computeJa[1, 1];
Jb1111 = computeJb[1, 1, 1, 1];
I1111 = a0 Ja1111 + b0 Jb1111;
Print[\"  Ja_{1111} = \", Ja1111, \" = \", N[Ja1111]];
Print[\"  Jb_{1111} = \", Jb1111, \" = \", N[Jb1111]];
Print[\"  I_{1111} = \", N[I1111]];\
\>", "Input",
 CellChangeTimes->{{3.982198309810165*^9, 3.98219831649897*^9}},
 CellLabel->"In[55]:=",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000004"],

