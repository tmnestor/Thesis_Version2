 InterpretationBox[
  RowBox[{"\<\"\\nGamma0_stat (tet, a=1) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"1.2212973507728048`*^-11", "+", 
    RowBox[{"2.892609213595486`*^-27", " ", "\[ImaginaryI]"}]}]}],
  SequenceForm["\nGamma0_stat (tet, a=1) = ", 
   Complex[1.2212973507728048`*^-11, 2.892609213595486*^-27]],
