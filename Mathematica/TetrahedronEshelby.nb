Cell[CellGroupData[{

Cell["7. Validation & Born Limit", "Section",ExpressionUUID->"a1b2c3d4-0008-0001-0001-000000000001"],

Cell["\<\
Validation checks:
1. Born limit: at weak contrast, amplification factors \[Rule] 1, effective \
contrasts \[Rule] bare contrasts
2. Volume scaling: T \[Proportional] V at fixed shape
3. Frequency limit: at \[Omega] \[Rule] 0, smooth corrections vanish\
\>", "Text",ExpressionUUID->"a1b2c3d4-0008-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === Born limit: weak contrast === *)
Print[\"=== BORN LIMIT VALIDATION ===\"];
\[CapitalDelta]\[Lambda]weak = \[Lambda]/10000;
\[CapitalDelta]\[Mu]weak = \[Mu]/10000;
\[CapitalDelta]\[Rho]weak = \[Rho]/10000;

Module[{dl = \[CapitalDelta]\[Lambda]weak, dm = \[CapitalDelta]\[Mu]weak,
         dr = \[CapitalDelta]\[Rho]weak},
  DcW[j_, k_, l_, p_] := dl KroneckerDelta[j, k] KroneckerDelta[l, p] +
    dm (KroneckerDelta[j, l] KroneckerDelta[k, p] +
         KroneckerDelta[j, p] KroneckerDelta[k, l]);
  TtW[m_, n_, l_, p_] := Sum[
    Stens[m, n, j, k, AtotTet, BtotTet, CtotTet] DcW[j, k, l, p],
    {j, 3}, {k, 3}];
  t1 = TtW[1, 1, 2, 2];
  t2 = TtW[1, 2, 1, 2];
  t3 = TtW[1, 1, 1, 1] - t1 - 2 t2;

  aU = 1/(1 - \[Omega]test^2 dr Gamma0tet);
  aTheta = 1/(1 - 3 t1 - 2 t2 - t3);
  aEoff = 1/(1 - 2 t2);
  aEdiag = 1/(1 - 2 t2 - t3);

  Print[\"Weak contrast amplification factors (should be ~1):\"];
  Print[\"  A_u = \", N[aU], \" (|1-A_u| = \", N[Abs[1 - aU]], \")\"];
  Print[\"  A_\[Theta] = \", N[aTheta], \" (|1-A_\[Theta]| = \", N[Abs[1 - \
aTheta]], \")\"];
  Print[\"  A_e^off = \", N[aEoff], \" (|1-A_e^off| = \", N[Abs[1 - aEoff]], \
\")\"];
  Print[\"  A_e^diag = \", N[aEdiag], \" (|1-A_e^diag| = \", N[Abs[1 - \
aEdiag]], \")\"];
];\
\>", "Input",
 CellLabel->
  "In[297]:=",ExpressionUUID->"a1b2c3d4-0008-0001-0001-000000000003"],

