Cell[CellGroupData[{

Cell["\<\
(* === Static limit: omega -> 0 === *)
Print[\"\\n=== STATIC LIMIT VALIDATION ===\"];
\[Omega]static = 1;  (* very small frequency *)

{phiSt, psiSt} = tetTaylorCoefficients[\[Omega]static, \[Alpha], \[Beta], \
\[Rho], nTaylor];

(* At omega~0, smooth corrections should be negligible *)
AsmSt = 0;
If[nTaylor > 2,
  Do[AsmSt += 4 nn (nn - 1) phiSt[[nn + 1]] s1Tet[[nn - 1]], {nn, 2, nTaylor \
- 1}];
  Do[AsmSt += 4 nn (nn - 1) psiSt[[nn + 1]] s11Tet[[nn - 1]], {nn, 2, nTaylor \
- 1}]
];
If[nTaylor > 1,
  Do[AsmSt += 2 nn phiSt[[nn + 1]] s0Tet[[nn]], {nn, 1, nTaylor - 1}];
  Do[AsmSt += 2 nn psiSt[[nn + 1]] s1Tet[[nn]], {nn, 1, nTaylor - 1}]
];

Print[\"At \[Omega] = \", \[Omega]static, \":\"];
Print[\"  |A_smooth/A_static| = \", N[Abs[AsmSt/Atet]]];
Print[\"  Static A dominates: \", N[Abs[AsmSt/Atet]] < 10^-6];\
\>", "Input",
 CellLabel->
  "In[304]:=",ExpressionUUID->"a1b2c3d4-0008-0001-0001-000000000004"],

