Cell[CellGroupData[{

Cell["\<\
(* === Simplify Ja, Jb using Pell identities === *)
(* Pell: (5-2Sqrt[6])(5+2Sqrt[6]) = 1  =>  Log[5-2Sqrt[6]] = -Log[5+2Sqrt[6]] *)
(* Pell: (5+2Sqrt[6])^3 = 485+198Sqrt[6]  =>  Log[485-198Sqrt[6]] = -3 Log[5+2Sqrt[6]] *)
(* Also: (Sqrt[2]+Sqrt[3])^2 = 5+2Sqrt[6], so L = Log[Sqrt[2]+Sqrt[3]] = (1/2)Log[5+2Sqrt[6]] *)
(* ArcTan identity: ArcTan[2Sqrt[2]-3Sqrt[3]] - ArcTan[2Sqrt[2]-Sqrt[3]] + ArcTan[4Sqrt[2]+3Sqrt[3]] = -Pi/6 *)
(*   (proved via two applications of the addition formula) *)

(* Ja_{kl} = -4Pi/3 * delta_{kl}  -- UNIVERSAL for any convex body containing the origin *)
(* This follows from nabla^2(1/r) = -4Pi delta(r) *)
Ja1122 = -4 Pi/3;
Ja1111 = -4 Pi/3;
Print[\"Simplified Ja_{kl} = -4Pi/3 * delta_{kl} (universal)\"];
Print[\"  Ja_{1122} = Ja_{1111} = \", Ja1111, \" = \", N[Ja1111]];

(* Jb: combine fractions using Pell identities *)
(* Define L = Log[Sqrt[2]+Sqrt[3]] for compact notation *)
L = Log[Sqrt[2] + Sqrt[3]];

Jb1122 = (6 Sqrt[2] L - 4 Pi - 12 Sqrt[3]) / 9;
Jb1212 = (6 Sqrt[2] L + 8 Pi - 12 Sqrt[3]) / 9;
Jb1111 = (-12 Sqrt[2] L - 4 Pi + 24 Sqrt[3]) / 9;

Print[\"\\nSimplified Jb (L = Log[Sqrt[2]+Sqrt[3]]):\"];
Print[\"  Jb_{1122} = (6 Sqrt[2] L - 4 Pi - 12 Sqrt[3]) / 9 = \", N[Jb1122]];
Print[\"  Jb_{1212} = (6 Sqrt[2] L + 8 Pi - 12 Sqrt[3]) / 9 = \", N[Jb1212]];
Print[\"  Jb_{1111} = (-12 Sqrt[2] L - 4 Pi + 24 Sqrt[3]) / 9 = \", N[Jb1111]];

(* Consistency: Jb_{1111} + 2 Jb_{1122} should = -4Pi/3 *)
Print[\"\\nTrace check: Jb_{1111} + 2 Jb_{1122} = \", Simplify[Jb1111 + 2 Jb1122],
  \" (should be -4Pi/3)\"];

(* Rebuild I components from simplified J *)
I1122 = a0 Ja1122 + b0 Jb1122;
I1212 = b0 Jb1212;
I1111 = a0 Ja1111 + b0 Jb1111;\
\>", "Input",
 CellChangeTimes->{{3.9826*^9, 3.9826*^9}},
 ExpressionUUID->"b1c2d3e4-0001-0001-0001-000000000001"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* === Extract A, B, C and build full Voigt matrix === *)
Atet = I1122;
Btet = I1212;
Ctet = I1111 - Atet - 2 Btet;

Print[\"\\n=== Tetrahedron Eshelby decomposition ===\"];
Print[\"  A_tet = \", N[Atet]];
Print[\"  B_tet = \", N[Btet]];
Print[\"  C_tet = \", N[Ctet]];

(* Build full 6x6 Voigt matrix from A, B, C *)
voigtPairs = {{1,1}, {2,2}, {3,3}, {2,3}, {1,3}, {1,2}};
voigtLabels = {\"11\", \"22\", \"33\", \"23\", \"13\", \"12\"};

Ivoigt = Table[
  Module[{i, j, k, l},
    {i, j} = voigtPairs[[m]];
    {k, l} = voigtPairs[[n]];
    Atet KroneckerDelta[i, j] KroneckerDelta[k, l] +
    Btet (KroneckerDelta[i, k] KroneckerDelta[j, l] +
           KroneckerDelta[i, l] KroneckerDelta[j, k]) +
    Ctet Boole[i == j == k == l]
  ],
  {m, 6}, {n, 6}];

Print[\"\\nFull Voigt matrix I_{IJ}:\"];
MatrixForm[N[Ivoigt]]\
\>", "Input",
 CellLabel->"In[91]:=",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000005"],

