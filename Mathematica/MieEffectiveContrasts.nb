Cell[CellGroupData[{

Cell["\<\
(* Verify Eshelby S-tensor components for a sphere *)
nuSym = lam/(2 (lam + mu));
S1111 = (7 - 5 nuSym)/(15 (1 - nuSym));
S1122 = (5 nuSym - 1)/(15 (1 - nuSym));
S1212 = (4 - 5 nuSym)/(15 (1 - nuSym));

Print[\"\\nEshelby S-tensor components:\"];
Print[\"  S_{1111} = \", Simplify[S1111]];
Print[\"  S_{1122} = \", Simplify[S1122]];
Print[\"  S_{1212} = \", Simplify[S1212]];
Print[\"  Check S_{1111} = S_{1122} + 2 S_{1212}: \",
  Simplify[S1111 - S1122 - 2 S1212] === 0];

(* T-matrix coupling from Eshelby A, B *)
AEsym = -(9 - 10 nuSym)/(30 mu (1 - nuSym));
BEsym = 1/(30 mu (1 - nuSym));
{T1sym, T2sym} = computeT1T2[AEsym, BEsym, Dl, Dm];
T1sym = Simplify[T1sym];
T2sym = Simplify[T2sym];

Print[\"\\nT-matrix coupling from Eshelby:\"];
Print[\"  T_1 = \", T1sym];
Print[\"  T_2 = \", T2sym];

(* Amplification factors in terms of \[Nu] *)
ampThetaSym = 1/(1 - 3 T1sym - 2 T2sym) // Simplify;
ampDevSym = 1/(1 - 2 T2sym) // Simplify;
Print[\"\\nAmplification factors (symbolic):\"];
Print[\"  amp_\[Theta] = \", ampThetaSym];
Print[\"  amp_dev   = \", ampDevSym];\
\>", "Input",
 CellLabel->
  "In[174]:=",ExpressionUUID->"7e070471-5e8a-42e8-9c2e-7a527075fd28"],

