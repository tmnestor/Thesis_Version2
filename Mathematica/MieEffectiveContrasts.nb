Cell[CellGroupData[{

Cell["8. Detailed Example (10% Contrast)", "Section",ExpressionUUID->"5365a3fc-338b-4c7c-9865-4c7b3b6ca429"],

Cell["\<\
Full printout for a single contrast level (10%) showing all intermediate \
quantities: Eshelby A, B, coupling coefficients T_1, T_2, amplification \
factors, Mie partial wave coefficients, and the exact match.\
\>", "Text",ExpressionUUID->"c2c65df9-a56b-4eba-bc0d-3740a89b4aee"],

Cell[CellGroupData[{

Cell["\<\
epsDetail = 0.1;
DlDetail = epsDetail lamNum;
DmDetail = epsDetail muNum;
DrDetail = epsDetail rhoNum;
lamInDetail = lamNum + DlDetail;
muInDetail = muNum + DmDetail;
rhoInDetail = rhoNum + DrDetail;
alphaInDetail = Sqrt[(lamInDetail + 2 muInDetail)/rhoInDetail];
betaInDetail = Sqrt[muInDetail/rhoInDetail];

Print[\"\\nContrast (10%):\"];
Print[\"  \[CapitalDelta]\[Lambda] = \", DlDetail/10.^9, \" GPa\"];
Print[\"  \[CapitalDelta]\[Mu]     = \", DmDetail/10.^9, \" GPa\"];
Print[\"  \[CapitalDelta]\[Rho]    = \", DrDetail, \" kg/m\\[ThreeSuperior]\"];

(* Rayleigh side *)
rayDetail = rayleighEffectiveContrasts[omegaNum, aNum,
  alphaNum, betaNum, rhoNum,
  lamNum, muNum, DlDetail, DmDetail, DrDetail];

nuDetail = lamNum/(2 (lamNum + muNum));
Print[\"\\nPoisson ratio \[Nu] = \", nuDetail];
Print[\"A_Eshelby = \", eshelbyA[lamNum, muNum]];
Print[\"B_Eshelby = \", eshelbyB[lamNum, muNum]];
Print[\"\\nT_1 = \", rayDetail[\"amps\"][\"T1\"]];
Print[\"T_2 = \", rayDetail[\"amps\"][\"T2\"]];
Print[\"\\nAmplification factors:\"];
Print[\"  amp_u     = \", N[rayDetail[\"amps\"][\"ampU\"]]];
Print[\"  amp_\[Theta]   = \", N[rayDetail[\"amps\"][\"ampTheta\"]]];
Print[\"  amp_dev   = \", N[rayDetail[\"amps\"][\"ampDev\"]]];
Print[\"\\nRayleigh effective contrasts:\"];
Print[\"  \[CapitalDelta]\[Kappa]* = \", Re[N[rayDetail[\"Dkappa\"]]], \" \
Pa\"];
Print[\"  \[CapitalDelta]\[Lambda]* = \", Re[N[rayDetail[\"Dlambda\"]]], \" \
Pa\"];
Print[\"  \[CapitalDelta]\[Mu]*    = \", Re[N[rayDetail[\"Dmu\"]]], \" Pa\"];
Print[\"  \[CapitalDelta]\[Rho]*   = \", Re[N[rayDetail[\"Drho\"]]], \" \
kg/m\\[ThreeSuperior]\"];\
\>", "Input",
 CellLabel->"In[97]:=",ExpressionUUID->"8d1dba62-6863-4f65-a01d-663cd2316df3"],

