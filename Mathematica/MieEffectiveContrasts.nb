In[1]:=",ExpressionUUID->"aa5176c7-554b-4aa7-9d94-4a370781d5f6"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Check h_0(z) = -i exp(iz)/z: \"\>", "\[InvisibleSpace]", 
   "True"}],
  SequenceForm["Check h_0(z) = -i exp(iz)/z: ", True],
  Editable->False]], "Print",
 CellChangeTimes->{3.981944965578418*^9},
 CellLabel->
  "During evaluation of \
In[1]:=",ExpressionUUID->"a1852d4e-db96-4342-b713-a9d2c740d823"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. P-Wave and S-Wave Radial Field Coefficients", "Section",ExpressionUUID->"5a41576f-7b38-4372-b4d9-e89b81d5663c"],

Cell["\<\
For a potential \[Phi]_n = z_n(kr) P_n(cos \[Theta]), the Helmholtz \
decomposition gives displacement and stress components.

P-WAVE (u = \[Del]\[Phi]):
  u_r = k z_n\[CloseCurlyQuote](kr) P_n
  u_\[Theta] = z_n(kr)/r  dP_n/d\[Theta]
  \[Sigma]_rr = \[Minus](\[Lambda]+2\[Mu])k\\[TwoSuperior] z_n \[Minus] \
4\[Mu] k z_n\[CloseCurlyQuote]/r + 2\[Mu] n(n+1) z_n/r\\[TwoSuperior]
  \[Sigma]_r\[Theta] = 2\[Mu] [k z_n\[CloseCurlyQuote] \[Minus] z_n/r] / r

S-WAVE (u = \[Del]\[Times]\[Del]\[Times](r\[Psi])):
  u_r = n(n+1) z_n(kr)/r P_n
  u_\[Theta] = [z_n + kr z_n\[CloseCurlyQuote]] / r  dP_n/d\[Theta]
  \[Sigma]_rr = 2\[Mu] n(n+1) [k z_n\[CloseCurlyQuote]/r \[Minus] \
z_n/r\\[TwoSuperior]]
  \[Sigma]_r\[Theta] = \[Mu] \
[(2n(n+1)\[Minus]2\[Minus]k\\[TwoSuperior]r\\[TwoSuperior]) z_n \[Minus] 2kr \
z_n\[CloseCurlyQuote]] / r\\[TwoSuperior]\
\>", "Text",ExpressionUUID->"bac0e71a-8526-41e3-a265-dc4929a9b702"],

Cell["\<\
(* P-wave field coefficients: {u_r, u_\[Theta], \[Sigma]_rr, \[Sigma]_r\
\[Theta]} *)
(* zFunc is either jn or hn, zpFunc is jnp or hnp *)
pWaveFields[n_, k_, r_, lam_, mu_, zFunc_, zpFunc_] := Module[
  {z, zv, zp, nn1, ur, ut, srr, srt},
  z = k r;
  zv = zFunc[n, z];
  zp = zpFunc[n, z];
  nn1 = n (n + 1);
  ur = k zp;
  ut = zv/r;
  srr = -(lam + 2 mu) k^2 zv - 4 mu k zp/r + 2 mu nn1 zv/r^2;
  srt = 2 mu (k zp - zv/r)/r;
  {ur, ut, srr, srt}
];

(* S-wave field coefficients *)
sWaveFields[n_, k_, r_, mu_, zFunc_, zpFunc_] := Module[
  {z, zv, zp, nn1, ur, ut, srr, srt},
  z = k r;
  zv = zFunc[n, z];
  zp = zpFunc[n, z];
  nn1 = n (n + 1);
  ur = nn1 zv/r;
  ut = (zv + z zp)/r;
  srr = 2 mu nn1 (k zp/r - zv/r^2);
  srt = mu ((2 nn1 - 2 - z^2) zv - 2 z zp)/r^2;
  {ur, ut, srr, srt}
];\
\>", "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"879e567b-49f4-4469-b7ed-dbdaf365e1e2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Mie Boundary Condition Matrices", "Section",ExpressionUUID->"f73376fb-1699-4f74-9198-2f35b05a6d17"],

Cell["\<\
At r = a, the boundary conditions are:
  u_inc + u_scat = u_int
  \[Sigma]_inc + \[Sigma]_scat = \[Sigma]_int

Rearranged: M [A_n, B_n, C_n, D_n]^T = \[Minus]RHS_inc
where A_n, B_n are scattered (outgoing h_n) P, SV coefficients
and   C_n, D_n are interior (regular j_n) P, SV coefficients.

n=0 monopole: purely P-wave, 2\[Times]2 system (no SV coupling).
n\[GreaterEqual]1 P-SV: 4\[Times]4 system [A_n, B_n, C_n, D_n].
n\[GreaterEqual]1 SH: 2\[Times]2 system (decoupled from P-SV).\
\>", "Text",ExpressionUUID->"aa824867-f2c7-45b7-a189-662c29d7df7c"],

Cell["\<\
(* 4\[Times]4 P-SV boundary matrix for order n \[GreaterEqual] 1 *)
miePSVMatrix[n_, omega_, a_,
  alphaOut_, betaOut_, rhoOut_, lamOut_, muOut_,
  alphaIn_, betaIn_, rhoIn_, lamIn_, muIn_] := Module[
  {kPout, kSout, kPin, kSin, M,
   fPs, fSs, fPi, fSi},

  kPout = omega/alphaOut;
  kSout = omega/betaOut;
  kPin = omega/alphaIn;
  kSin = omega/betaIn;

  (* Scattered P (outgoing h_n, exterior) *)
  fPs = pWaveFields[n, kPout, a, lamOut, muOut, hn, hnp];
  (* Scattered SV (outgoing h_n, exterior) *)
  fSs = sWaveFields[n, kSout, a, muOut, hn, hnp];
  (* Interior P (regular j_n) *)
  fPi = pWaveFields[n, kPin, a, lamIn, muIn, jn, jnp];
  (* Interior SV (regular j_n) *)
  fSi = sWaveFields[n, kSin, a, muIn, jn, jnp];

  (* Rows: u_r, u_\[Theta], \[Sigma]_rr, \[Sigma]_r\[Theta] *)
  (* Columns: A_n(scat P), B_n(scat S), -C_n(int P), -D_n(int S) *)
  M = {
    {fPs[[1]], fSs[[1]], -fPi[[1]], -fSi[[1]]},
    {fPs[[2]], fSs[[2]], -fPi[[2]], -fSi[[2]]},
    {fPs[[3]], fSs[[3]], -fPi[[3]], -fSi[[3]]},
    {fPs[[4]], fSs[[4]], -fPi[[4]], -fSi[[4]]}
  };
  M
];

(* Incident P-wave RHS for 4\[Times]4 P-SV system *)
mieIncidentPSV[n_, omega_, a_, alpha_, beta_, rho_, lam_, mu_] := Module[
  {kP, coeff, fPinc, rhs},
  kP = omega/alpha;
  (* Partial wave coefficient: (2n+1) i^n / (i kP) *)
  coeff = (2 n + 1) I^n / (I kP);
  fPinc = pWaveFields[n, kP, a, lam, mu, jn, jnp];
  rhs = -coeff {fPinc[[1]], fPinc[[2]], fPinc[[3]], fPinc[[4]]};
  rhs
];

(* 2\[Times]2 SH boundary matrix for order n \[GreaterEqual] 1 *)
mieSHMatrix[n_, omega_, a_, betaOut_, muOut_, betaIn_, muIn_] := Module[
  {kSout, kSin, zOut, zIn},
  kSout = omega/betaOut;
  kSin = omega/betaIn;
  zOut = kSout a;
  zIn = kSin a;

  (* Row 1: u_\[Phi] continuity *)
  (* Row 2: \[Sigma]_r\[Phi] continuity *)
  {
    {hn[n, zOut], -jn[n, zIn]},
    {muOut kSout hnp[n, zOut], -muIn kSin jnp[n, zIn]}
  }
];\
\>", "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"1d26fdc7-9cff-4ad0-81f6-69c188e93a22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["4. Compute Mie Coefficients", "Section",ExpressionUUID->"226af4b0-ddf0-4177-ab07-c8e042ebc8d3"],

Cell["\<\
Solve the boundary condition systems for each angular order n = 0, 1, 2, \
\[Ellipsis], n_max.

Sign convention: the standard partial wave expansion
  exp(ikz) = \[CapitalSigma] (2n+1) i^n j_n(kr) P_n(cos \[Theta])
uses a polar axis that produces backward-peaked scattering.
We multiply by (\[Minus]1)^n to correct the angular pattern for
forward-peaked scattering consistent with the Rayleigh T-matrix.\
\>", "Text",ExpressionUUID->"d2b4124d-b6db-4d6d-9eb9-fe298e66a1c3"],

Cell["\<\
computeMieCoefficients[omega_, a_,
  alphaOut_, betaOut_, rhoOut_, lamOut_, muOut_,
  alphaIn_, betaIn_, rhoIn_, lamIn_, muIn_,
  nMax_] := Module[
  {kPout, kPin, kSout, kSin,
   anArr, bnArr, cnArr,
   M0, rhs0, sol0, coeff0,
   urS0, srrS0, urI0, srrI0, urInc0, srrInc0,
   Mpsv, rhsPsv, solPsv,
   Msh, rhsSH, solSH,
   coeffSH, zInc, sign, n, dummy},

  kPout = omega/alphaOut;
  kSout = omega/betaOut;
  kPin = omega/alphaIn;
  kSin = omega/betaIn;

  (* Initialize coefficient arrays *)
  anArr = ConstantArray[0. + 0. I, nMax + 1];
  bnArr = ConstantArray[0. + 0. I, nMax + 1];
  cnArr = ConstantArray[0. + 0. I, nMax + 1];

  (* n=0 monopole: 2\[Times]2 P-wave only *)
  {urS0, dummy, srrS0, dummy} = pWaveFields[0, kPout, a, lamOut, muOut, hn, \
hnp];
  {urI0, dummy, srrI0, dummy} = pWaveFields[0, kPin, a, lamIn, muIn, jn, \
jnp];
  {urInc0, dummy, srrInc0, dummy} = pWaveFields[0, kPout, a, lamOut, muOut, \
jn, jnp];
  coeff0 = 1/(I kPout);
  M0 = {{urS0, -urI0}, {srrS0, -srrI0}};
  rhs0 = {-coeff0 urInc0, -coeff0 srrInc0};
  sol0 = LinearSolve[N[M0], N[rhs0]];
  anArr[[1]] = sol0[[1]];

  (* n \[GreaterEqual] 1: P-SV 4\[Times]4 + SH 2\[Times]2 *)
  Do[
    sign = (-1.)^n;

    (* P-SV system *)
    Mpsv = N[miePSVMatrix[n, omega, a,
      alphaOut, betaOut, rhoOut, lamOut, muOut,
      alphaIn, betaIn, rhoIn, lamIn, muIn]];
    rhsPsv = N[mieIncidentPSV[n, omega, a, alphaOut, betaOut, rhoOut,
      lamOut, muOut]];
    solPsv = LinearSolve[Mpsv, rhsPsv];
    anArr[[n + 1]] = sign solPsv[[1]];
    bnArr[[n + 1]] = sign solPsv[[2]];

    (* SH system *)
    Msh = N[mieSHMatrix[n, omega, a, betaOut, muOut, betaIn, muIn]];
    zInc = kSout a;
    coeffSH = (2 n + 1) I^n / (I kSout);
    rhsSH = {
      -coeffSH jn[n, zInc],
      -coeffSH muOut kSout jnp[n, zInc]
    };
    solSH = LinearSolve[N[Msh], N[rhsSH]];
    cnArr[[n + 1]] = sign solSH[[1]],

    {n, 1, nMax}
  ];

  <|\"a\" -> anArr, \"b\" -> bnArr, \"c\" -> cnArr, \"nMax\" -> nMax|>
];\
\>", "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"81e2c77b-31db-477b-a43a-9eb9cc9775a9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5. Legendre Projection \[Dash] Effective Contrast Extraction", "Section",ExpressionUUID->"60bf70ae-12f0-4c1d-8c3b-c022fc366f5a"],

Cell["\<\
The Mie P-wave far-field amplitude decomposes as:
  f_P(\[Theta]) = \[CapitalSigma]_n a_n (\[Minus]i)^n P_n(cos \[Theta])

The Rayleigh scattering formula (Shekhar et al. 2023) gives:
  f_P(\[Theta]) = \[Minus]C_P { k\\[TwoSuperior] \[CapitalDelta]\[Kappa]* P_0 \
+ \[Omega]\\[TwoSuperior] \[CapitalDelta]\[Rho]* P_1 + (4k\\[TwoSuperior]\
\[CapitalDelta]\[Mu]*/3) P_2 }

where C_P = V/(4\[Pi]\[Rho]\[Alpha]\\[TwoSuperior]) and V = \
(4/3)\[Pi]a\\[ThreeSuperior].

Matching coefficients of P_n for n = 0, 1, 2:
  n=0 (monopole):    a_0 = \[Minus]C_P k\\[TwoSuperior] \[CapitalDelta]\
\[Kappa]*
  n=1 (dipole):     \[Minus]i a_1 = \[Minus]C_P \[Omega]\\[TwoSuperior] \
\[CapitalDelta]\[Rho]*
  n=2 (quadrupole): \[Minus]a_2 = \[Minus]C_P (4k\\[TwoSuperior]\
\[CapitalDelta]\[Mu]*/3)

Solving:
  \[CapitalDelta]\[Kappa]* = \[Minus]a_0 / (C_P k\\[TwoSuperior])
  \[CapitalDelta]\[Rho]* = i a_1 / (C_P \[Omega]\\[TwoSuperior])
  \[CapitalDelta]\[Mu]* = 3 a_2 / (4 C_P k\\[TwoSuperior])
  \[CapitalDelta]\[Lambda]* = \[CapitalDelta]\[Kappa]* \[Minus] (2/3) \
\[CapitalDelta]\[Mu]*

The S-wave dipole coefficient b_1 gives an independent density:
  \[CapitalDelta]\[Rho]*_S = i b_1 / (C_S \[Omega]\\[TwoSuperior])\
\>", "Text",ExpressionUUID->"9edc1ce0-9ac4-4ca1-acf4-f74184790a39"],

Cell["\<\
extractEffectiveContrasts[mieCoeffs_, omega_, a_, alpha_, beta_, rho_] := \
Module[
  {V, kP, CP, CS, an, bn,
   Dkappa, Drho, Dmu, Dlambda, DrhoS},

  V = (4./3.) Pi a^3;
  kP = omega/alpha;
  CP = V/(4 Pi rho alpha^2);
  CS = V/(4 Pi rho beta^2);

  an = mieCoeffs[\"a\"];
  bn = mieCoeffs[\"b\"];

  (* Direct Legendre projection from partial wave coefficients *)
  Dkappa = -an[[1]]/(CP kP^2);          (* n=0: monopole \[Rule] bulk modulus \
*)
  Drho = I an[[2]]/(CP omega^2);        (* n=1: dipole \[Rule] density *)
  Dmu = 3 an[[3]]/(4 CP kP^2);          (* n=2: quadrupole \[Rule] shear \
modulus *)
  Dlambda = Dkappa - 2 Dmu/3;

  (* Independent density from S-wave dipole *)
  DrhoS = I bn[[2]]/(CS omega^2);

  <|
    \"Dkappa\" -> Dkappa,
    \"Dlambda\" -> Dlambda,
    \"Dmu\" -> Dmu,
    \"Drho\" -> Drho,
    \"DrhoS\" -> DrhoS
  |>
];\
\>", "Input",
 CellLabel->"In[28]:=",ExpressionUUID->"b079c9e0-631f-480f-be09-2d7d9507c221"]
}, Open  ]],

Cell[CellGroupData[{

Cell["6. Eshelby-Corrected Rayleigh T-Matrix", "Section",ExpressionUUID->"d8fa3bec-9ffa-4b76-80c0-b2663558c2f6"],

Cell["\<\
The volume integral of the Green\[CloseCurlyQuote]s tensor second derivative \
over a sphere has a distributional \[Delta]-function contribution from the \
1/r singularity that numerical quadrature misses.

For an isotropic sphere in an isotropic matrix (Eshelby 1957):
  A_E = \[Minus](9 \[Minus] 10\[Nu]) / (30\[Mu](1 \[Minus] \[Nu]))
  B_E = 1 / (30\[Mu](1 \[Minus] \[Nu]))
where \[Nu] = \[Lambda]/(2(\[Lambda]+\[Mu])) is the Poisson ratio.

These are EXACT at all contrast levels. The self-consistent amplification \
factors match the exact Mie solution in the ka \[Rule] 0 limit for ANY \
magnitude of material contrast.\
\>", "Text",ExpressionUUID->"d2888643-9a2c-460e-a775-1fcd95075c05"],

Cell[CellGroupData[{

Cell["\<\
(* Radial functions of the Green's tensor *)
cNF[alpha_, beta_, rho_] := (1 - beta^2/alpha^2)/(8 Pi rho beta^2);
fRad[r_, omega_, alpha_, beta_, rho_] :=
  -cNF[alpha, beta, rho]/r + Exp[I omega r/beta]/(4 Pi rho beta^2 r);
gRad[r_, omega_, alpha_, beta_, rho_] :=
  3 cNF[alpha, beta, rho]/r + Exp[I omega r/alpha]/(4 Pi rho alpha^2 r) -
  Exp[I omega r/beta]/(4 Pi rho beta^2 r);

(* \[CapitalGamma]_0: volume integral of Green's tensor *)
gamma0Integrand[r_, omega_, alpha_, beta_, rho_] :=
  r^2 (4 Pi fRad[r, omega, alpha, beta, rho] +
       (4 Pi/3) gRad[r, omega, alpha, beta, rho]);

gamma0Exact[omega_, a_, alpha_, beta_, rho_] :=
  Integrate[gamma0Integrand[r, omega, alpha, beta, rho],
    {r, 0, a},
    Assumptions -> {a > 0, omega > 0, alpha > 0, beta > 0, rho > 0,
      alpha > beta}] // FullSimplify;

(* Pre-compute symbolic \[CapitalGamma]_0 *)
Print[\"Computing symbolic \[CapitalGamma]_0...\"];
gamma0Sym = gamma0Exact[\[Omega], aa, \[Alpha], \[Beta], \[Rho]];
Print[\"\[CapitalGamma]_0 = \", gamma0Sym];\
\>", "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"a85fd65e-a50e-47f3-a8f0-f0d51eb05a0c"],

Cell[CellGroupData[{

Cell[BoxData["\<\"Computing symbolic \[CapitalGamma]_0...\"\>"], "Print",
 CellChangeTimes->{3.981944965827993*^9},
 CellLabel->
  "During evaluation of \
In[29]:=",ExpressionUUID->"692bfbb8-0f2e-4cc0-a13c-9f261cec6292"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\[CapitalGamma]_0 = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "3"}], "+", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "aa", " ", "\[Omega]"}], "\[Alpha]"]], 
       " ", 
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "-", 
         RowBox[{"\[ImaginaryI]", " ", "aa", " ", "\[Omega]"}]}], ")"}]}], 
      "\[Alpha]"], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "aa", " ", "\[Omega]"}], "\[Beta]"]], " ", 
      RowBox[{"(", 
       RowBox[{"2", "-", 
        FractionBox[
         RowBox[{"2", " ", "\[ImaginaryI]", " ", "aa", " ", "\[Omega]"}], 
         "\[Beta]"]}], ")"}]}]}], 
    RowBox[{"3", " ", "\[Rho]", " ", 
     SuperscriptBox["\[Omega]", "2"]}]]}],
  SequenceForm[
  "\[CapitalGamma]_0 = ", 
   Rational[1, 3] $CellContext`\[Rho]^(-1) $CellContext`\[Omega]^(-2) (-3 + 
    E^(Complex[
        0, 1] $CellContext`aa $CellContext`\[Alpha]^(-1) \
$CellContext`\[Omega]) $CellContext`\[Alpha]^(-1) ($CellContext`\[Alpha] + 
      Complex[0, -1] $CellContext`aa $CellContext`\[Omega]) + 
    E^(Complex[
        0, 1] $CellContext`aa $CellContext`\[Beta]^(-1) \
$CellContext`\[Omega]) (2 + 
      Complex[0, -2] $CellContext`aa $CellContext`\[Beta]^(-1) $CellContext`\
\[Omega]))],
  Editable->False]], "Print",
 CellChangeTimes->{3.981944967538911*^9},
 CellLabel->
  "During evaluation of \
In[29]:=",ExpressionUUID->"0d319113-703c-4f78-b8a2-f2f69e4ced76"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* Eshelby A, B coefficients for a sphere *)
eshelbyA[lam_, mu_] := Module[{nu},
  nu = lam/(2 (lam + mu));
  -(9 - 10 nu)/(30 mu (1 - nu))
];

eshelbyB[lam_, mu_] := Module[{nu},
  nu = lam/(2 (lam + mu));
  1/(30 mu (1 - nu))
];

Print[\"Eshelby result for sphere:\"];
Print[\"  A_E = -(9 - 10\[Nu])/(30\[Mu](1-\[Nu]))\"];
Print[\"  B_E = 1/(30\[Mu](1-\[Nu]))\"];
Print[\"  where \[Nu] = \[Lambda]/(2(\[Lambda]+\[Mu]))\"];\
\>", "Input",
 CellLabel->"In[43]:=",ExpressionUUID->"dfcf4a69-b19d-4dc7-bf54-71182527a0eb"],

Cell[CellGroupData[{

Cell[BoxData["\<\"Eshelby result for sphere:\"\>"], "Print",
 CellChangeTimes->{3.981944967639669*^9},
 CellLabel->
  "During evaluation of \
In[43]:=",ExpressionUUID->"131da315-e6fe-4b19-bbad-91204ce8eb7c"],

Cell[BoxData["\<\"  A_E = -(9 - 10\[Nu])/(30\[Mu](1-\[Nu]))\"\>"], "Print",
 CellChangeTimes->{3.981944967640164*^9},
 CellLabel->
  "During evaluation of \
In[43]:=",ExpressionUUID->"57734e69-5659-4fc6-90c9-ffacb24794ce"],

Cell[BoxData["\<\"  B_E = 1/(30\[Mu](1-\[Nu]))\"\>"], "Print",
 CellChangeTimes->{3.981944967640815*^9},
