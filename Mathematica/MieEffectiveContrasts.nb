      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", " ", "lam"}], "+", 
        RowBox[{"8", " ", "mu"}]}], ")"}]}]}]]}],
  SequenceForm[
  "  amp_\[Theta] = ", 
   15 $CellContext`mu ($CellContext`lam + 2 $CellContext`mu)/(
