Cell["\<\
(* T-matrix coupling coefficients *)
(* T1 = T_{1122}, T2 = T_{1212} *)
computeT1T2[Av_, Bv_, Dl_, Dm_] := Module[{T1, T2},
  T1 = Dl (Av + 3 Bv) + 2 Dm (Av + Bv);
  T2 = Dm (Av + Bv);
  {T1, T2}
];

(* Amplification factors *)
computeAmplificationFactors[omega_, a_, alpha_, beta_, rho_,
  lam_, mu_, Dl_, Dm_, Drho_] := Module[
  {G0, Av, Bv, T1, T2, ampU, ampTheta, ampDev},

  G0 = gamma0Sym /. {
    \[Omega] -> omega, aa -> a, \[Alpha] -> alpha, \[Beta] -> beta, \[Rho] -> \
rho
  };
  Av = eshelbyA[lam, mu];
  Bv = eshelbyB[lam, mu];
  {T1, T2} = computeT1T2[Av, Bv, Dl, Dm];

  ampU = 1/(1 - omega^2 Drho G0);
  ampTheta = 1/(1 - 3 T1 - 2 T2);
  ampDev = 1/(1 - 2 T2);

  <|
    \"Gamma0\" -> G0,
    \"A\" -> Av, \"B\" -> Bv,
    \"T1\" -> T1, \"T2\" -> T2,
    \"ampU\" -> ampU, \"ampTheta\" -> ampTheta, \"ampDev\" -> ampDev
  |>
];

(* Effective contrasts from Rayleigh T-matrix *)
rayleighEffectiveContrasts[omega_, a_, alpha_, beta_, rho_,
  lam_, mu_, Dl_, Dm_, Drho_] := Module[
  {amps, Dlstar, Dmstar, Drhostar, Dkappastar},

  amps = computeAmplificationFactors[omega, a, alpha, beta, rho,
    lam, mu, Dl, Dm, Drho];

  Drhostar = Drho amps[\"ampU\"];
  Dmstar = Dm amps[\"ampDev\"];
  Dlstar = (Dl + 2 Dm/3) amps[\"ampTheta\"] - Dm/3 (amps[\"ampDev\"] + \
amps[\"ampDev\"]);
  Dkappastar = Dlstar + 2 Dmstar/3;

  <|
    \"Dlambda\" -> Dlstar,
    \"Dmu\" -> Dmstar,
    \"Dkappa\" -> Dkappastar,
    \"Drho\" -> Drhostar,
    \"amps\" -> amps
  |>
];\
\>", "Input",
 CellLabel->"In[52]:=",ExpressionUUID->"e9df52e9-f4f9-4fde-be28-4fa3ca5e08b6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["7. Numerical Comparison at Multiple Contrasts", "Section",ExpressionUUID->"31766b16-3abe-4a18-a077-7babfff7826f"],

Cell["\<\
We demonstrate that the Mie-extracted effective contrasts match the \
Eshelby-corrected Rayleigh T-matrix EXACTLY (to within numerical precision) \
at ALL contrast levels, from weak (Born limit, 0.01%) to strong (50%).

This validates that:
  1. The Eshelby \[Delta]-function correction is exact (not approximate)
  2. The Legendre projection extraction is exact at each order
  3. The self-consistent amplification is physically correct\
\>", "Text",ExpressionUUID->"e0b5f441-54b1-408a-8db6-ac966bd6e18d"],

Cell[CellGroupData[{

Cell["\<\
(* Background medium *)
alphaNum = 5000.;
betaNum = 3000.;
rhoNum = 2500.;
lamNum = rhoNum (alphaNum^2 - 2 betaNum^2);
muNum = rhoNum betaNum^2;

Print[\"Background medium:\"];
Print[\"  \[Alpha] = \", alphaNum, \" m/s\"];
Print[\"  \[Beta]  = \", betaNum, \" m/s\"];
Print[\"  \[Rho]   = \", rhoNum, \" kg/m\\[ThreeSuperior]\"];
Print[\"  \[Lambda] = \", lamNum/10.^9, \" GPa\"];
Print[\"  \[Mu]     = \", muNum/10.^9, \" GPa\"];

(* Sphere parameters: deep Rayleigh regime *)
fNum = 10.;
omegaNum = 2 Pi fNum;
aNum = 1.;
kPa = omegaNum aNum / alphaNum;
kSa = omegaNum aNum / betaNum;

Print[\"\\nSphere:\"];
Print[\"  a = \", aNum, \" m,  f = \", fNum, \" Hz\"];
Print[\"  k_P a = \", kPa, \",  k_S a = \", kSa, \"  (deep Rayleigh)\"];

nMaxNum = Max[2, Ceiling[kSa + 4 kSa^(1./3.) + 2]];
Print[\"  n_max = \", nMaxNum];\
\>", "Input",
 CellLabel->"In[61]:=",ExpressionUUID->"a34d3dbb-7bf8-4f41-8e2c-644bfb62fc41"],

