Cell[CellGroupData[{

Cell["\<\
(* Contrast sweep: Mie vs Eshelby-corrected Rayleigh *)
contrastFractions = {0.0001, 0.001, 0.01, 0.05, 0.1, 0.2, 0.3, 0.5};

results = Table[
  Module[
    {DlNum, DmNum, DrNum, lamIn, muIn, rhoIn, alphaIn, betaIn,
     mieCoeffs, mieEC, rayEC, ratioKappa, ratioRho, ratioMu, ratioRhoS},

    DlNum = eps lamNum;
    DmNum = eps muNum;
    DrNum = eps rhoNum;
    lamIn = lamNum + DlNum;
    muIn = muNum + DmNum;
    rhoIn = rhoNum + DrNum;
    alphaIn = Sqrt[(lamIn + 2 muIn)/rhoIn];
    betaIn = Sqrt[muIn/rhoIn];

    mieCoeffs = computeMieCoefficients[omegaNum, aNum,
      alphaNum, betaNum, rhoNum, lamNum, muNum,
      alphaIn, betaIn, rhoIn, lamIn, muIn, nMaxNum];
    mieEC = extractEffectiveContrasts[mieCoeffs, omegaNum, aNum,
      alphaNum, betaNum, rhoNum];
    rayEC = rayleighEffectiveContrasts[omegaNum, aNum,
      alphaNum, betaNum, rhoNum, lamNum, muNum, DlNum, DmNum, DrNum];

    ratioKappa = Re[mieEC[\"Dkappa\"]]/Re[N[rayEC[\"Dkappa\"]]];
    ratioRho = Re[mieEC[\"Drho\"]]/Re[N[rayEC[\"Drho\"]]];
    ratioMu = Re[mieEC[\"Dmu\"]]/Re[N[rayEC[\"Dmu\"]]];
    ratioRhoS = Re[mieEC[\"DrhoS\"]]/Re[N[rayEC[\"Drho\"]]];

    {eps, ratioKappa, ratioRho, ratioMu, ratioRhoS}
  ],
  {eps, contrastFractions}
];

(* Display results *)
Print[\"\\n--- Mie / Rayleigh Effective Contrast Ratios ---\"];
Print[\"(All should be 1.000000 at deep Rayleigh)\\n\"];
Print[PaddedForm[
  TableForm[results,
    TableHeadings -> {None,
      {\"\[Epsilon]\", \"\[CapitalDelta]\[Kappa]* ratio\", \"\[CapitalDelta]\
\[Rho]* ratio\",
       \"\[CapitalDelta]\[Mu]* ratio\", \"\[CapitalDelta]\[Rho]*_S \
ratio\"}}],
  {12, 8}
]];\
\>", "Input",
 CellLabel->"In[88]:=",ExpressionUUID->"2eba9ada-e3d6-4813-b975-a35191839a4b"],

