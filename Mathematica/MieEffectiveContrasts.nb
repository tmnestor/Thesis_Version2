Cell[CellGroupData[{

Cell["10. Frequency Dependence at Finite ka", "Section",ExpressionUUID->"47d53a15-23a3-4e65-a0cc-7d59e2157233"],

Cell["\<\
At larger ka, the Mie coefficients contain dynamic corrections beyond the \
Rayleigh (ka\\[ThreeSuperior]) order.  We compare Mie-extracted contrasts \
with Rayleigh for increasing ka to show the expected growing discrepancy at \
higher frequencies.\
\>", "Text",ExpressionUUID->"c3988e8f-a3e1-45ac-bf73-3d459feb4f2e"],

Cell[CellGroupData[{

Cell["\<\
epsFixed = 0.1;
DlFixed = epsFixed lamNum;
DmFixed = epsFixed muNum;
DrFixed = epsFixed rhoNum;
lamInFixed = lamNum + DlFixed;
muInFixed = muNum + DmFixed;
rhoInFixed = rhoNum + DrFixed;
alphaInFixed = Sqrt[(lamInFixed + 2 muInFixed)/rhoInFixed];
betaInFixed = Sqrt[muInFixed/rhoInFixed];

kaValues = {0.001, 0.01, 0.05, 0.1, 0.2, 0.5, 1.0, 2.0};

freqResults = Table[
  Module[{omegaVar, nMaxVar, mieVar, mieECVar, rayECVar,
    rKappa, rRho, rMu},

    omegaVar = kaS betaNum / aNum;
    nMaxVar = Max[2, Ceiling[kaS + 4 kaS^(1./3.) + 2]];

    mieVar = computeMieCoefficients[omegaVar, aNum,
      alphaNum, betaNum, rhoNum, lamNum, muNum,
      alphaInFixed, betaInFixed, rhoInFixed, lamInFixed, muInFixed,
      nMaxVar];
    mieECVar = extractEffectiveContrasts[mieVar, omegaVar, aNum,
      alphaNum, betaNum, rhoNum];
    rayECVar = rayleighEffectiveContrasts[omegaVar, aNum,
      alphaNum, betaNum, rhoNum,
      lamNum, muNum, DlFixed, DmFixed, DrFixed];

    rKappa = Re[mieECVar[\"Dkappa\"]]/Re[N[rayECVar[\"Dkappa\"]]];
    rRho = Re[mieECVar[\"Drho\"]]/Re[N[rayECVar[\"Drho\"]]];
    rMu = Re[mieECVar[\"Dmu\"]]/Re[N[rayECVar[\"Dmu\"]]];

    {kaS, rKappa, rRho, rMu}
  ],
  {kaS, kaValues}
];

Print[\"\\n--- Frequency Dependence (10% contrast) ---\"];
Print[\"(Ratios deviate from 1.0 as ka increases)\\n\"];
Print[PaddedForm[
  TableForm[freqResults,
    TableHeadings -> {None,
      {\"k_S a\", \"\[CapitalDelta]\[Kappa]* ratio\",
       \"\[CapitalDelta]\[Rho]* ratio\", \"\[CapitalDelta]\[Mu]* ratio\"}}],
  {12, 8}
]];\
\>", "Input",
 CellLabel->
  "In[203]:=",ExpressionUUID->"ede7598e-5fa2-453c-81f2-2e52513b1707"],

