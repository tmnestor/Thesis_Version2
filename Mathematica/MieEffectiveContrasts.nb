Cell[CellGroupData[{

Cell["\<\
(* Mie side *)
mieDetail = computeMieCoefficients[omegaNum, aNum,
  alphaNum, betaNum, rhoNum, lamNum, muNum,
  alphaInDetail, betaInDetail, rhoInDetail, lamInDetail, muInDetail,
  nMaxNum];

Print[\"\\nMie partial wave coefficients:\"];
Print[\"  a_0 (monopole)   = \", mieDetail[\"a\"][[1]]];
Print[\"  a_1 (dipole)     = \", mieDetail[\"a\"][[2]]];
Print[\"  a_2 (quadrupole) = \", mieDetail[\"a\"][[3]]];
Print[\"  b_1 (SV dipole)  = \", mieDetail[\"b\"][[2]]];

mieECDetail = extractEffectiveContrasts[mieDetail, omegaNum, aNum,
  alphaNum, betaNum, rhoNum];

Print[\"\\nMie-extracted effective contrasts:\"];
Print[\"  \[CapitalDelta]\[Kappa]* = \", Re[mieECDetail[\"Dkappa\"]], \" Pa\"];
Print[\"  \[CapitalDelta]\[Lambda]* = \", Re[mieECDetail[\"Dlambda\"]], \" Pa\
\"];
Print[\"  \[CapitalDelta]\[Mu]*    = \", Re[mieECDetail[\"Dmu\"]], \" Pa\"];
Print[\"  \[CapitalDelta]\[Rho]*   = \", Re[mieECDetail[\"Drho\"]], \" \
kg/m\\[ThreeSuperior]\"];

Print[\"\\nRatios (Mie / Rayleigh):\"];
Print[\"  \[CapitalDelta]\[Kappa]: \", \
Re[mieECDetail[\"Dkappa\"]]/Re[N[rayDetail[\"Dkappa\"]]]];
Print[\"  \[CapitalDelta]\[Lambda]: \", \
Re[mieECDetail[\"Dlambda\"]]/Re[N[rayDetail[\"Dlambda\"]]]];
Print[\"  \[CapitalDelta]\[Mu]:    \", \
Re[mieECDetail[\"Dmu\"]]/Re[N[rayDetail[\"Dmu\"]]]];
Print[\"  \[CapitalDelta]\[Rho]:   \", \
Re[mieECDetail[\"Drho\"]]/Re[N[rayDetail[\"Drho\"]]]];\
\>", "Input",
 CellLabel->
  "In[130]:=",ExpressionUUID->"c1d54899-1b0a-4c7e-afe9-d9182cd3f1bd"],

