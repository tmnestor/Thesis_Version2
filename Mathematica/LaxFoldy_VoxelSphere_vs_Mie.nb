            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"relErr", " ", "=", " ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"fwd", " ", "-", " ", "mieForward"}], "]"}], "/", 
