                    RowBox[{"idxJ", " ", "+", " ", "ii"}], ",", " ", 
                    RowBox[{"idxK", " ", "+", " ", "jj"}]}], "]"}], "]"}], 
                    " ", "=", " ", 
                    RowBox[{"block", "[", 
                    RowBox[{"[", 
                    RowBox[{"ii", ",", " ", "jj"}], "]"}], "]"}]}], ",", "\n",
                    "        ", 
                   RowBox[{"{", 
                    RowBox[{"jj", ",", " ", "9"}], "}"}]}], "]"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{"ii", ",", " ", "9"}], "}"}]}], "]"}], ";"}]}], 
             "\n", "    ", "]"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"j", ",", " ", "nC"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"k", ",", " ", "nC"}], "}"}]}], "]"}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"excF", " ", "=", " ", 
         RowBox[{"LinearSolve", "[", 
          RowBox[{"sysMat", ",", " ", "rhsVec"}], "]"}]}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"Forward", " ", "far", "-", 
          RowBox[{"field", " ", "amplitude", " ", 
           RowBox[{"(", "asymptotic", ")"}]}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"kPv", " ", "=", " ", 
         RowBox[{"omega", "/", "alphaBg"}]}], ";", "\n", "  ", 
        RowBox[{"srcList", " ", "=", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"tMat", " ", ".", " ", 
            RowBox[{"excF", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{
                RowBox[{"9", " ", 
                 RowBox[{"(", 
                  RowBox[{"kk", " ", "-", " ", "1"}], ")"}]}], " ", "+", " ", 
                "1"}], " ", ";;", " ", 
               RowBox[{"9", " ", "kk"}]}], "]"}], "]"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"kk", ",", " ", "nC"}], "}"}]}], "]"}]}], ";", "\n", "\n",
         "  ", 
        RowBox[{"{", 
         RowBox[{"nC", ",", " ", 
          RowBox[{"cubeFarFieldP", "[", 
           RowBox[{
           "0.", ",", " ", "kPv", ",", " ", "alphaBg", ",", " ", "rhoBg", ",",
             "\n", "    ", "centres", ",", " ", "srcList", ",", " ", 
            "voigtPairs", ",", " ", "voigtWeight"}], "]"}]}], "}"}]}]}], "\n",
       "]"}]}], ";", "\n", "\n", 
    RowBox[{"(*", " ", 
     RowBox[{"Reference", ":", " ", 
      RowBox[{"Mie", " ", "forward", " ", "amplitude"}]}], " ", "*)"}], "\n", 
    
    RowBox[{"mieForward", " ", "=", " ", 
     RowBox[{"mieFarFieldP", "[", 
      RowBox[{"0.", ",", " ", "mie"}], "]"}]}], ";", "\n", "\n", 
    RowBox[{
    "Print", "[", "\"\<\\n--- Convergence Study: Forward Scattering ---\>\"", 
     "]"}], ";", "\n", 
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Mie reference |f(0)| = \>\"", ",", " ", 
      RowBox[{"Abs", "[", "mieForward", "]"}]}], "]"}], ";", "\n", "\n", 
    RowBox[{"(*", " ", 
     RowBox[{"Run", " ", "for", " ", "several", " ", "resolutions"}], " ", 
     "*)"}], "\n", 
    RowBox[{"nPerDiamList", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "5", ",", " ", "7"}], "}"}]}], ";", "\n", 
    RowBox[{"convergenceData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "result", ",", " ", "nC", ",", " ", "fwd", ",", " ", "relErr"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<  nPerDiam = \>\"", ",", " ", "np", ",", 
            " ", "\"\<...\>\""}], "]"}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"laxFoldyForwardAmplitude", "[", "np", "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"nC", " ", "=", " ", 
           RowBox[{"result", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"fwd", " ", "=", " ", 
           RowBox[{"result", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"relErr", " ", "=", " ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"fwd", " ", "-", " ", "mieForward"}], "]"}], "/", 
            RowBox[{"Abs", "[", "mieForward", "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<    N_cubes = \>\"", ",", " ", "nC", ",", 
            " ", "\"\<, |f_LF(0)| = \>\"", ",", " ", 
            RowBox[{"Abs", "[", "fwd", "]"}], ",", "\n", 
            "      ", "\"\<, rel error = \>\"", ",", " ", "relErr"}], "]"}], ";",
           "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"np", ",", " ", "nC", ",", " ", 
            RowBox[{"Abs", "[", "fwd", "]"}], ",", " ", "relErr"}], "}"}]}]}],
         "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"np", ",", " ", "nPerDiamList"}], "}"}]}], "\n", "]"}]}], ";",
     "\n", "\n", 
    RowBox[{"Print", "[", "\"\<\\n--- Summary ---\>\"", "]"}], ";", "\n", 
    RowBox[{"Print", "[", 
     RowBox[{"PaddedForm", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"TableForm", "[", 
        RowBox[{"convergenceData", ",", "\n", "    ", 
         RowBox[{"TableHeadings", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"None", ",", "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<n/diam\>\"", ",", " ", "\"\<N_cubes\>\"", ",", 
              " ", "\"\<|f_LF(0)|\>\"", ",", " ", "\"\<Rel Error\>\""}], 
             "}"}]}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"10", ",", " ", "6"}], "}"}]}], "\n", "]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "*)"}], "\n"}]], "Input",
