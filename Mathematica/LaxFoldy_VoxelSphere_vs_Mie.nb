          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<    N_cubes = \>\"", ",", " ", "nC", ",", 
            " ", "\"\<, |f_LF(0)| = \>\"", ",", " ", 
            RowBox[{"Abs", "[", "fwd", "]"}], ",", "\n", 
