               RowBox[{"{", 
                RowBox[{"J1", ",", " ", "6"}], "}"}]}], "\n", "    ", "]"}], 
             ";"}]}], "\n", "  ", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"kk", ",", " ", "nC"}], "}"}]}], "]"}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"{", 
         RowBox[{"nC", ",", " ", 
          RowBox[{"RR", " ", 
           RowBox[{"uScatFwd", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}]}]}], "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"R", " ", "*", " ", 
         RowBox[{"u", "^", "scat_z"}], " ", "at", " ", "theta"}], "=", "0"}], 
       " ", "*)"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Reference", ":", " ", 
     RowBox[{"Mie", " ", "forward", " ", "amplitude"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"mieForward", " ", "=", " ", 
     RowBox[{
      RowBox[{"mieFarFieldP", "[", 
       RowBox[{"0.", ",", " ", "mie"}], "]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", 
        RowBox[{"omega", "/", "alphaBg"}], " ", "20.", " ", "aRadius"}], 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Convergence Study: Forward Scattering ---\>\"", 
     "]"}], ";"}], "\n", 
