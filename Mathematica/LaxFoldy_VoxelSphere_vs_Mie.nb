Cell[CellGroupData[{

Cell["5. Voxelize the Sphere", "Section",ExpressionUUID->"a1b00006-0001-0001-0001-000000000001"],

Cell["\<\
Fill the sphere of radius a with a regular grid of cubes of side length d. A \
cube is included if its centre lies within the sphere. The cube centres form \
the scatterer locations for the Lax\[Dash]Foldy system.

Coordinates: {z, x, y} with z = axis 0 (down, propagation direction).\
\>", "Text",ExpressionUUID->"a1b00006-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Number", " ", "of", " ", "cubes", " ", "per", " ", "diameter"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"nPerDiam", " ", "=", " ", "7"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"d", " ", "=", " ", 
     RowBox[{"2", " ", 
      RowBox[{"aRadius", "/", "nPerDiam"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Voxel side length d = \>\"", ",", " ", "d", ",", 
      " ", "\"\< km\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<d/a = \>\"", ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"d", "/", "aRadius"}], "]"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Generate", " ", "cube", " ", "centres", " ", "inside", " ", "sphere"}], 
    " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Grid", " ", "from"}], " ", "-", 
      RowBox[{
      "a", " ", "to", " ", "a", " ", "in", " ", "steps", " ", "of", " ", 
       "d"}]}], ",", " ", 
     RowBox[{"centred", " ", "at", " ", "0"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"halfGrid", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "nPerDiam"}], "/", "2"}], " ", "+", " ", "0.5", " ", "+",
           " ", "i"}], ")"}], " ", "d"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "0", ",", " ", 
         RowBox[{"nPerDiam", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"cubeCentres", " ", "=", " ", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Do", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"Do", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"pos", " ", "=", " ", 
              RowBox[{"{", 
               RowBox[{"zz", ",", " ", "xx", ",", " ", "yy"}], "}"}]}], "}"}],
             ",", "\n", "        ", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Norm", "[", "pos", "]"}], " ", "<", " ", "aRadius"}], 
              ",", "\n", "          ", 
              RowBox[{"AppendTo", "[", 
               RowBox[{"cubeCentres", ",", " ", "pos"}], "]"}]}], "\n", 
             "        ", "]"}]}], "\n", "      ", "]"}], ",", "\n", "      ", 
          
          RowBox[{"{", 
           RowBox[{"yy", ",", " ", "halfGrid"}], "}"}]}], "\n", "    ", "]"}],
         ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"xx", ",", " ", "halfGrid"}], "}"}]}], "\n", "  ", "]"}], ",",
       "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"zz", ",", " ", "halfGrid"}], "}"}]}], "\n", "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"cubeCentres", " ", "=", " ", 
     RowBox[{"N", "[", "cubeCentres", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nCubes", " ", "=", " ", 
     RowBox[{"Length", "[", "cubeCentres", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Number of voxels inside sphere: \>\"", ",", " ", "nCubes"}],
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Volume of voxels: \>\"", ",", " ", 
      RowBox[{"nCubes", " ", 
       RowBox[{"d", "^", "3"}]}], ",", " ", "\"\< km\\[ThreeSuperior]\>\""}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Sphere volume: \>\"", ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{
        RowBox[{"4.", "/", "3."}], " ", "Pi", " ", 
        RowBox[{"aRadius", "^", "3"}]}], "]"}], ",", 
      " ", "\"\< km\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Fill fraction: \>\"", ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"nCubes", " ", 
        RowBox[{
         RowBox[{"d", "^", "3"}], " ", "/", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"4.", "/", "3."}], " ", "Pi", " ", 
           RowBox[{"aRadius", "^", "3"}]}], ")"}]}]}], "]"}]}], "]"}], ";"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[60]:=",ExpressionUUID->"a1b00006-0001-0001-0001-000000000003"],

