Cell[CellGroupData[{

Cell["7. Lax\[Dash]Foldy 9N\[Times]9N System Assembly and Solution", "Section",ExpressionUUID->"a1b00008-0001-0001-0001-000000000001"],

Cell["\<\
The 9-component Lax\[Dash]Foldy self-consistent equations:

  w^{exc}(x_j) = w^{inc}(x_j) + \[CapitalSigma]_{k \[NotEqual] j} P(x_j - \
x_k) \[CenterDot] T \[CenterDot] w^{exc}(x_k)

where w = {u_z, u_x, u_y, \[Epsilon]_zz, \[Epsilon]_xx, \[Epsilon]_yy, \
\[Epsilon]_yz, \[Epsilon]_zx, \[Epsilon]_xy}, P is the 9\[Times]9 propagator, \
and T is the 9\[Times]9 T-matrix. This gives a 9N\[Times]9N linear system.

For a P-wave incident along +z: u^inc = \\[HAT]z exp(i k_P z), \
\[Epsilon]^inc_zz = i k_P exp(i k_P z), all other \[Epsilon] = 0.\
\>", "Text",ExpressionUUID->"a1b00008-0001-0001-0001-000000000002"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"FFT", "-", 
     RowBox[{"Accelerated", " ", "Lax", "-", 
      RowBox[{"Foldy", " ", "Solve"}]}]}], " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "this", " ", "cell", " ", "INSTEAD", " ", "of", " ", 
    "the", " ", "dense", " ", "assembly", " ", "below"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Get", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], " ", "<>", 
      " ", "\"\<FFTLaxFoldy.wl\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"excField", " ", "=", " ", 
     RowBox[{"fftSolveSystem", "[", 
      RowBox[{
      "cubeCentres", ",", " ", "nPerDiam", ",", " ", "d", ",", " ", 
       "tMatrix9", ",", "\n", "    ", "omega", ",", " ", "alphaBg", ",", " ", 
       "betaBg", ",", " ", "rhoBg", ",", " ", "incidentState"}], "]"}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"379d43ec-d28e-444f-bc7a-\
6b043d9afa09"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"Diagnostic", ":", " ", 
     RowBox[{"FFT", " ", "vs", " ", "Dense", " ", "matvec"}]}], " ", "==="}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Get", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], " ", "<>", 
      " ", "\"\<FFTLaxFoldy.wl\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"verifyFFTMatvec", "[", "3", "]"}], ";"}]}]}]], "Input",Expression\
UUID->"b40e7e01-d10f-4f72-8b0e-d26c593c7b84"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8. Compute Scattered Field (Full Source)", "Section",ExpressionUUID->"a1b00009-0001-0001-0001-000000000001"],

Cell["\<\
The scattered displacement uses both density (force) and stiffness (stress \
dipole) sources from each cube:
  u^scat_i(x) = \[CapitalSigma]_k [G_{il}(x-x_k) f^eff_l + H_{ipq}(x-x_k) \
\[CapitalDelta]\[Sigma]^eff_{pq}]
where the effective source s_k = T \[CenterDot] w^exc_k.\
\>", "Text",ExpressionUUID->"a1b00009-0001-0001-0001-000000000002"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{
    "Scattered", " ", "displacement", " ", "at", " ", "observation", " ", 
     "point"}], " ", "==="}], " ", "*)"}], "\n", 
