       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"All", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "2"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Epilog", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Gray", ",", " ", "Dashed", ",", " ", 
          RowBox[{"InfiniteLine", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltRatio", "]"}], ";"}], "\n"}]}]], "Input",
