    "Print", "[", "\"\<\\n--- Amplitude comparison (first few angles) ---\>\"",
      "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"PaddedForm", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"TableForm", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", "\n", "      ", 
            RowBox[{
             RowBox[{
