Cell[CellGroupData[{

Cell["8. Compute Scattered Field (Full Source)", "Section",ExpressionUUID->"a1b00009-0001-0001-0001-000000000001"],

Cell["\<\
The scattered displacement uses both density (force) and stiffness (stress \
dipole) sources from each cube:
  u^scat_i(x) = \[CapitalSigma]_k [G_{il}(x-x_k) f^eff_l + H_{ipq}(x-x_k) \
\[CapitalDelta]\[Sigma]^eff_{pq}]
where the effective source s_k = T \[CenterDot] w^exc_k.\
\>", "Text",ExpressionUUID->"a1b00009-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{
    "Scattered", " ", "displacement", " ", "at", " ", "observation", " ", 
     "point"}], " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Uses", " ", "full", " ", "9"}], "-", 
    RowBox[{"component", " ", 
     RowBox[{"source", ":", " ", 
      RowBox[{
       RowBox[{"force", " ", 
        RowBox[{"(", 
         RowBox[{"1", ":", "3"}], ")"}]}], " ", "+", " ", 
       RowBox[{"stress", " ", "dipole", " ", 
        RowBox[{"(", 
         RowBox[{"4", ":", "9"}], ")"}]}]}]}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"scatteredFieldAt", "[", "xObs_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"uScat", " ", "=", " ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0.", ",", " ", "0.", ",", " ", "0."}], "}"}], " ", "+", 
           " ", 
           RowBox[{"0.", " ", "I"}]}]}], ",", " ", "idx", ",", " ", "wExcK", ",",
          " ", "sourceK", ",", "\n", "   ", "xRel", ",", " ", "G3", ",", " ", 
         "Gd", ",", " ", "H3", ",", " ", "fEff", ",", " ", "sigEff", ",", " ",
          "pp", ",", " ", "qq", ",", " ", "i", ",", " ", "j", ",", " ", "k", ",",
          " ", "J1"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Do", "[", "\n", "    ", 
         RowBox[{
          RowBox[{
           RowBox[{"idx", " ", "=", " ", 
            RowBox[{"9", " ", 
             RowBox[{"(", 
              RowBox[{"kk", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", 
           "    ", 
           RowBox[{"wExcK", " ", "=", " ", 
            RowBox[{"excField", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"idx", " ", "+", " ", "1"}], " ", ";;", " ", 
               RowBox[{"idx", " ", "+", " ", "9"}]}], "]"}], "]"}]}], ";", 
           "\n", "    ", 
           RowBox[{"sourceK", " ", "=", " ", 
            RowBox[{"tMatrix9", " ", ".", " ", "wExcK"}]}], ";", "  ", 
           RowBox[{"(*", " ", 
            RowBox[{"{", 
             RowBox[{
             "f_z", ",", "f_x", ",", "f_y", ",", " ", "sig_zz", ",", "...", ",",
               "sig_xy"}], "}"}], " ", "*)"}], "\n", "    ", 
           RowBox[{"fEff", " ", "=", " ", 
            RowBox[{"sourceK", "[", 
             RowBox[{"[", 
              RowBox[{"1", " ", ";;", " ", "3"}], "]"}], "]"}]}], ";", "\n", 
           "    ", 
           RowBox[{"sigEff", " ", "=", " ", 
            RowBox[{"sourceK", "[", 
             RowBox[{"[", 
              RowBox[{"4", " ", ";;", " ", "9"}], "]"}], "]"}]}], ";", "\n", 
           "    ", 
           RowBox[{"xRel", " ", "=", " ", 
            RowBox[{"xObs", " ", "-", " ", 
             RowBox[{"cubeCentres", "[", 
              RowBox[{"[", "kk", "]"}], "]"}]}]}], ";", "\n", "    ", 
           RowBox[{"G3", " ", "=", " ", 
            RowBox[{"greensTensor", "[", 
             RowBox[{
             "xRel", ",", " ", "omega", ",", " ", "alphaBg", ",", " ", 
              "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"Gd", " ", "=", " ", 
            RowBox[{"greensDerivTensor", "[", 
             RowBox[{
             "xRel", ",", " ", "omega", ",", " ", "alphaBg", ",", " ", 
              "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"H_", 
              RowBox[{"{", "ijk", "}"}]}], " ", "=", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "/", "2"}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"G_", 
                 RowBox[{"{", 
                  RowBox[{"ij", ",", "k"}], "}"}]}], " ", "+", " ", 
                RowBox[{"G_", 
                 RowBox[{"{", 
                  RowBox[{"ik", ",", "j"}], "}"}]}]}], ")"}]}]}], " ", "*)"}],
            "\n", "    ", 
           RowBox[{"H3", " ", "=", " ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"Gd", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", " ", "j", ",", " ", "k"}], "]"}], "]"}], 
                 " ", "+", " ", 
                 RowBox[{"Gd", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", " ", "k", ",", " ", "j"}], "]"}], 
                  "]"}]}], ")"}], "/", "2"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"i", ",", " ", "3"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"j", ",", " ", "3"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"k", ",", " ", "3"}], "}"}]}], "]"}]}], ";", "\n", 
           "    ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"u", "^", "scat_i"}], " ", "+=", " ", 
             RowBox[{"G_", 
              RowBox[{"{", "il", "}"}], " ", "f_l"}]}], " ", "*)"}], "\n", 
           "    ", 
           RowBox[{"uScat", " ", "+=", " ", 
            RowBox[{"G3", " ", ".", " ", "fEff"}]}], ";", "\n", "    ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"u", "^", "scat_i"}], " ", "+=", " ", 
             RowBox[{"H_", 
              RowBox[{"{", "ipq", "}"}], " ", "sigma_", 
              RowBox[{"{", "pq", "}"}], " ", 
              RowBox[{"(", 
               RowBox[{"with", " ", "Voigt", " ", "weights"}], ")"}]}]}], " ",
             "*)"}], "\n", "    ", 
           RowBox[{"Do", "[", "\n", "      ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"pp", ",", " ", "qq"}], "}"}], " ", "=", " ", 
               RowBox[{"voigtPairs", "[", 
                RowBox[{"[", "J1", "]"}], "]"}]}], ";", "\n", "      ", 
              RowBox[{"uScat", " ", "+=", " ", 
               RowBox[{
                RowBox[{"voigtWeight", "[", 
                 RowBox[{"[", "J1", "]"}], "]"}], " ", 
                RowBox[{"H3", "[", 
                 RowBox[{"[", 
                  RowBox[{"All", ",", " ", "pp", ",", " ", "qq"}], "]"}], 
                 "]"}], " ", 
                RowBox[{"sigEff", "[", 
                 RowBox[{"[", "J1", "]"}], "]"}]}]}]}], ",", "\n", "      ", 
             RowBox[{"{", 
              RowBox[{"J1", ",", " ", "6"}], "}"}]}], "\n", "    ", "]"}]}], ",",
           "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"kk", ",", " ", "nCubes"}], "}"}]}], "\n", "  ", "]"}], ";",
         "\n", "  ", "uScat"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Far", "-", 
      RowBox[{"field", " ", "P", "-", 
       RowBox[{"wave", " ", "amplitude", " ", 
        RowBox[{"(", "asymptotic", ")"}]}]}]}], " ", "==="}], " ", "*)"}], 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "effective", " ", "sources", " ", "T", ".", "psi_exc", " ",
      "for", " ", "each", " ", "cube"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sourcesList", " ", "=", " ", 
