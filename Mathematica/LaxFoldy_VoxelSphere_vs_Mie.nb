Cell[CellGroupData[{

Cell["7. Lax\[Dash]Foldy 9N\[Times]9N System Assembly and Solution", "Section",ExpressionUUID->"a1b00008-0001-0001-0001-000000000001"],

Cell["\<\
The 9-component Lax\[Dash]Foldy self-consistent equations:

  w^{exc}(x_j) = w^{inc}(x_j) + \[CapitalSigma]_{k \[NotEqual] j} P(x_j - \
x_k) \[CenterDot] T \[CenterDot] w^{exc}(x_k)

where w = {u_z, u_x, u_y, \[Epsilon]_zz, \[Epsilon]_xx, \[Epsilon]_yy, \
\[Epsilon]_yz, \[Epsilon]_zx, \[Epsilon]_xy}, P is the 9\[Times]9 propagator, \
and T is the 9\[Times]9 T-matrix. This gives a 9N\[Times]9N linear system.

For a P-wave incident along +z: u^inc = \\[HAT]z exp(i k_P z), \
\[Epsilon]^inc_zz = i k_P exp(i k_P z), all other \[Epsilon] = 0.\
\>", "Text",ExpressionUUID->"a1b00008-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{
     RowBox[{"Incident", " ", "P"}], "-", 
     RowBox[{"wave", " ", "state", " ", 
      RowBox[{"vector", ":", " ", 
       RowBox[{
        RowBox[{"9", " ", "components"}], " ", "==="}]}]}]}]}], " ", "*)"}], 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"u", "^", "inc"}], " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"exp", 
       RowBox[{"(", "ikz", ")"}]}], ",", " ", "0", ",", " ", "0"}], "}"}]}], 
   " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"eps", "^", "inc_zz"}], " ", "=", " ", 
     RowBox[{"i", " ", "kP", " ", "exp", 
      RowBox[{"(", "ikz", ")"}]}]}], ",", " ", 
    RowBox[{"all", " ", "others", " ", "zero"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"State", ":", " ", 
    RowBox[{"{", 
     RowBox[{
     "u_z", ",", " ", "u_x", ",", " ", "u_y", ",", " ", "eps_zz", ",", " ", 
      "eps_xx", ",", " ", "eps_yy", ",", " ", "eps_yz", ",", " ", "eps_zx", ",",
       " ", "eps_xy"}], "}"}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"incidentState", "[", "pos_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"kPv", ",", " ", "phase"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"kPv", " ", "=", " ", 
         RowBox[{"omega", "/", "alphaBg"}]}], ";", "\n", "  ", 
        RowBox[{"phase", " ", "=", " ", 
         RowBox[{"Exp", "[", 
          RowBox[{"I", " ", "kPv", " ", 
           RowBox[{"pos", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"phase", ",", " ", "0.", ",", " ", "0.", ",", "          ", 
          RowBox[{"(*", " ", "displacement", " ", "*)"}], "\n", "   ", 
          RowBox[{"I", " ", "kPv", " ", "phase"}], ",", " ", "0.", ",", " ", 
          "0.", ",", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{"normal", " ", 
            RowBox[{"strains", ":", " ", 
             RowBox[{"only", " ", "eps_zz", " ", "nonzero"}]}]}], " ", "*)"}],
           "\n", "   ", "0.", ",", " ", "0.", ",", " ", "0."}], "}"}]}]}], 
      "             ", 
      RowBox[{"(*", " ", 
       RowBox[{"shear", " ", "strains"}], " ", "*)"}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{
     "Assemble", " ", "the", " ", "9", "N", " ", "x", " ", "9", "N", " ", 
      "system"}], " ", "==="}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"System", ":", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", " ", "-", " ", 
         RowBox[{"P", ".", "T"}]}], ")"}], " ", "W"}]}], " ", "=", " ", 
     "Winc"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dim", " ", "=", " ", 
     RowBox[{"9", " ", "nCubes"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Building \>\"", ",", " ", "dim", ",", " ", "\"\< x \>\"", ",",
       " ", "dim", ",", " ", "\"\< Lax-Foldy matrix (\>\"", ",", "\n", "  ", 
      "nCubes", ",", " ", "\"\< cubes x 9 DOF)...\>\""}], "]"}], ";"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"systemMatrix", " ", "=", " ", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "dim", "]"}], " ", "+", " ", 
      RowBox[{"0.", " ", "I"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rhsVector", " ", "=", " ", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{
       RowBox[{"0.", " ", "+", " ", 
        RowBox[{"0.", " ", "I"}]}], ",", " ", "dim"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Fill", " ", "RHS", " ", "with", " ", "incident", " ", "state"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"winc", ",", " ", "idx"}], "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"idx", " ", "=", " ", 
          RowBox[{"9", " ", 
           RowBox[{"(", 
            RowBox[{"j", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", "    ", 
         RowBox[{"winc", " ", "=", " ", 
          RowBox[{"incidentState", "[", 
           RowBox[{"cubeCentres", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"rhsVector", "[", 
             RowBox[{"[", 
              RowBox[{"idx", " ", "+", " ", "ii"}], "]"}], "]"}], " ", "=", 
            " ", 
            RowBox[{"winc", "[", 
             RowBox[{"[", "ii", "]"}], "]"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"ii", ",", " ", "9"}], "}"}]}], "]"}], ";"}]}], "\n", 
       "  ", "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"j", ",", " ", "nCubes"}], "}"}]}], "\n", "]"}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Fill", " ", "off"}], "-", 
     RowBox[{"diagonal", " ", 
      RowBox[{"blocks", ":", " ", 
       RowBox[{
        RowBox[{"-", "P"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x_j", " ", "-", " ", "x_k"}], ")"}], " ", ".", " ", 
         "T"}]}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Pre", "-", 
      RowBox[{"compute", " ", 
       RowBox[{"P", ".", "T"}], " ", "for", " ", "each", " ", "pair", " ", 
       RowBox[{"(", 
        RowBox[{"j", ",", "k"}], ")"}], " ", "with", " ", "j"}]}], " ", "!=", 
     " ", "k"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"j", " ", "!=", " ", "k"}], ",", "\n", "    ", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "xjk", ",", " ", "Pjk", ",", " ", "block", ",", " ", "idxJ", ",", 
            " ", "idxK"}], "}"}], ",", "\n", "      ", 
          RowBox[{
           RowBox[{"xjk", " ", "=", " ", 
            RowBox[{
             RowBox[{"cubeCentres", "[", 
              RowBox[{"[", "j", "]"}], "]"}], " ", "-", " ", 
             RowBox[{"cubeCentres", "[", 
              RowBox[{"[", "k", "]"}], "]"}]}]}], ";", "\n", "      ", 
           RowBox[{"Pjk", " ", "=", " ", 
            RowBox[{"propagator9x9", "[", 
             RowBox[{
             "xjk", ",", " ", "omega", ",", " ", "alphaBg", ",", " ", 
              "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "      ", 
           RowBox[{"block", " ", "=", " ", 
            RowBox[{"-", 
             RowBox[{"Pjk", " ", ".", " ", "tMatrix9"}]}]}], ";", "\n", 
           "      ", 
           RowBox[{"idxJ", " ", "=", " ", 
            RowBox[{"9", " ", 
             RowBox[{"(", 
              RowBox[{"j", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", 
           "      ", 
           RowBox[{"idxK", " ", "=", " ", 
            RowBox[{"9", " ", 
             RowBox[{"(", 
              RowBox[{"k", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", 
           "      ", 
           RowBox[{"Do", "[", 
            RowBox[{
             RowBox[{"Do", "[", "\n", "        ", 
              RowBox[{
               RowBox[{
                RowBox[{"systemMatrix", "[", 
                 RowBox[{"[", 
                  RowBox[{
                   RowBox[{"idxJ", " ", "+", " ", "ii"}], ",", " ", 
                   RowBox[{"idxK", " ", "+", " ", "jj"}]}], "]"}], "]"}], " ",
                 "=", " ", 
                RowBox[{"block", "[", 
                 RowBox[{"[", 
                  RowBox[{"ii", ",", " ", "jj"}], "]"}], "]"}]}], ",", "\n", 
               "        ", 
               RowBox[{"{", 
                RowBox[{"jj", ",", " ", "9"}], "}"}]}], "]"}], ",", " ", 
             RowBox[{"{", 
              RowBox[{"ii", ",", " ", "9"}], "}"}]}], "]"}], ";"}]}], "\n", 
         "    ", "]"}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"j", ",", " ", "nCubes"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "nCubes"}], "}"}]}], "\n", "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Solving \>\"", ",", " ", "dim", ",", " ", "\"\< x \>\"", ",",
       " ", "dim", ",", " ", "\"\< linear system...\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"excField", " ", "=", " ", 
     RowBox[{"LinearSolve", "[", 
      RowBox[{"systemMatrix", ",", " ", "rhsVector"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Lax-Foldy system solved.\>\"", "]"}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "displacement", " ", "components", " ", "for", " ", 
     "inspection"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nExciting field at cube 1:\>\"", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  u = \>\"", ",", " ", 
      RowBox[{"excField", "[", 
       RowBox[{"[", 
        RowBox[{"1", " ", ";;", " ", "3"}], "]"}], "]"}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  eps = \>\"", ",", " ", 
      RowBox[{"excField", "[", 
       RowBox[{"[", 
        RowBox[{"4", " ", ";;", " ", "9"}], "]"}], "]"}]}], "]"}], ";"}], 
   "\n"}]}]], "Input",
 CellLabel->
