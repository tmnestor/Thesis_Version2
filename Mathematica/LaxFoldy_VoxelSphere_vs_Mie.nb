Cell[CellGroupData[{

Cell["6. Green\[CloseCurlyQuote]s Tensor, 9\[Times]9 Propagator, and \
T-Matrix", "Section",ExpressionUUID->"a1b00007-0001-0001-0001-000000000001"],

Cell["\<\
State vector per cube: w = {u_z, u_x, u_y, \[Epsilon]_zz, \[Epsilon]_xx, \
\[Epsilon]_yy, \[Epsilon]_yz, \[Epsilon]_zx, \[Epsilon]_xy}.

The 9\[Times]9 T-matrix maps exciting field to effective source:
  T = V diag(\[Omega]\\[TwoSuperior] \[CapitalDelta]\[Rho]_eff I_3, \
\[CapitalDelta]C*_Voigt)
with Eshelby-corrected amplification factors. For cube-shaped voxels, the \
Eshelby depolarization tensor has cubic symmetry (three independent constants \
A, B, C with C \[NotEqual] 0), producing four amplification factors and cubic \
anisotropy in the effective stiffness: C11\[Dash]C12 \[NotEqual] 2 C44.

The 9\[Times]9 propagator maps source at x_k to field at x_j:
  P = | G_{il}     H_{i,pq}  |     (displacement from force/stress)
      | K_{mn,l}   S_{mn,pq} |     (strain from force/stress)
where K = sym grad of G, S = sym grad of H.\
\>", "Text",ExpressionUUID->"a1b00007-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "==="}], 
    "="}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"6", 
    RowBox[{"a", ".", " ", 
     RowBox[{"GREEN", "'"}]}], "S", " ", "TENSOR", " ", "AND", " ", 
    "ANALYTICAL", " ", "DERIVATIVES"}], "                   ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "===", "===", "==="}], 
    "="}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Near", "-", 
    RowBox[{"field", " ", "constant"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"cNF", "[", 
      RowBox[{"alpha_", ",", " ", "beta_", ",", " ", "rho_"}], "]"}], " ", ":=",
      " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{
         RowBox[{"beta", "^", "2"}], "/", 
         RowBox[{"alpha", "^", "2"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", "Pi", " ", "rho", " ", 
        RowBox[{"beta", "^", "2"}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"P", "-", 
     RowBox[{"wave", " ", "and", " ", "S"}], "-", 
     RowBox[{"wave", " ", "amplitude", " ", "functions"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"vP", "[", 
      RowBox[{"r_", ",", " ", "om_", ",", " ", "alpha_", ",", " ", "rho_"}], 
      "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "om", " ", 
        RowBox[{"r", "/", "alpha"}]}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"4", " ", "Pi", " ", "rho", " ", 
        RowBox[{"alpha", "^", "2"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"vS", "[", 
      RowBox[{"r_", ",", " ", "om_", ",", " ", "beta_", ",", " ", "rho_"}], 
      "]"}], "  ", ":=", " ", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", "om", " ", 
        RowBox[{"r", "/", "beta"}]}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"4", " ", "Pi", " ", "rho", " ", 
        RowBox[{"beta", "^", "2"}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Radial", " ", "functions", " ", "f", 
      RowBox[{"(", "r", ")"}]}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"g", 
        RowBox[{"(", "r", ")"}]}], ":", " ", 
       RowBox[{"G_", 
        RowBox[{"{", "ij", "}"}]}]}], " ", "=", " ", 
      RowBox[{
       RowBox[{"f", 
        RowBox[{"(", "r", ")"}], " ", "d_", 
        RowBox[{"{", "ij", "}"}]}], " ", "+", " ", 
       RowBox[{"g", 
        RowBox[{"(", "r", ")"}], " ", "nhat_i", " ", "nhat_j"}]}]}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fRadial", "[", 
      RowBox[{
      "r_", ",", " ", "om_", ",", " ", "alpha_", ",", " ", "beta_", ",", " ", 
       "rho_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"vS", "[", 
         RowBox[{"r", ",", " ", "om", ",", " ", "beta", ",", " ", "rho"}], 
         "]"}], " ", "-", " ", 
        RowBox[{"cNF", "[", 
         RowBox[{"alpha", ",", " ", "beta", ",", " ", "rho"}], "]"}]}], ")"}],
       "/", "r"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"gRadial", "[", 
      RowBox[{
      "r_", ",", " ", "om_", ",", " ", "alpha_", ",", " ", "beta_", ",", " ", 
       "rho_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", " ", 
         RowBox[{"cNF", "[", 
          RowBox[{"alpha", ",", " ", "beta", ",", " ", "rho"}], "]"}]}], " ", 
        "+", " ", 
        RowBox[{"vP", "[", 
         RowBox[{"r", ",", " ", "om", ",", " ", "alpha", ",", " ", "rho"}], 
         "]"}], " ", "-", " ", 
        RowBox[{"vS", "[", 
         RowBox[{"r", ",", " ", "om", ",", " ", "beta", ",", " ", "rho"}], 
         "]"}]}], ")"}], "/", "r"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Analytical", " ", "radial", " ", 
     RowBox[{"derivatives", ":"}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "'"}], 
      RowBox[{"(", "r", ")"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"i", " ", "om", " ", 
            RowBox[{"r", "/", "beta"}]}], " ", "-", " ", "1"}], ")"}], " ", 
         "V_S"}], " ", "+", " ", "C"}], "]"}], " ", "/", " ", 
      RowBox[{"r", "^", "2"}]}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"g", "'"}], 
      RowBox[{"(", "r", ")"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"i", " ", "om", " ", 
            RowBox[{"r", "/", "alpha"}]}], " ", "-", " ", "1"}], ")"}], " ", 
         "V_P"}], " ", "-", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"i", " ", "om", " ", 
            RowBox[{"r", "/", "beta"}]}], " ", "-", " ", "1"}], ")"}], " ", 
         "V_S"}], " ", "-", " ", 
        RowBox[{"3", "C"}]}], "]"}], " ", "/", " ", 
      RowBox[{"r", "^", "2"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"fRadialDeriv", "[", 
      RowBox[{
      "r_", ",", " ", "om_", ",", " ", "alpha_", ",", " ", "beta_", ",", " ", 
       "rho_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"I", " ", "om", " ", 
            RowBox[{"r", "/", "beta"}]}], " ", "-", " ", "1"}], ")"}], " ", 
         RowBox[{"vS", "[", 
