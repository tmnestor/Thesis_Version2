Cell[CellGroupData[{

Cell["10. Comparison Plots", "Section",ExpressionUUID->"a1b00011-0001-0001-0001-000000000001"],

Cell["\<\
Plot the Lax\[Dash]Foldy voxelized result against exact Mie on the same axes. \
We show both amplitude and phase of the far-field P-wave scattering pattern.\
\>", "Text",ExpressionUUID->"a1b00011-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "thetaGrid", " ", "already", " ", "covers", " ", "0", " ", "to", " ", 
    "Pi"}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", " ", 
     RowBox[{"Plot", " ", "1"}]}], ":", " ", 
    RowBox[{"Amplitude", " ", "==="}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"pltAmp", " ", "=", " ", 
     RowBox[{"Show", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Abs", "[", "mieAmplitude", "]"}]}], "}"}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Blue"}], "}"}]}], ",", "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", "\"\<Mie (exact)\>\"", "}"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Abs", "[", "lfAmplitude", "]"}]}], "}"}], "]"}], ",", 
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<Lax-Foldy 9x9 (\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
            " ", "\"\< cubes)\>\""}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n",
        "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<| R u^scat_r | (far-field amplitude)\>\""}], "}"}]}], ",",
        "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Scattering Amplitude: 9x9 Lax-Foldy vs Mie\>\""}], ",",
        "\n", "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltAmp", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", " ", 
      RowBox[{"Plot", " ", "2"}]}], ":", " ", 
     RowBox[{"Phase", " ", "==="}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"pltPhase", " ", "=", " ", 
     RowBox[{"Show", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{
             RowBox[{"Arg", "[", "mieAmplitude", "]"}], " ", 
             RowBox[{"180", "/", "Pi"}]}]}], "}"}], "]"}], ",", "\n", "    ", 
         
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Blue"}], "}"}]}], ",", "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", "\"\<Mie (exact)\>\"", "}"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"thetaGrid", " ", 
             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{
             RowBox[{"Arg", "[", "lfAmplitude", "]"}], " ", 
             RowBox[{"180", "/", "Pi"}]}]}], "}"}], "]"}], ",", "\n", "    ", 
         
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<Lax-Foldy 9x9 (\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
            " ", "\"\< cubes)\>\""}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n",
        "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<Phase (degrees)\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Scattering Phase: 9x9 Lax-Foldy vs Mie\>\""}], ",", 
       "\n", "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltPhase", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", " ", 
      RowBox[{"Plot", " ", "3"}]}], ":", " ", 
     RowBox[{
      RowBox[{"Amplitude", " ", "ratio"}], " ", "==="}]}], " ", "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"ratioData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"thetaGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", 
          RowBox[{"180", "/", "Pi"}]}], ",", "\n", "   ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", ">", " ", 
            RowBox[{"10", "^", 
             RowBox[{"-", "15"}]}]}], ",", "\n", "     ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"lfAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", 
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", " ", "1"}], 
          "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nAngles"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltRatio", " ", "=", " ", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"ratioData", ",", "\n", "  ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", " ", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<|Lax-Foldy| / |Mie|\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Amplitude Ratio: 9x9 Lax-Foldy / Mie\>\""}], ",", "\n", 
       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"All", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "2"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Epilog", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Gray", ",", " ", "Dashed", ",", " ", 
          RowBox[{"InfiniteLine", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltRatio", "]"}], ";"}], "\n"}]}]], "Input",
