          "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nAngles"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltRatio", " ", "=", " ", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"ratioData", ",", "\n", "  ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", " ", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<|Lax-Foldy| / |Mie|\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Amplitude Ratio: 9x9 Lax-Foldy / Mie\>\""}], ",", "\n", 
       "  ", 
       RowBox[{"Frame", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}], ",", "\n", "  ", 
       RowBox[{"PlotRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"All", ",", " ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "2"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Epilog", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Gray", ",", " ", "Dashed", ",", " ", 
          RowBox[{"InfiniteLine", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltRatio", "]"}], ";"}], "\n"}]}]], "Input",
 CellLabel->
  "In[180]:=",ExpressionUUID->"a1b00011-0001-0001-0001-000000000003"]
}, Open  ]],

Cell[CellGroupData[{

Cell["11. Voxelization Visualization", "Section",ExpressionUUID->"a1b00012-0001-0001-0001-000000000001"],

Cell["\<\
Show the voxelized sphere with cube centres and the bounding sphere for \
reference.\
\>", "Text",ExpressionUUID->"a1b00012-0001-0001-0001-000000000002"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "3", "D", " ", "visualization", " ", "of", " ", "voxelized", " ", 
    "sphere"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cubeGraphics", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cubeCentres", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"d", "/", "2"}], " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}]}], ",", "\n",
          "         ", 
         RowBox[{
          RowBox[{"cubeCentres", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"d", "/", "2"}], " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}]}]}], "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nCubes"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltVoxels", " ", "=", " ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{
       RowBox[{"{", "\n", "  ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"EdgeForm", "[", 
            RowBox[{"{", 
             RowBox[{"Thin", ",", " ", "Gray"}], "}"}], "]"}], ",", " ", 
           RowBox[{"FaceForm", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Opacity", "[", "0.3", "]"}], ",", " ", "Orange"}], 
             "}"}], "]"}], ",", "\n", "   ", "cubeGraphics"}], "}"}], ",", 
         "\n", "  ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Opacity", "[", "0.1", "]"}], ",", " ", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
             "aRadius"}], "]"}]}], "}"}]}], "\n", "  ", "}"}], ",", "\n", 
       "  ", 
       RowBox[{"Boxed", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"BoxRatios", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}], ",", "\n", 
       "  ", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<z (km)\>\"", ",", " ", "\"\<x (km)\>\"", ",", 
          " ", "\"\<y (km)\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Axes", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"PlotLabel", " ", "->", " ", 
        RowBox[{"\"\<Voxelized Sphere (\>\"", " ", "<>", " ", 
         RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
         " ", "\"\< cubes)\>\""}]}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "500"}], ",", "\n", "  ", 
       RowBox[{"ViewPoint", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"2.5", ",", " ", "2.0", ",", " ", "1.5"}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltVoxels", "]"}], ";"}], "\n"}]}]], "Input",
 CellLabel->
  "In[187]:=",ExpressionUUID->"a1b00012-0001-0001-0001-000000000003"]
}, Open  ]],

Cell[CellGroupData[{

Cell["12. Convergence Study", "Section",ExpressionUUID->"a1b00013-0001-0001-0001-000000000001"],

Cell["\<\
Study how the Lax\[Dash]Foldy result converges to the exact Mie solution as \
the voxel size decreases (more cubes per diameter). We measure the relative \
error in the forward scattering amplitude (\[Theta] = 0).\
\>", "Text",ExpressionUUID->"a1b00013-0001-0001-0001-000000000002"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"Diagnostic", ":", " ", 
     RowBox[{"Dense", " ", "vs", " ", "FFT", " ", "Convergence"}]}], " ", 
    "==="}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Run", " ", "this", " ", "first", " ", "to", " ", "verify", " ", "FFT", " ",
     "matches", " ", "dense", " ", "at", " ", "each", " ", "nPerD"}], " ", 
   "*)"}], "\n", "\n", 
  RowBox[{"(*", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Get", "[", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], " ", "<>", 
      " ", "\"\<FFTLaxFoldy.wl\>\""}], "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"convergenceStudyDenseVsFFT", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "5", ",", " ", "7"}], "}"}], "]"}], ";"}], "\n", 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.982179269689743*^9, 3.9821792894802437`*^9}},
 CellLabel->
  "In[156]:=",ExpressionUUID->"07554e9b-8d6c-4601-953d-b0b30151e2b2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
