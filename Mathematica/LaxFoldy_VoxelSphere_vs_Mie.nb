Cell[CellGroupData[{

Cell["3. Material Parameters (Seismological Units)", "Section",ExpressionUUID->"a1b00004-0001-0001-0001-000000000001"],

Cell["\<\
Background and inclusion properties in seismological units:
  Velocities in km/s, densities in g/cm\\[ThreeSuperior], lengths in km.
Coordinate system: z (down, propagation), x (across), y (out of plane).\
\>", "Text",ExpressionUUID->"a1b00004-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"Background", " ", "medium"}], " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"alphaBg", " ", "=", " ", "5.0"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"P", "-", 
      RowBox[{"wave", " ", "velocity"}]}], ",", " ", 
     RowBox[{"km", "/", "s"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"betaBg", "  ", "=", " ", "3.0"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"S", "-", 
      RowBox[{"wave", " ", "velocity"}]}], ",", " ", 
     RowBox[{"km", "/", "s"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rhoBg", "   ", "=", " ", "2.5"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"density", ",", " ", 
     RowBox[{"g", "/", 
      RowBox[{"cm", "^", "3"}]}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Lam\[EAcute]", " ", 
      RowBox[{"parameters", ":", " ", 
       RowBox[{"units", " ", "are", " ", 
        RowBox[{"g", "/", 
         RowBox[{"(", 
          RowBox[{"cm", "^", "3"}], ")"}]}], " ", "*", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"km", "/", "s"}], ")"}], "^", "2"}]}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"10", "^", "9"}], " ", "Pa"}], " ", "=", " ", "GPa"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"muBg", "  ", "=", " ", 
     RowBox[{"rhoBg", " ", 
      RowBox[{"betaBg", "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lamBg", " ", "=", " ", 
     RowBox[{"rhoBg", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"alphaBg", "^", "2"}], " ", "-", " ", 
        RowBox[{"2", " ", 
         RowBox[{"betaBg", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Background medium:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vp = \>\"", ",", " ", "alphaBg", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vs = \>\"", ",", " ", "betaBg", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Rho]  = \>\"", ",", " ", "rhoBg", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Lambda] = \>\"", ",", " ", "lamBg", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Mu]     = \>\"", ",", " ", "muBg", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Contrasts", " ", 
      RowBox[{"(", 
       RowBox[{"matching", " ", "Python", " ", 
        RowBox[{
         RowBox[{"test_sphere", "_scattering"}], ".", "py"}]}], ")"}]}], " ", 
     "==="}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Dlam", " ", "=", " ", "3.0"}], ";"}], "     ", 
   RowBox[{"(*", " ", 
    RowBox[{"GPa", ",", " ", 
     RowBox[{"~", "50", "%", " ", "positive"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Dmu", "  ", "=", " ", "1.0"}], ";"}], "    ", 
   RowBox[{"(*", " ", "GPa", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Drho", " ", "=", " ", "0.1"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"g", "/", 
     RowBox[{"cm", "^", "3"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Inclusion", " ", "medium", " ", 
      RowBox[{"(", 
       RowBox[{"derived", " ", "from", " ", "contrasts"}], ")"}]}], " ", 
     "==="}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lamIn", " ", "=", " ", 
     RowBox[{"lamBg", " ", "+", " ", "Dlam"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"muIn", "  ", "=", " ", 
     RowBox[{"muBg", " ", "+", " ", "Dmu"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rhoIn", " ", "=", " ", 
     RowBox[{"rhoBg", " ", "+", " ", "Drho"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alphaIn", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"lamIn", " ", "+", " ", 
         RowBox[{"2", " ", "muIn"}]}], ")"}], "/", "rhoIn"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"betaIn", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"muIn", "/", "rhoIn"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nInclusion medium:\>\"", "]"}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vp = \>\"", ",", " ", "alphaIn", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vs = \>\"", ",", " ", "betaIn", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Rho]  = \>\"", ",", " ", "rhoIn", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Lambda] = \>\"", ",", " ", "lamIn", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Mu]     = \>\"", ",", " ", "muIn", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nContrasts:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Lambda] = \>\"", ",", " ", "Dlam", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Mu]     = \>\"", ",", " ", "Dmu", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Rho]    = \>\"", ",", " ", "Drho", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Sphere", " ", "and", " ", "frequency"}], " ", "==="}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"aRadius", " ", "=", " ", "0.5"}], ";"}], "       ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"sphere", " ", "radius"}], ",", " ", "km"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"freq", "    ", "=", " ", "0.5"}], ";"}], "       ", 
   RowBox[{"(*", " ", "Hz", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"omega", "   ", "=", " ", 
     RowBox[{"2", " ", "Pi", " ", "freq"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"kP", " ", "=", " ", 
     RowBox[{"omega", "/", "alphaBg"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kS", " ", "=", " ", 
     RowBox[{"omega", "/", "betaBg"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nSphere radius a = \>\"", ",", " ", "aRadius", ",", 
      " ", "\"\< km\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Frequency f = \>\"", ",", " ", "freq", ",", 
      " ", "\"\< Hz\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<k_P a = \>\"", ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"kP", " ", "aRadius"}], "]"}], ",", " ", "\"\<,  k_S a = \>\"",
       ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"kS", " ", "aRadius"}], "]"}]}], "]"}], ";"}], 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.98217820417566*^9, 3.982178213288356*^9}},
