Cell[CellGroupData[{

Cell["3. Material Parameters (Seismological Units)", "Section",ExpressionUUID->"a1b00004-0001-0001-0001-000000000001"],

Cell["\<\
Background and inclusion properties in seismological units:
  Velocities in km/s, densities in g/cm\\[ThreeSuperior], lengths in km.
Coordinate system: z (down, propagation), x (across), y (out of plane).\
\>", "Text",ExpressionUUID->"a1b00004-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"Background", " ", "medium"}], " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"alphaBg", " ", "=", " ", "6.0"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"P", "-", 
      RowBox[{"wave", " ", "velocity"}]}], ",", " ", 
     RowBox[{"km", "/", "s"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"betaBg", "  ", "=", " ", "3.5"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"S", "-", 
      RowBox[{"wave", " ", "velocity"}]}], ",", " ", 
     RowBox[{"km", "/", "s"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rhoBg", "   ", "=", " ", "2.7"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"density", ",", " ", 
     RowBox[{"g", "/", 
      RowBox[{"cm", "^", "3"}]}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Lam\[EAcute]", " ", 
      RowBox[{"parameters", ":", " ", 
       RowBox[{"units", " ", "are", " ", 
        RowBox[{"g", "/", 
         RowBox[{"(", 
          RowBox[{"cm", "^", "3"}], ")"}]}], " ", "*", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"km", "/", "s"}], ")"}], "^", "2"}]}]}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"10", "^", "9"}], " ", "Pa"}], " ", "=", " ", "GPa"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"muBg", "  ", "=", " ", 
     RowBox[{"rhoBg", " ", 
      RowBox[{"betaBg", "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lamBg", " ", "=", " ", 
     RowBox[{"rhoBg", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"alphaBg", "^", "2"}], " ", "-", " ", 
        RowBox[{"2", " ", 
         RowBox[{"betaBg", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Background medium:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vp = \>\"", ",", " ", "alphaBg", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vs = \>\"", ",", " ", "betaBg", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Rho]  = \>\"", ",", " ", "rhoBg", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Lambda] = \>\"", ",", " ", "lamBg", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Mu]     = \>\"", ",", " ", "muBg", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Inclusion", " ", "medium"}], " ", "==="}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"alphaIn", " ", "=", " ", "4.0"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"km", "/", "s"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"betaIn", "  ", "=", " ", "2.3"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"km", "/", "s"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rhoIn", "   ", "=", " ", "2.3"}], ";"}], "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"g", "/", 
     RowBox[{"cm", "^", "3"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"muIn", "  ", "=", " ", 
     RowBox[{"rhoIn", " ", 
      RowBox[{"betaIn", "^", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lamIn", " ", "=", " ", 
     RowBox[{"rhoIn", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"alphaIn", "^", "2"}], " ", "-", " ", 
        RowBox[{"2", " ", 
         RowBox[{"betaIn", "^", "2"}]}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", "Contrasts", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Dlam", " ", "=", " ", 
     RowBox[{"lamIn", " ", "-", " ", "lamBg"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Dmu", "  ", "=", " ", 
     RowBox[{"muIn", " ", "-", " ", "muBg"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Drho", " ", "=", " ", 
     RowBox[{"rhoIn", " ", "-", " ", "rhoBg"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nInclusion medium:\>\"", "]"}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vp = \>\"", ",", " ", "alphaIn", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  Vs = \>\"", ",", " ", "betaIn", ",", 
      " ", "\"\< km/s\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Rho]  = \>\"", ",", " ", "rhoIn", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Lambda] = \>\"", ",", " ", "lamIn", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[Mu]     = \>\"", ",", " ", "muIn", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nContrasts:\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Lambda] = \>\"", ",", " ", "Dlam", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Mu]     = \>\"", ",", " ", "Dmu", ",", 
      " ", "\"\< GPa\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<  \[CapitalDelta]\[Rho]    = \>\"", ",", " ", "Drho", ",", 
      " ", "\"\< g/cm\\[ThreeSuperior]\>\""}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"===", " ", 
     RowBox[{"Sphere", " ", "and", " ", "frequency"}], " ", "==="}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"aRadius", " ", "=", " ", "0.5"}], ";"}], "       ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"sphere", " ", "radius"}], ",", " ", "km"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"freq", "    ", "=", " ", "0.5"}], ";"}], "       ", 
   RowBox[{"(*", " ", "Hz", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"omega", "   ", "=", " ", 
     RowBox[{"2", " ", "Pi", " ", "freq"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"kP", " ", "=", " ", 
     RowBox[{"omega", "/", "alphaBg"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kS", " ", "=", " ", 
     RowBox[{"omega", "/", "betaBg"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\\nSphere radius a = \>\"", ",", " ", "aRadius", ",", 
      " ", "\"\< km\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Frequency f = \>\"", ",", " ", "freq", ",", 
      " ", "\"\< Hz\>\""}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<k_P a = \>\"", ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"kP", " ", "aRadius"}], "]"}], ",", " ", "\"\<,  k_S a = \>\"",
       ",", " ", 
      RowBox[{"N", "[", 
       RowBox[{"kS", " ", "aRadius"}], "]"}]}], "]"}], ";"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"a1b00004-0001-0001-0001-000000000003"],

