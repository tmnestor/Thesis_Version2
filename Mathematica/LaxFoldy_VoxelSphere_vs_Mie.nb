          RowBox[{
           RowBox[{"-", "coeff0"}], " ", "srrInc0"}]}], "}"}]}], ";", "\n", 
       "  ", 
       RowBox[{"sol0", " ", "=", " ", 
        RowBox[{"LinearSolve", "[", 
         RowBox[{
          RowBox[{"N", "[", "M0", "]"}], ",", " ", 
          RowBox[{"N", "[", "rhs0", "]"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{
        RowBox[{"anArr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", "=", " ", 
        RowBox[{"sol0", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"n", " ", "\[GreaterEqual]", " ", "1"}], ":", " ", 
         RowBox[{
          RowBox[{"4", "\[Times]", "4", " ", "P"}], "-", "SV"}]}], " ", 
        "*)"}], "\n", "  ", 
       RowBox[{"Do", "[", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"sign", " ", "=", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "1."}], ")"}], "^", "n"}]}], ";", "\n", "    ", 
          RowBox[{"Mpsv", " ", "=", " ", 
           RowBox[{"N", "[", 
            RowBox[{"miePSVMatrix", "[", 
             RowBox[{
             "n", ",", " ", "omega", ",", " ", "a", ",", "\n", "      ", 
              "alphaOut", ",", " ", "betaOut", ",", " ", "rhoOut", ",", " ", 
              "lamOut", ",", " ", "muOut", ",", "\n", "      ", "alphaIn", ",",
               " ", "betaIn", ",", " ", "rhoIn", ",", " ", "lamIn", ",", " ", 
              "muIn"}], "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"rhsPsv", " ", "=", " ", 
           RowBox[{"N", "[", 
            RowBox[{"mieIncidentPSV", "[", 
             RowBox[{
             "n", ",", " ", "omega", ",", " ", "a", ",", " ", "alphaOut", ",",
               " ", "betaOut", ",", " ", "rhoOut", ",", "\n", "      ", 
              "lamOut", ",", " ", "muOut"}], "]"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"solPsv", " ", "=", " ", 
           RowBox[{"LinearSolve", "[", 
            RowBox[{"Mpsv", ",", " ", "rhsPsv"}], "]"}]}], ";", "\n", "    ", 
          
          RowBox[{
           RowBox[{"anArr", "[", 
            RowBox[{"[", 
             RowBox[{"n", " ", "+", " ", "1"}], "]"}], "]"}], " ", "=", " ", 
           RowBox[{"sign", " ", 
            RowBox[{"solPsv", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "    ", 
          RowBox[{
           RowBox[{"bnArr", "[", 
            RowBox[{"[", 
             RowBox[{"n", " ", "+", " ", "1"}], "]"}], "]"}], " ", "=", " ", 
           RowBox[{"sign", " ", 
            RowBox[{"solPsv", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}]}]}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"n", ",", " ", "1", ",", " ", "nMax"}], "}"}]}], "\n", "  ",
         "]"}], ";", "\n", "\n", "  ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<a\>\"", " ", "->", " ", "anArr"}], ",", " ", 
         RowBox[{"\"\<b\>\"", " ", "->", " ", "bnArr"}], ",", " ", 
         RowBox[{"\"\<nMax\>\"", " ", "->", " ", "nMax"}]}], "|>"}]}]}], "\n",
      "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Print", "[", "\"\<Mie machinery loaded.\>\"", "]"}], "\n"}], "Input",\

 CellLabel->"In[1]:=",ExpressionUUID->"a1b00002-0001-0001-0001-000000000003"],

