   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"===", " ", 
      RowBox[{"Plot", " ", "3"}]}], ":", " ", 
     RowBox[{
      RowBox[{"Amplitude", " ", "ratio"}], " ", "==="}]}], " ", "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"ratioData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"thetaGrid", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", 
          RowBox[{"180", "/", "Pi"}]}], ",", "\n", "   ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], " ", ">", " ", 
            RowBox[{"10", "^", 
             RowBox[{"-", "15"}]}]}], ",", "\n", "     ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"lfAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}], "/", 
            RowBox[{"Abs", "[", 
             RowBox[{"mieAmplitude", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", " ", "1"}], 
          "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nAngles"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltRatio", " ", "=", " ", 
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"ratioData", ",", "\n", "  ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", " ", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
