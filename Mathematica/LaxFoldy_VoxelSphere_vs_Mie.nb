         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<Im[f_P]\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Im[f_P]: 9x9 Lax-Foldy vs Mie\>\""}], ",", "\n", 
       "  ", 
