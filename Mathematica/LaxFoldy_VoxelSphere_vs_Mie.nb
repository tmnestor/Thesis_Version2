          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<  nPerDiam = \>\"", ",", " ", "np", ",", 
            " ", "\"\<...\>\""}], "]"}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"laxFoldyForwardAmplitude", "[", "np", "]"}]}], ";", "\n", 
