         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
