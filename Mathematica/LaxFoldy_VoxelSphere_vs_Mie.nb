Cell["\<\
Evaluate the exact Mie far-field P-wave amplitude on the same angular grid \
for direct comparison.\
\>", "Text",ExpressionUUID->"a1b00010-0001-0001-0001-000000000002"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Mie", " ", "far"}], "-", 
