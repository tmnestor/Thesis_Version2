Cell[CellGroupData[{

Cell["11. Convergence Sweep", "Section",ExpressionUUID->"30064607-111e-45b9-8bb1-21003b6c7659"],

Cell["\<\
Sweep over N and kmax to study convergence at a fixed z.
Compares G[1,1] on-axis against exact.\
\>", "Text",ExpressionUUID->"c9fa3194-e5f2-4f75-9958-a70221786c00"],

Cell[CellGroupData[{

Cell["\<\
(* Convergence sweep \[Dash] edit zSweep as needed *)
zSweep = 0.02;

Print[\"\\nConvergence sweep at z = \", zSweep];
Print[\"kS\[CenterDot]z = \", kSabs zSweep];
Print[\"\"];

Do[
 Module[{dk, b, grid, G00, ix0, Gex, actualErr, timing},
  dk = 2.0 km/nn;
  If[dk > 2.0, Continue[]];
  
  b = computeErrorBounds[nn, km, zSweep,
    \[Omega], \[Rho], \[Alpha], \[Beta]];
  
  {timing, G00} = AbsoluteTiming[
   greensFFTComponent[1, 1, nn, km, zSweep,
     \[Omega], \[Rho], \[Alpha], \[Beta]]];
  
  grid = fftGrid[nn, km];
  ix0 = nn/2 + 1;
  Gex = exactGreens[grid[\"x\"][[ix0]], grid[\"x\"][[ix0]],
    zSweep, \[Omega], \[Rho], \[Alpha], \[Beta]];
  actualErr = Abs[G00[[ix0, ix0]] - Gex[[1, 1]]]/Abs[Gex[[1, 1]]];
  
  Print[\"  N=\", PaddedForm[nn, 4],
   \"  kmax=\", PaddedForm[km, {5, 0}],
   \"  dk=\", NumberForm[dk, 4],
   \"  bound=\", ScientificForm[b[\"relTotal\"], 3],
   \"  actual=\", ScientificForm[actualErr, 3],
   \"  [\", NumberForm[timing, 3], \"s]\"];
 ],
 {nn, {256, 512, 1024, 2048,8192}},
 {km, {50, 100, 200, 400}}
]\
\>", "Input",
 CellChangeTimes->{{3.981333908531801*^9, 3.981333932373296*^9}, {
  3.9813341035040417`*^9, 3.981334105958878*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"d9342839-a757-4bcd-aaf1-59d20a788fe9"],

