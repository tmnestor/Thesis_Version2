Cell[CellGroupData[{

Cell["\<\
(* Compare with exact formula *)
Print[\"\\n=== FFT vs EXACT ===\"];
Do[
 Module[{ix, iy, xv, yv, Gex, Gff, err},
  {ix, iy} = idxMap[pt];
  xv = xGrid[[ix]];
  yv = xGrid[[iy]];
  Gex = exactGreens[xv, yv, zTest, \[Omega], \[Rho], \[Alpha], \[Beta]];
  Gff = GfftPts[pt];
  err = Norm[Gff - Gex, \"Frobenius\"]/Norm[Gex, \"Frobenius\"];
  Print[\"  pt=\", pt, \" -> grid=(\", xv, \",\", yv,
    \")  Frob err=\", ScientificForm[err, 4],
    \"  bound=\", ScientificForm[bounds[\"relTotal\"], 4]];
 ],
 {pt, testPoints}
]\
\>", "Input",
 CellLabel->"In[66]:=",ExpressionUUID->"a9fc8c96-3108-46ca-bea6-0b6ed4158127"],

