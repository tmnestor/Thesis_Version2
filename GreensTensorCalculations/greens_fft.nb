Cell[CellGroupData[{

Cell["\<\
(* Compute grid *)
gridInfo = fftGrid[nTest, kmaxTest];
xGrid = gridInfo[\"x\"];

(* Helper: find nearest grid index *)
nearestIdx[grid_, target_] :=
 First[Ordering[Abs[grid - target], 1]];

(* Index map for test points *)
idxMap = Association[
  Table[pt -> {nearestIdx[xGrid, pt[[1]]],
    nearestIdx[xGrid, pt[[2]]]}, {pt, testPoints}]];

(* Allocate result tensors *)
GfftPts = Association[
  Table[pt -> ConstantArray[0. + 0. I, {3, 3}],
    {pt, testPoints}]];

(* Compute all 6 unique components *)
Print[\"\\nComputing full 3\[Times]3 tensor...\"];
AbsoluteTiming[
 Do[
  Module[{comp},
   Print[\"  Computing G[\", ii, \",\", jj, \"]...\"];
   comp = greensFFTComponent[ii, jj, nTest, kmaxTest,
     zTest, \[Omega], \[Rho], \[Alpha], \[Beta]];
   Do[
    Module[{ix, iy},
     {ix, iy} = idxMap[pt];
     GfftPts[pt][[ii, jj]] = comp[[ix, iy]];
     If[ii != jj,
      GfftPts[pt][[jj, ii]] = comp[[ix, iy]]];
    ],
    {pt, testPoints}
   ];
  ],
  {ii, 1, 3}, {jj, ii, 3}
 ]
]\
\>", "Input",
 CellLabel->"In[50]:=",ExpressionUUID->"40f3570c-59e4-4dfc-bf6e-f180e43400b9"],

