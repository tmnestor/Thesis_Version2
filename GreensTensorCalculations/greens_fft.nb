Cell[CellGroupData[{

Cell["2. Exact Spatial Green\[CloseCurlyQuote]s Tensor (Ben-Menahem & \
Singh)", "Section",ExpressionUUID->"1ffc41b2-f633-4b82-87d2-05c4fc186765"],

Cell["\<\
The exact spatial Green\[CloseCurlyQuote]s tensor for a homogeneous isotropic \
medium:

  G_ij = f \[Delta]_ij + g \[Gamma]_i \[Gamma]_j

where \[Gamma] = x/r is the unit direction vector.\
\>", "Text",ExpressionUUID->"d30393aa-ebb6-486a-97e3-b88476e88f2a"],

Cell["\<\
exactGreens[x_, y_, z_, \[Omega]v_, \[Rho]v_, \[Alpha]v_, \[Beta]v_] :=
 Module[{r, gam, kP, kS, phiP, phiS, fac, f, g, G},
  r = Sqrt[x^2 + y^2 + z^2];
  gam = {x, y, z}/r;
  kP = \[Omega]v/\[Alpha]v;
  kS = \[Omega]v/\[Beta]v;
  phiP = Exp[I kP r];
  phiS = Exp[I kS r];
  fac = 1/(4 \[Pi] \[Rho]v);
  f = fac (phiS/(\[Beta]v^2 r)
    + (phiP - phiS)/(\[Omega]v^2 r^3)
    + I (phiS/\[Beta]v - phiP/\[Alpha]v)/(\[Omega]v r^2));
  g = fac (phiP/(\[Alpha]v^2 r) - phiS/(\[Beta]v^2 r)
    + 3 (phiS - phiP)/(\[Omega]v^2 r^3)
    - 3 I (phiS/\[Beta]v - phiP/\[Alpha]v)/(\[Omega]v r^2));
  G = Table[
    f KroneckerDelta[i, j] + g gam[[i]] gam[[j]],
    {i, 3}, {j, 3}];
  G
 ]\
\>", "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"26ae527c-8f5d-4499-adc6-6ab7fd846d46"],

Cell[CellGroupData[{

Cell["\<\
(* Quick test *)
Gtest = exactGreens[0.5, 0.3, 0.8, \[Omega], \[Rho], \[Alpha], \[Beta]];
MatrixForm[Gtest]\
\>", "Input",
 CellLabel->"In[19]:=",ExpressionUUID->"d94a17de-162d-481d-885e-5baf20b60d4b"],

