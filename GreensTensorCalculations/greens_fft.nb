Cell[CellGroupData[{

Cell["9. Full 3\[Times]3 Tensor FFT vs Exact", "Section",ExpressionUUID->"ed83c196-c497-4327-b02c-0c5e0303d02a"],

Cell["\<\
Compute all 6 unique components of the Green\[CloseCurlyQuote]s tensor via \
FFT
and compare with the exact Ben-Menahem & Singh formula at test points.

Note: For large N (e.g. 4096), this requires significant memory.
Start with N=512 for quick tests.\
\>", "Text",ExpressionUUID->"8cb54c6a-79ee-4347-89a7-4d479ce7962a"],

Cell["\<\
(* === USER PARAMETERS === *)
nTest = 512;     (* Grid size \[Dash] increase for accuracy *)
kmaxTest = 100;  (* Wavenumber truncation *)
zTest = 0.02;    (* Vertical separation *)

(* Test points {x, y} *)
testPoints = {{0.0, 0.0}, {0.02, 0.01}, {0.03, 0.02}};\
\>", "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"e7849aa6-ab5a-49bf-aa7a-820fac51f6ea"],

Cell[CellGroupData[{

Cell["\<\
(* Error bounds first *)
bounds = computeErrorBounds[nTest, kmaxTest, zTest,
  \[Omega], \[Rho], \[Alpha], \[Beta]];
printErrorBounds[bounds]\
\>", "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"44a997e1-c767-49dc-9ce3-9fd5ba3ee53e"],

Cell[CellGroupData[{

Cell[BoxData["\<\"\\n=== ERROR BOUNDS ===\"\>"], "Print",
