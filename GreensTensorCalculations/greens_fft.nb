Cell[CellGroupData[{

Cell["1. Material Parameters and Frequency", "Section",ExpressionUUID->"96c8e04c-c0d1-4be5-aeaf-1a0ecb117a55"],

Cell[CellGroupData[{

Cell["\<\
(* Material parameters *)
\[Rho] = 3.0;
\[Alpha] = 5.0;  (* P-wave speed *)
\[Beta] = 3.0;   (* S-wave speed *)

(* Complex frequency with damping *)
\[Eta] = 0.03;
\[Omega]r = 2 \[Pi];
\[Omega] = \[Omega]r (1 + I \[Eta]);

(* Derived wavenumbers *)
kPabs = Abs[\[Omega]/\[Alpha]];
kSabs = Abs[\[Omega]/\[Beta]];

Print[\"Material: \[Rho]=\", \[Rho], \", \[Alpha]=\", \[Alpha], \", \
\[Beta]=\", \[Beta]];
Print[\"\[Omega] = \", \[Omega]];
Print[\"|kP| = \", kPabs, \",  |kS| = \", kSabs];\
\>", "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"0b18c4ca-352b-4cdb-bb8c-ffa1569fe4ff"],

