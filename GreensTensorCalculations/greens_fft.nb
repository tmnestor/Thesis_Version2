Cell[CellGroupData[{

Cell["12. Error Bound Parameter Sweep (No FFT)", "Section",ExpressionUUID->"a720429b-8665-4603-9352-a8305170cc63"],

Cell["\<\
Fast parameter sweep computing only analytical error bounds.
No FFT computation, so this runs in seconds even for large N.\
\>", "Text",ExpressionUUID->"9bbbb0cc-6dc4-4a7a-b02a-a0859d242483"],

Cell[CellGroupData[{

Cell["\<\
zBoundTest = 0.02;

Print[\"\\n=== Parameter sweep (bounds only) ===\"];
Print[\"z = \", zBoundTest];
Print[\"\"];

boundTable = {{\"N\", \"kmax\", \"dk\", \"kmax\[CenterDot]\[CapitalDelta]z\",
  \"trunc\", \"alias\", \"total\", \"mem/comp\"}};

Do[
 Module[{dk, b, mem},
  dk = 2.0 km/nn;
  If[dk > 2.0, Continue[]];
  mem = nn^2 16./10^9;
  If[mem > 8.0, Continue[]];
  b = computeErrorBounds[nn, km, zBoundTest,
    \[Omega], \[Rho], \[Alpha], \[Beta]];
  AppendTo[boundTable, {nn, km,
    NumberForm[dk, 4], NumberForm[b[\"p\"], 4],
    ScientificForm[b[\"relTrunc\"], 3],
    ScientificForm[b[\"relAlias\"], 3],
    ScientificForm[b[\"relTotal\"], 3],
    StringForm[\"``GB\", NumberForm[mem, {4, 2}]]}];
 ],
 {nn, {512, 1024, 2048, 4096, 8192}},
 {km, {100, 200, 400, 750, 1000}}
];

Grid[boundTable, Frame -> All, Alignment -> Right]\
\>", "Input",
 CellLabel->"In[78]:=",ExpressionUUID->"83440cf7-b493-41e9-8db9-9228f8da0070"],

