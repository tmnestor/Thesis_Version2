Cell[CellGroupData[{

Cell["10. Component-by-Component Detail", "Section",ExpressionUUID->"7a5c708c-91cd-4356-8d29-1c63cdf993af"],

Cell[CellGroupData[{

Cell["\<\
Module[{pt, ix, iy, xv, yv, Gff, Gex},
 pt = testPoints[[1]];
 {ix, iy} = idxMap[pt];
 xv = xGrid[[ix]];
 yv = xGrid[[iy]];
 Gff = GfftPts[pt];
 Gex = exactGreens[xv, yv, zTest, \[Omega], \[Rho], \[Alpha], \[Beta]];
 
 Print[\"\\nComponent detail at (\", xv, \", \", yv, \", \", zTest, \")\"];
 Print[\"Frobenius error: \",
  ScientificForm[
   Norm[Gff - Gex, \"Frobenius\"]/Norm[Gex, \"Frobenius\"], 6]];
 Print[\"\"];
 
 Do[
  Module[{s, e, ce},
   s = Gff[[i, j]];
   e = Gex[[i, j]];
   If[Abs[e] > 10^-15,
    ce = Abs[s - e]/Abs[e];
    Print[\"  G[\", i, \",\", j, \"]: FFT=\",
     ScientificForm[s, 8], \"  exact=\",
     ScientificForm[e, 8], \"  err=\",
     ScientificForm[ce, 3]];
   ];
  ],
  {i, 3}, {j, 3}
 ];
]\
\>", "Input",
 CellLabel->"In[69]:=",ExpressionUUID->"9a1cc4da-e827-433e-983d-8b5bee570525"],

