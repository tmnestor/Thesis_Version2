   \edef\@itemitem{labelitem\romannumeral\the\@itemdepth}% 
   \list{\csname\@itemitem\endcsname}% 
  {\let\makelabel\makeRRlabel}% 
   \leftmargin 3.5em\labelsep 0.5em\itemindent 2.0em\labelwidth 0.5em% 
  \fi} 
