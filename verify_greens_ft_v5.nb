Cell[CellGroupData[{

Cell["7. Full SV + SH Dyadic Decomposition of S-Wave (Eqn. A.25)", "Section",ExpressionUUID->"6890651e-ee30-4e9b-8f1e-8872673e5946"],

Cell["\<\
The main result: verify that the S-wave contour contributions decompose \
exactly into the sum of SV and SH dyads with the prefactors stated in Eqn. \
A.25 of the thesis.\
\>", "Text",ExpressionUUID->"3e4614de-c18f-4f08-9398-ca471d86f1e8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Construct", " ", "the", " ", "full", " ", "dyadic", " ", "S"}], "-", 
    RowBox[{"wave", " ", "contributions", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".25"}], ")"}]}]}], " ", "*)"}], "\n", 
  
  RowBox[{
   RowBox[{
    RowBox[{"cTpSVSH", "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"I", " ", "\[Pi]"}], 
        RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2", " ", "kT2"}]], 
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "sSVp", ",", "sSVp"}], "]"}]}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{"I", " ", "\[Pi]"}], 
        RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2"}]], 
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"cTmSVSH", "=", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[Pi]"}], 
        RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2", " ", "kT2"}]], 
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "sSVm", ",", "sSVm"}], "]"}]}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[Pi]"}], 
        RowBox[{"\[Mu]", " ", "\[Nu]T", " ", "\[Xi]h2"}]], 
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}]}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Simplify", " ", "for", " ", "display"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cTpSVSHphys", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"cTpSVSH", "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cTmSVSHphys", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"cTmSVSH", "/.", "sub"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Test", " ", "on", " ", "raw", " ", "difference", " ", "with", " ", 
     "Together", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"avoids", " ", "FullSimplify", " ", "canonical"}], "-", 
       RowBox[{"form", " ", "issues"}]}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"testSdnSVSH", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cTp", "-", "cTpSVSH"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testSupSVSH", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cTm", "-", "cTmSVSH"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{"testSdnSVSH", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] S-wave downgoing = SV dyad + SH dyad (Eqn. A.25)\
\>\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] S-wave downgoing SV+SH decomposition failed\>\"",
           ",", "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{"testSupSVSH", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] S-wave upgoing = SV dyad + SH dyad (Eqn. A.25)\>\
\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] S-wave upgoing SV+SH decomposition failed\>\"", ",",
           "Bold", ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",\

 CellLabel->"In[65]:=",ExpressionUUID->"0815c9d6-d213-4887-81c8-be9a48543b29"],

