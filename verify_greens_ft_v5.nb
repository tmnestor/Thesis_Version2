Cell["10. Reduction to 2.5-D Cross-Check", "Section",ExpressionUUID->"2fdf19fb-1f6a-4c0d-b712-d9fdd0298fa4"],

Cell["\<\
Verify that at \[Xi]3 = 0, the polarisation vectors reduce to the thesis \
eigenvectors (Eqns. 3.63-3.65).\
\>", "Text",ExpressionUUID->"7fd01d1a-976b-49e0-8dd1-ebaa50fc6ccd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
