Cell[CellGroupData[{

Cell["5. SV and SH Polarisation Vectors (Eqns. A.22-A.23)", "Section",ExpressionUUID->"ac4ae623-e64f-4b3c-9055-936c2bd2e7c5"],

Cell["\<\
Define the SV and SH polarisation vectors and verify their orthogonality \
properties.\
\>", "Text",ExpressionUUID->"1ce81908-00e2-4b37-b41f-85f8c2d4e97f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"SV", " ", "polarisation", " ", "vectors", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Eqn", ".", " ", "A"}], ".22"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sSVp", "=", 
     RowBox[{"{", 
      RowBox[{"\[Xi]h2", ",", 
       RowBox[{"-", 
        RowBox[{"\[Nu]T", " ", "\[Xi]2"}]}], ",", 
       RowBox[{"-", 
        RowBox[{"\[Nu]T", " ", "\[Xi]3"}]}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sSVm", "=", 
     RowBox[{"{", 
      RowBox[{"\[Xi]h2", ",", 
       RowBox[{"\[Nu]T", " ", "\[Xi]2"}], ",", 
       RowBox[{"\[Nu]T", " ", "\[Xi]3"}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"SH", " ", "polarisation", " ", "vector", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".23"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sSH", "=", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "\[Xi]3"}], ",", "\[Xi]2"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Verify", " ", "norms"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"normSVp2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVp", ".", "sSVp"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"normSVm2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVm", ".", "sSVm"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"normSH2", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"sSH", ".", "sSH"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<|sSV(+)|^2 = \>\"", ",", "normSVp2", 
     ",", "\"\<  (expected: \[Xi]h^2 kT^2 = \>\"", ",", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"\[Xi]h2", " ", "kT2"}], "]"}], ",", "\"\<)\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<|sSV(-)|^2 = \>\"", ",", "normSVm2", 
     ",", "\"\<  (expected: \[Xi]h^2 kT^2)\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<|sSH|^2   = \>\"", ",", "normSH2", 
     ",", "\"\<  (expected: \[Xi]h^2 = \>\"", ",", "\[Xi]h2", 
     ",", "\"\<)\>\""}], "]"}]}]}]], "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"2af4cf3e-d5dd-4c6d-8a43-dd25ee8096e7"],

