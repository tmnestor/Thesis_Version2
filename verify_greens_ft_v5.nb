(* Beginning of Notebook Content *)
Notebook[{

Cell[CellGroupData[{
Cell["\<\
P-SV-SH Dyadic Decomposition of the Elastodynamic Green\[CloseCurlyQuote]s \
Tensor\
\>", "Title",ExpressionUUID->"3bda764c-d83e-4008-abc9-e3d5f08f1613"],

Cell[TextData[{
 "The Fourier-domain Green\[CloseCurlyQuote]s tensor satisfies the elastic \
wave equation by substituting back into the PDE.\nThe PDE (frequency domain):\
\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[Mu]", " ", 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[PartialD]", "2"], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["x", "j"], "\[PartialD]", 
         SubscriptBox["x", "j"]}]], " ", 
       SubscriptBox[
        OverscriptBox["U", "^"], "ik"]}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "+", "\[Mu]"}], ")"}], 
      RowBox[{
       FractionBox[
        SuperscriptBox["\[PartialD]", "2"], 
        RowBox[{"\[PartialD]", 
         SubscriptBox["x", "i"], "\[PartialD]", 
         SubscriptBox["x", "j"]}]], 
       SubscriptBox[
        OverscriptBox["U", "^"], "jk"]}]}], " ", "+", " ", 
     RowBox[{"\[Rho]", 
      SuperscriptBox["\[Omega]", "2"], 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["\[Delta]", "ik"]}], " ", 
     RowBox[{"\[Delta]", "(", 
      RowBox[{"x", "-", "y"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ef0247fc-e8c2-470c-89b4-53446a3936db"],
 "\nIn Fourier space (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[PartialD]", 
     SubscriptBox["x", "j"]], " ", 
    RowBox[{"\[Rule]", " ", 
     RowBox[{"i", " ", 
      SubscriptBox["\[Xi]", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "31a39b8d-c127-4472-99b2-3a6a59ee56ac"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Delta]", "(", 
     RowBox[{"x", "-", "y"}], ")"}], " ", "\[Rule]", " ", 
    SuperscriptBox["e", 
     RowBox[{"i", " ", "\[Xi]", "\[CenterDot]", "y"}]]}], TraditionalForm]],
  ExpressionUUID->"67df1007-41d0-45db-aea5-66b5add12b67"],
 "), the PDE becomes:\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"-", "\[Mu]"}], " ", 
      SuperscriptBox["\[Xi]", "2"], " ", 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}], " ", "-", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Lambda]", "+", "\[Mu]"}], ")"}], " ", 
      SubscriptBox["\[Xi]", "i"], 
      SubscriptBox["\[Xi]", "j"], " ", 
      SubscriptBox[
       OverscriptBox["U", "^"], "jk"]}], " ", "+", " ", 
     RowBox[{"\[Rho]", 
      SuperscriptBox["\[Omega]", "2"], 
      SubscriptBox[
       OverscriptBox["U", "^"], "ik"]}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["\[Delta]", "ik"]}], " ", 
     SuperscriptBox["e", 
      RowBox[{"i", " ", "\[Xi]", "\[CenterDot]", "y"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"ee9b2509-8192-4100-86a4-91f34ab0b109"],
 "\n\nThis notebook derives the elastodynamic Green\[CloseCurlyQuote]s tensor \
in the spatial Fourier domain, verifies it satisfies the governing PDE, \
decomposes it into simple poles, and evaluates the inverse Fourier transform \
in \[Xi]1 using the calculus of residues.\n\nThis notebook verifies that the \
contour contributions to the 3-D elastodynamic Green\[CloseCurlyQuote]s \
tensor decompose into rank-1 dyads for P, SV and SH wave polarisations, as \
derived in Appendix A of the thesis (Eqns. A.17-A.25).\n\nSpecifically, we \
verify:\n  1. P-wave contour contributions are rank-1 dyads\n  2. S-wave \
matrix factorises as a transverse projector\n  3. The transverse projector \
decomposes into SV + SH dyads\n  4. P + SV + SH dyads sum to the full contour \
result"
}], "Text",
 CellChangeTimes->{{3.981730537729639*^9, 
  3.981730540013421*^9}},ExpressionUUID->"213f6c3f-4922-4422-b8c5-\
eacd548fee7f"],

Cell[CellGroupData[{

Cell["1. Setup", "Section",ExpressionUUID->"9ac18505-5583-458a-8d23-29be38f8e594"],

Cell["\<\
We reproduce the essential definitions. All symbols match the thesis notation \
in Appendix A.\
\>", "Text",ExpressionUUID->"327c7052-0ea5-4e29-ab92-4216f6d80d28"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]", "=", 
   RowBox[{"{", 
    RowBox[{"\[Xi]1", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]sq", "=", 
   RowBox[{
    SuperscriptBox["\[Xi]1", "2"], "+", 
    SuperscriptBox["\[Xi]2", "2"], "+", 
    SuperscriptBox["\[Xi]3", "2"]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kL2", "=", 
   FractionBox[
    RowBox[{"\[Rho]", " ", 
     SuperscriptBox["\[Omega]", "2"]}], 
    RowBox[{"\[Lambda]", "+", 
     RowBox[{"2", "\[Mu]"}]}]]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kT2", "=", 
   FractionBox[
    RowBox[{"\[Rho]", " ", 
     SuperscriptBox["\[Omega]", "2"]}], "\[Mu]"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Xi]h2", "=", 
   RowBox[{
    SuperscriptBox["\[Xi]2", "2"], "+", 
    SuperscriptBox["\[Xi]3", "2"]}]}], ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"e79d830b-7fe0-4837-abe0-df68e2ffd852"],

Cell["Substitution rules for vertical wavenumbers:", "Text",ExpressionUUID->"3790b9a0-7675-4feb-b718-eccb3612a6e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sub", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Nu]L", "2"], "\[Rule]", 
      RowBox[{"kL2", "-", 
       SuperscriptBox["\[Xi]2", "2"], "-", 
       SuperscriptBox["\[Xi]3", "2"]}]}], ",", 
     RowBox[{
      SuperscriptBox["\[Nu]T", "2"], "\[Rule]", 
      RowBox[{"kT2", "-", 
       SuperscriptBox["\[Xi]2", "2"], "-", 
       SuperscriptBox["\[Xi]3", "2"]}]}]}], "}"}]}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"aa1689aa-ea8e-49fa-914b-3f6a8848448b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Residue Matrices", "Section",ExpressionUUID->"21b84848-571e-4921-b9d4-f52cee8cb5df"],

Cell["\<\
We define the partial-fraction form (Form 2) with \[Nu]L, \[Nu]T denominators \
and compute the residues at all four poles.\
\>", "Text",ExpressionUUID->"4fe4ac65-5c12-4173-b9f8-fed1cc14d657"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"OhatR", "[", 
   RowBox[{"i_", ",", "k_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "\[Mu]"], 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
        "\[Xi]", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], 
        RowBox[{
        "\[Xi]", "\[LeftDoubleBracket]", "k", "\[RightDoubleBracket]"}]}], 
       "kT2"], 
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", 
         RowBox[{
          SuperscriptBox["\[Xi]1", "2"], "-", 
          SuperscriptBox["\[Nu]L", "2"]}]], "-", 
        FractionBox["1", 
         RowBox[{
          SuperscriptBox["\[Xi]1", "2"], "-", 
          SuperscriptBox["\[Nu]T", "2"]}]]}], ")"}]}], "+", 
     FractionBox[
      RowBox[{"KroneckerDelta", "[", 
       RowBox[{"i", ",", "k"}], "]"}], 
      RowBox[{
       SuperscriptBox["\[Xi]1", "2"], "-", 
       SuperscriptBox["\[Nu]T", "2"]}]]}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"Rhat", "[", 
   RowBox[{"i_", ",", "k_"}], "]"}], ":=", 
  RowBox[{"Apart", "[", 
   RowBox[{
    RowBox[{"OhatR", "[", 
     RowBox[{"i", ",", "k"}], "]"}], ",", "\[Xi]1"}], "]"}]}]}], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"015a4996-cf6a-4348-abd0-55ed30e2dd31"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"resLp", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", "\[Nu]L"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resLm", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", 
          RowBox[{"-", "\[Nu]L"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resTp", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", "\[Nu]T"}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"resTm", "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Residue", "[", 
       RowBox[{
        RowBox[{"Rhat", "[", 
         RowBox[{"i", ",", "k"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Xi]1", ",", 
          RowBox[{"-", "\[Nu]T"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "3"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "3"}], "}"}]}], "]"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"eea17665-9f0e-4f42-867b-0a8b4407f789"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cLp", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resLp"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cLm", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resLm"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cTp", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resTp"}], "/.", "sub"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"cTm", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "I", " ", "resTm"}], "/.", "sub"}], "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"663089f5-fe87-43de-9dba-ef766dcbbc90"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. P-Wave Dyadic Verification (Eqn. A.18)", "Section",ExpressionUUID->"c41f16d8-d4c5-49e4-92fb-af5d658a4d5d"],

Cell["\<\
The P-wave contour contributions should be rank-1 dyads proportional to the \
outer product of the P-wave polarisation vector with itself.\
\>", "Text",ExpressionUUID->"2c4b7bf7-cf90-4322-a30e-b075d5dbe8a5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"P", "-", 
    RowBox[{"wave", " ", "polarisation", " ", "vectors", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".17"}], ")"}]}]}], " ", "*)"}], "\n", 
  
  RowBox[{
   RowBox[{
    RowBox[{"pPlus", "=", 
     RowBox[{"{", 
      RowBox[{"\[Nu]L", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"pMinus", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "\[Nu]L"}], ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Dyadic", " ", "products"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"PdyadP", "=", 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "pPlus", ",", "pPlus"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"PdyadM", "=", 
     RowBox[{"Outer", "[", 
      RowBox[{"Times", ",", "pMinus", ",", "pMinus"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Expected", " ", "contour", " ", "contributions", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".18"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cLpDyad", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"I", " ", "\[Pi]"}], 
       RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
        SuperscriptBox["\[Omega]", "2"]}]], "PdyadP"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cLmDyad", "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "I"}], " ", "\[Pi]"}], 
       RowBox[{"\[Nu]L", " ", "\[Rho]", " ", 
        SuperscriptBox["\[Omega]", "2"]}]], "PdyadM"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Test", ":", " ", 
     RowBox[{
     "dyadic", " ", "form", " ", "matches", " ", "contour", " ", "result"}]}],
     " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"testPdnDyad", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cLp", "-", "cLpDyad"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testPupDyad", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cLm", "-", "cLmDyad"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{"testPdnDyad", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] P-wave downgoing = P dyad\>\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] P-wave downgoing dyad mismatch\>\"", ",", "Bold",
           ",", "Red"}], "]"}]}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{"testPupDyad", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] P-wave upgoing = P dyad\>\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] P-wave upgoing dyad mismatch\>\"", ",", "Bold", ",",
           "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"7f5ae59b-042d-4cd4-803c-6e0edfb446dd"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"[PASS] P-wave downgoing = P dyad\"\>",
      StripOnInput->False,
      LineColor->RGBColor[0, 
        Rational[2, 3], 0],
      FrontFaceColor->RGBColor[0, 
