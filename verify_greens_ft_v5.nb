Cell[CellGroupData[{

Cell["6. Transverse Projector Decomposition (Eqn. A.24)", "Section",ExpressionUUID->"b31fcd16-8189-4b36-9c59-3307e5b51363"],

Cell["\<\
Verify that the transverse projector decomposes as the sum of normalised SV \
and SH dyads.\
\>", "Text",ExpressionUUID->"e21f76e2-5003-4bf3-b633-97be72d1562f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Construct", " ", "the", " ", "SV", " ", "and", " ", "SH", " ", "dyadic", " ",
     "terms"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"SVdyadP", "=", 
     FractionBox[
      RowBox[{"Outer", "[", 
       RowBox[{"Times", ",", "sSVp", ",", "sSVp"}], "]"}], 
      RowBox[{"\[Xi]h2", " ", "kT2"}]]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SVdyadM", "=", 
     FractionBox[
      RowBox[{"Outer", "[", 
       RowBox[{"Times", ",", "sSVm", ",", "sSVm"}], "]"}], 
      RowBox[{"\[Xi]h2", " ", "kT2"}]]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"SHdyad", "=", 
     FractionBox[
      RowBox[{"Outer", "[", 
       RowBox[{"Times", ",", "sSH", ",", "sSH"}], "]"}], "\[Xi]h2"]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Sum", " ", "of", " ", "SV"}], " ", "+", " ", 
     RowBox[{"SH", " ", "dyads"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dyadSumP", "=", 
     RowBox[{"SVdyadP", "+", "SHdyad"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dyadSumM", "=", 
     RowBox[{"SVdyadM", "+", "SHdyad"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Test", ":", " ", 
     RowBox[{
     "dyad", " ", "sum", " ", "equals", " ", "transverse", " ", 
      "projector"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"testProjPlus", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"projP", "-", "dyadSumP"}], "]"}], "/.", "sub"}], "]"}], "===", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testProjMinus", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"projM", "-", "dyadSumM"}], "]"}], "/.", "sub"}], "]"}], "===", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{"testProjPlus", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] Projector = SV dyad + SH dyad (downgoing)\>\"", ",",
           "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] Projector decomposition failed (downgoing)\>\"", 
          ",", "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{"testProjMinus", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] Projector = SV dyad + SH dyad (upgoing)\>\"", ",",
           "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] Projector decomposition failed (upgoing)\>\"", ",",
           "Bold", ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",\

 CellLabel->"In[57]:=",ExpressionUUID->"c131aa1f-f5fa-4ad4-bc62-4ca3ffd0b18b"],

Cell[BoxData[
 TagBox[GridBox[{
    {
     StyleBox["\<\"[PASS] Projector = SV dyad + SH dyad (downgoing)\"\>",
      StripOnInput->False,
      LineColor->RGBColor[0, 
        Rational[2, 3], 0],
      FrontFaceColor->RGBColor[0, 
