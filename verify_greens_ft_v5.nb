Cell[CellGroupData[{

Cell["8. Complete P + SV + SH Reconstruction", "Section",ExpressionUUID->"78ac0258-5caa-4e56-8397-e76f5ad0d22e"],

Cell["\<\
As a final cross-check, verify that the sum of all three dyadic contributions \
(P + SV + SH) for each direction reconstructs the total contour result (P + \
S) from Section 2.\
\>", "Text",ExpressionUUID->"6c4f6d3b-3c9f-4aa1-b41c-587c1e06c3f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Total", " ", "contour", " ", "result", " ", "from", " ", "residues"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"totalDn", "=", 
     RowBox[{"cLp", "+", "cTp"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"totalUp", "=", 
     RowBox[{"cLm", "+", "cTm"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Test", " ", "on", " ", "raw", " ", "differences", " ", "with", " ", 
     "Together"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"testTotalDn", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cLp", "+", "cTp", "-", "cLpDyad", "-", "cTpSVSH"}], "]"}], "/.",
         "sub"}], "]"}], "===", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testTotalUp", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cLm", "+", "cTm", "-", "cLmDyad", "-", "cTmSVSH"}], "]"}], "/.",
         "sub"}], "]"}], "===", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{"testTotalDn", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] Downgoing: P + SV + SH dyads = total contour \
result\>\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] Downgoing reconstruction failed\>\"", ",", 
          "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{"testTotalUp", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] Upgoing: P + SV + SH dyads = total contour \
result\>\"", ",", "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] Upgoing reconstruction failed\>\"", ",", "Bold", 
          ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",
 CellLabel->"In[72]:=",ExpressionUUID->"6fe40eab-7715-46bf-98fc-69e7610a142a"],

