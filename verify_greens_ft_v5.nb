    {
     StyleBox["\<\"[PASS] P-wave upgoing = P dyad\"\>",
      StripOnInput->False,
      LineColor->RGBColor[0, 
        Rational[2, 3], 0],
      FrontFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      BackFaceColor->RGBColor[0, 
        Rational[2, 3], 0],
      GraphicsColor->RGBColor[0, 
        Rational[2, 3], 0],
      FontWeight->Bold,
      FontColor->RGBColor[0, 
        Rational[2, 3], 0]]}
   },
   DefaultBaseStyle->"Column",
   GridBoxAlignment->{"Columns" -> {{Left}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Column"]], "Output",
 CellChangeTimes->{3.981677185050249*^9, 3.9816782199486322`*^9, 
  3.981678351246022*^9, 3.981679017345544*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"ae4b214f-d2d1-4117-ad65-718add6946b8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Rank of P-wave downgoing matrix: \>\"", ",", 
   RowBox[{"MatrixRank", "[", "cLp", "]"}]}], "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Rank of P-wave upgoing matrix: \>\"", ",", 
   RowBox[{"MatrixRank", "[", "cLm", "]"}]}], "]"}]}], "Input",
 CellLabel->"In[27]:=",ExpressionUUID->"6986d393-c7ed-457b-9815-6f25c8ef10fa"],

