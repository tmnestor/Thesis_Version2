   RowBox[{"{", 
    RowBox[{"\[Xi]3", "\[Rule]", "0"}], "}"}]}], ";"}], "\n", 
 RowBox[{}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"Style", "[", 
   RowBox[{"\"\<At \[Xi]3 = 0 (2.5-D limit):\>\"", ",", "Bold"}], "]"}], 
  "]"}], "\n", 
