Cell[CellGroupData[{

Cell["4. S-Wave Transverse Projector (Eqns. A.19-A.21)", "Section",ExpressionUUID->"98a5c41f-c384-4f45-97c0-a29686a91b49"],

Cell["\<\
The S-wave matrix should factorise as a transverse projector, giving the \
S-wave contribution scaled by a scalar prefactor.\
\>", "Text",ExpressionUUID->"d43d5b7c-7ca6-4a36-956d-2e6f1cf08b77"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"S", "-", 
    RowBox[{"wave", " ", "propagation", " ", "vectors", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eqn", ".", " ", "A"}], ".19"}], ")"}]}]}], " ", "*)"}], "\n", 
  
  RowBox[{
   RowBox[{
    RowBox[{"qPlus", "=", 
     RowBox[{"{", 
      RowBox[{"\[Nu]T", ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], ";"}], "\n", 
   
   RowBox[{
    RowBox[{"qMinus", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "\[Nu]T"}], ",", "\[Xi]2", ",", "\[Xi]3"}], "}"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Transverse", " ", 
     RowBox[{"projector", ":", " ", 
      RowBox[{"I", " ", "-", " ", 
       RowBox[{"qhat", " ", 
        RowBox[{"qhat", "^", "T"}]}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"projP", "=", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "3", "]"}], "-", 
      FractionBox[
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "qPlus", ",", "qPlus"}], "]"}], 
       RowBox[{
        SuperscriptBox["\[Nu]T", "2"], "+", "\[Xi]h2"}]]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"projM", "=", 
     RowBox[{
      RowBox[{"IdentityMatrix", "[", "3", "]"}], "-", 
      FractionBox[
       RowBox[{"Outer", "[", 
        RowBox[{"Times", ",", "qMinus", ",", "qMinus"}], "]"}], 
       RowBox[{
        SuperscriptBox["\[Nu]T", "2"], "+", "\[Xi]h2"}]]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Expected", " ", "S"}], "-", 
     RowBox[{"wave", " ", "contour", " ", "contributions", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Eqn", ".", " ", "A"}], ".21"}], ")"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cTpProj", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"I", " ", "\[Pi]"}], 
       RowBox[{"\[Mu]", " ", "\[Nu]T"}]], "projP"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cTmProj", "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"-", "I"}], " ", "\[Pi]"}], 
       RowBox[{"\[Mu]", " ", "\[Nu]T"}]], "projM"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Test", ":", " ", 
     RowBox[{
     "transverse", " ", "projector", " ", "form", " ", "matches", " ", 
      "contour", " ", "result"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"testSdnProj", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cTp", "-", "cTpProj"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"testSupProj", "=", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"Together", "[", 
         RowBox[{"cTm", "-", "cTmProj"}], "]"}], "/.", "sub"}], "]"}], "===", 
      
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"3", ",", "3"}], "}"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{"testSdnProj", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] S-wave downgoing = transverse projector\>\"", ",",
           "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] S-wave downgoing projector mismatch\>\"", ",", 
          "Bold", ",", "Red"}], "]"}]}], "]"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{"testSupProj", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] S-wave upgoing = transverse projector\>\"", ",", 
          "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] S-wave upgoing projector mismatch\>\"", ",", 
          "Bold", ",", "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"5af6bd35-f64d-4d85-a84e-0b3cd36a94aa"],

