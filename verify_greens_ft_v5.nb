Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Orthogonality", " ", "checks"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ortho1p", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVp", ".", "qPlus"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ortho2p", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSH", ".", "qPlus"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ortho3p", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVp", ".", "sSH"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ortho1m", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVm", ".", "qMinus"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ortho2m", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSH", ".", "qMinus"}], "/.", "sub"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ortho3m", "=", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{"sSVm", ".", "sSH"}], "/.", "sub"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"testOrtho", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"ortho1p", "===", "0"}], "&&", 
       RowBox[{"ortho2p", "===", "0"}], "&&", 
       RowBox[{"ortho3p", "===", "0"}], "&&", 
       RowBox[{"ortho1m", "===", "0"}], "&&", 
       RowBox[{"ortho2m", "===", "0"}], "&&", 
       RowBox[{"ortho3m", "===", "0"}]}], ")"}]}], ";"}], "\n", "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSV(+).q(+)  = \>\"", ",", "ortho1p"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSH  .q(+)  = \>\"", ",", "ortho2p"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSV(+).sSH  = \>\"", ",", "ortho3p"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSV(-).q(-) = \>\"", ",", "ortho1m"}], "}"}], "]"}], ",", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSH  .q(-) = \>\"", ",", "ortho2m"}], "}"}], "]"}], ",", 
      
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<sSV(-).sSH = \>\"", ",", "ortho3m"}], "}"}], "]"}], 
      ",", "\"\<\>\"", ",", 
      RowBox[{"If", "[", 
       RowBox[{"testOrtho", ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[PASS] All orthogonality conditions satisfied.\>\"", ",",
           "Bold", ",", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<[FAIL] Orthogonality failure!\>\"", ",", "Bold", ",", 
          "Red"}], "]"}]}], "]"}]}], "}"}], "]"}]}]}]], "Input",
 CellLabel->"In[49]:=",ExpressionUUID->"c64ef10d-a12c-4de0-95d8-d7db036766d0"],

