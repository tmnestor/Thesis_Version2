Cell[CellGroupData[{

Cell["11. Numerical Verification of Symbolic Tests", "Section",ExpressionUUID->"d51340e6-570b-4a81-a3a8-e33afadbead3"],

Cell["\<\
FullSimplify may not reduce all symbolic differences to zero. We cross-check \
with exact rational arithmetic at a specific point.\
\>", "Text",ExpressionUUID->"4d82a992-4391-4cb7-ad7b-1353869b25c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Consistent", " ", "test", " ", "point"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"numVal", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Xi]2", "\[Rule]", 
        FractionBox["1", "2"]}], ",", 
       RowBox[{"\[Xi]3", "\[Rule]", 
        FractionBox["1", "4"]}], ",", 
       RowBox[{"\[Xi]h2", "\[Rule]", 
        FractionBox["5", "16"]}], ",", 
       RowBox[{"\[Mu]", "\[Rule]", "2"}], ",", 
       RowBox[{"\[Rho]", "\[Rule]", "1"}], ",", 
       RowBox[{"\[Omega]", "\[Rule]", 
        RowBox[{"Sqrt", "[", "6", "]"}]}], ",", 
       RowBox[{"\[Lambda]", "\[Rule]", "4"}], ",", 
       RowBox[{"kT2", "\[Rule]", "3"}], ",", 
       RowBox[{"kL2", "\[Rule]", 
        FractionBox["3", "4"]}], ",", 
       RowBox[{"\[Nu]T", "\[Rule]", 
        FractionBox[
         RowBox[{"Sqrt", "[", "43", "]"}], "4"]}], ",", 
       RowBox[{"\[Nu]L", "\[Rule]", 
        FractionBox[
         RowBox[{"Sqrt", "[", "7", "]"}], "4"]}]}], "}"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Numerical", " ", "zero"}], "-", 
     RowBox[{"matrix", " ", "test"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"numZero", "[", "m_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Max", "[", 
       RowBox[{"Abs", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{"N", "[", 
          RowBox[{"m", "/.", "numVal"}], "]"}], "]"}], "]"}], "]"}], "<", 
      SuperscriptBox["10", 
       RowBox[{"-", "10"}]]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Re", "-", 
     RowBox[{
     "check", " ", "any", " ", "symbolic", " ", "FAILs", " ", 
      "numerically"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", "testSupProj"}], ",", 
      RowBox[{"testSupProj", "=", 
       RowBox[{"numZero", "[", 
        RowBox[{
         RowBox[{"cTm", "-", "cTmProj"}], "/.", "sub"}], "]"}]}]}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", "testSdnSVSH"}], ",", 
      RowBox[{"testSdnSVSH", "=", 
       RowBox[{"numZero", "[", 
        RowBox[{
         RowBox[{"cTp", "-", "cTpSVSH"}], "/.", "sub"}], "]"}]}]}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", "testSupSVSH"}], ",", 
      RowBox[{"testSupSVSH", "=", 
       RowBox[{"numZero", "[", 
        RowBox[{
         RowBox[{"cTm", "-", "cTmSVSH"}], "/.", "sub"}], "]"}]}]}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", "testTotalDn"}], ",", 
      RowBox[{"testTotalDn", "=", 
       RowBox[{"numZero", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cLp", "+", "cTp"}], "-", "cLpDyad", "-", "cTpSVSH"}], "/.",
          "sub"}], "]"}]}]}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"!", "testTotalUp"}], ",", 
      RowBox[{"testTotalUp", "=", 
       RowBox[{"numZero", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cLm", "+", "cTm"}], "-", "cLmDyad", "-", "cTmSVSH"}], "/.",
          "sub"}], "]"}]}]}], "]"}], ";"}]}]}]], "Input",
 CellLabel->
  "In[100]:=",ExpressionUUID->"c0d00e37-056b-4ac7-bae6-6eed8b2ea597"],

Cell["\<\
If any test still fails after numerical verification, compute the \
multiplicative factor by which the result differs from the expected form.\
\>", "Text",ExpressionUUID->"f134b837-daef-40d5-a0cb-81fb2f0d9d0a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Diagnostic", ":", " ", 
    RowBox[{
    "compute", " ", "ratio", " ", "for", " ", "any", " ", "remaining", " ", 
     "failures"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ratioAt", "[", 
     RowBox[{"actual_", ",", "expected_", ",", 
      RowBox[{"{", 
       RowBox[{"i_", ",", "k_"}], "}"}]}], "]"}], ":=", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"actual", "\[LeftDoubleBracket]", 
       RowBox[{"i", ",", "k"}], "\[RightDoubleBracket]"}], "/", 
      RowBox[{"expected", "\[LeftDoubleBracket]", 
       RowBox[{"i", ",", "k"}], "\[RightDoubleBracket]"}]}], "]"}]}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"S", "-", 
     RowBox[{"wave", " ", 
      RowBox[{"upgoing", ":", " ", 
       RowBox[{
       "ratio", " ", "of", " ", "actual", " ", "to", " ", "expected"}]}]}]}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<Diagnostic ratios (actual / expected):\>\"", ",", "Bold"}],
       "]"}], "]"}], ";"}], "\n", 
   RowBox[{"Print", "[", "\"\<\>\"", "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<S-wave upgoing [2,2]: cTm / cTmProj = \>\"", ",", 
     RowBox[{"ratioAt", "[", 
      RowBox[{"cTm", ",", 
       RowBox[{"cTmProj", "/.", "sub"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<S-wave dn [2,2]: cTp / cTpSVSH = \>\"", ",", 
     RowBox[{"ratioAt", "[", 
      RowBox[{"cTp", ",", 
       RowBox[{"cTpSVSH", "/.", "sub"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<S-wave up [2,2]: cTm / cTmSVSH = \>\"", ",", 
     RowBox[{"ratioAt", "[", 
      RowBox[{"cTm", ",", 
       RowBox[{"cTmSVSH", "/.", "sub"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Total dn [2,2]: (cLp+cTp) / (cLpDyad+cTpSVSH) = \>\"", ",", 
     RowBox[{"ratioAt", "[", 
      RowBox[{
       RowBox[{"cLp", "+", "cTp"}], ",", 
       RowBox[{
        RowBox[{"cLpDyad", "+", "cTpSVSH"}], "/.", "sub"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Total up [2,2]: (cLm+cTm) / (cLmDyad+cTmSVSH) = \>\"", ",", 
     RowBox[{"ratioAt", "[", 
      RowBox[{
       RowBox[{"cLm", "+", "cTm"}], ",", 
       RowBox[{
        RowBox[{"cLmDyad", "+", "cTmSVSH"}], "/.", "sub"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], "]"}], "\n", "\n", 
   RowBox[{"Print", "[", "\"\<\>\"", "]"}], "\n", 
   RowBox[{
   "Print", "[", "\"\<(All ratios should be 1 if the formulas are \
correct)\>\"", "]"}]}]}]], "Input",
 CellLabel->
  "In[107]:=",ExpressionUUID->"88bfba18-f652-4f3b-9d65-1df1c73f3fcf"],

Cell[CellGroupData[{

Cell[BoxData[
 StyleBox["\<\"Diagnostic ratios (actual / expected):\"\>",
  StripOnInput->False,
